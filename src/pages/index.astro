---
/**
 * Homepage — AZ Law Now
 * EDITORIAL-FIRST homepage. Front page of a publication.
 *
 * Flow:
 * 1. Editorial hero — warm cream, big serif headline, no dark photo overlay
 * 2. Featured investigation grid — 1+2 newspaper layout
 * 3. "What We're Watching" — data nuggets, dark strip
 * 4. Three content hubs (Investigated / Answered / Guided) — editorial grid
 * 5. Abuse & Negligence Spotlight — editorial callout, vermillion accent
 * 6. Practice areas — grouped by cluster with subheadings
 * 7. West Valley locations — minimal
 * 8. Results teaser — editorial, not flashy
 * 9. Team — editorial byline cards
 * 10. Final CTA — warm, not aggressive
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { authors } from '../data/authors';
import { getSiteWideSchemas } from '../utils/schema';

const siteSchemas = getSiteWideSchemas();

const practiceAreaClusters = [
  {
    label: 'Vehicle Crashes',
    areas: [
      { name: 'Car Accidents', url: '/vehicle-crashes/car-accidents/' },
      { name: 'Truck Accidents', url: '/vehicle-crashes/truck-accidents/' },
      { name: 'Motorcycle Accidents', url: '/vehicle-crashes/motorcycle-accidents/' },
      { name: 'Pedestrian Accidents', url: '/vehicle-crashes/pedestrian-accidents/' },
      { name: 'Bus Accidents', url: '/vehicle-crashes/bus-accidents/' },
      { name: 'Bicycle Accidents', url: '/vehicle-crashes/bicycle-accidents/' },
      { name: 'Rideshare Accidents', url: '/vehicle-crashes/rideshare-accidents/' },
    ],
  },
  {
    label: 'Abuse & Negligence',
    areas: [
      { name: 'Elder Abuse', url: '/abuse-negligence/elder-abuse/' },
      { name: 'Nursing Home Abuse', url: '/abuse-negligence/nursing-home-abuse/' },
      { name: 'Child Abuse', url: '/abuse-negligence/child-abuse/' },
      { name: 'Daycare Negligence', url: '/abuse-negligence/daycare-negligence/' },
      { name: 'School Abuse', url: '/abuse-negligence/school-abuse/' },
      { name: 'Medical Negligence', url: '/abuse-negligence/medical-negligence/' },
    ],
  },
  {
    label: 'Other Claims',
    areas: [
      { name: 'Slip and Fall', url: '/other-claims/slip-and-fall/' },
      { name: 'Wrongful Death', url: '/other-claims/wrongful-death/' },
      { name: 'Dog Bite', url: '/other-claims/dog-bite/' },
      { name: 'Premises Liability', url: '/other-claims/premises-liability/' },
    ],
  },
];

const caseResults = [
  { amount: '$800K', type: 'School Bus Negligence', description: 'A child injured when a bus driver failed safety protocol.' },
  { amount: '$745K', type: 'Motor Vehicle Accident', description: 'Spinal injuries from a multi-vehicle I-10 collision.' },
  { amount: '$500K', type: 'Trucking Accident', description: 'Commercial truck ran a red light in Goodyear.' },
  { amount: '$255K', type: 'Rear-End Collision', description: 'Distracted driver crash at a Buckeye intersection.' },
];

const locations = [
  { name: 'Buckeye', label: 'HQ', url: '/buckeye/' },
  { name: 'Maricopa', label: 'New', url: '/maricopa/' },
  { name: 'Goodyear', label: '', url: '/goodyear/' },
  { name: 'Avondale', label: '', url: '/avondale/' },
  { name: 'Phoenix', label: '', url: '/phoenix/' },
];

const dataStats = [
  { value: '4,200+', label: 'Students restrained in AZ schools last year', source: 'ADE Data', url: '/investigations/arizona-school-restraint-data/' },
  { value: '88,094', label: 'Crashes in Maricopa County 2024', source: 'ADOT', url: '/resources/i-10-crash-data-buckeye-goodyear/' },
  { value: '47%', label: 'Nursing homes below average staffing', source: 'CMS', url: '/resources/arizona-nursing-home-violations/' },
  { value: '$800K', label: 'Settlement — school bus negligence', source: 'AZ Law Now', url: '/case-results/' },
];

const brendan = authors['brendan-franks'];
const brandon = authors['brandon-millam'];
const stephanie = authors['stephanie-ramirez'];
---

<BaseLayout
  title="Arizona Injury Attorneys | AZ Law Now — You Get Answers."
  description={siteConfig.defaultDescription}
  schema={siteSchemas}
>

  <!-- ============================== -->
  <!-- EDITORIAL HERO                 -->
  <!-- ============================== -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="/images/heroes/homepage-hero.png"
        alt="AZ Law Now office — family at reception"
        class="hero-bg-img"
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-dateline">Buckeye &amp; West Valley, Arizona</span>
        <h1 class="hero-h1">You Get Answers.</h1>
        <p class="hero-deck">
          The firm that does the work before the case. Original reporting on
          West Valley crash data, clear legal guides, and the people who walk
          you through every step.
        </p>
        <div class="hero-actions">
          <a href="/free-case-review/" class="btn btn-primary btn-lg">
            Get My Free Consultation &rarr;
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-value">Investigated</span>
            <span class="hero-stat-label">We pull the data nobody else does</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">Answered</span>
            <span class="hero-stat-label">Arizona law, explained in plain language</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">Guided</span>
            <span class="hero-stat-label">Every step, every form, every call</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FEATURED INVESTIGATION GRID    -->
  <!-- 1+2 layout: main + 2 secondary -->
  <!-- ============================== -->
  <section class="section featured-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">What We're Covering</span>
        <div class="section-rule"></div>
      </div>
      <div class="featured-grid">
        <!-- Main card — spans both rows -->
        <a href="/investigations/arizona-school-restraint-data/" class="featured-main">
          <div class="featured-card-overlay" aria-hidden="true"></div>
          <div class="featured-card-content">
            <span class="featured-badge">Investigation</span>
            <h2 class="featured-main-headline">Arizona Schools Restrained 4,200+ Students Last Year. Most Were Kids With Disabilities.</h2>
            <div class="featured-byline-inline">
              <img src={brendan.photo} alt="" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brendan.name}</span>
            </div>
          </div>
        </a>
        <!-- Secondary card 1 -->
        <a href="/investigations/maricopa-county-daycare-violations/" class="featured-secondary">
          <div class="featured-card-overlay" aria-hidden="true"></div>
          <div class="featured-card-content">
            <span class="featured-badge">Investigation</span>
            <h3 class="featured-secondary-headline">Maricopa County Daycares With the Most DHS Violations</h3>
            <div class="featured-byline-inline">
              <img src={brendan.photo} alt="" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brendan.name}</span>
            </div>
          </div>
        </a>
        <!-- Secondary card 2 -->
        <a href="/resources/i-10-crash-data-buckeye-goodyear/" class="featured-secondary">
          <div class="featured-card-overlay" aria-hidden="true"></div>
          <div class="featured-card-content">
            <span class="featured-badge">Investigation</span>
            <h3 class="featured-secondary-headline">What the ADOT Data Shows About I-10 Crashes</h3>
            <div class="featured-byline-inline">
              <img src={brendan.photo} alt="" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brendan.name}</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- WHAT WE'RE WATCHING — data     -->
  <!-- ============================== -->
  <section class="watching-section">
    <div class="container">
      <div class="watching-header">
        <span class="watching-eyebrow">What We're Watching</span>
      </div>
      <div class="watching-row">
        {dataStats.map((stat) => (
          <a href={stat.url} class="watching-stat">
            <span class="watching-value">{stat.value}</span>
            <span class="watching-label">{stat.label}</span>
            <span class="watching-source">{stat.source}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- THREE EDITORIAL HUBS           -->
  <!-- Investigated / Answered / Guided -->
  <!-- ============================== -->
  <section class="section hubs-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">How We Work</span>
        <div class="section-rule"></div>
      </div>
      <div class="hubs-grid">
        <a href="/resources/" class="hub-card">
          <div class="hub-number">01</div>
          <h3 class="hub-tag">Investigated.</h3>
          <h4 class="hub-title">Resources</h4>
          <p class="hub-description">
            This month: school restraint data across Arizona districts, West
            Valley daycare inspection failures, and SR-347 crash corridor analysis.
          </p>
          <div class="hub-author">
            <img src={brendan.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">{brendan.name.split(' ')[0]} runs the desk.</span>
          </div>
          <span class="hub-link">Explore the data &rarr;</span>
        </a>
        <a href="/legal-guides/" class="hub-card">
          <div class="hub-number">02</div>
          <h3 class="hub-tag">Answered.</h3>
          <h4 class="hub-title">Legal Guides</h4>
          <p class="hub-description">
            Latest: Arizona school liability law explained, mandatory reporting
            requirements, and daycare licensing standards for parents.
          </p>
          <div class="hub-author">
            <img src={brandon.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">Reviewed by {brandon.name.split(',')[0]}.</span>
          </div>
          <span class="hub-link">Read the guides &rarr;</span>
        </a>
        <a href="/client-guides/" class="hub-card">
          <div class="hub-number">03</div>
          <h3 class="hub-tag">Guided.</h3>
          <h4 class="hub-title">Client Guides</h4>
          <p class="hub-description">
            New: What to do if your child was restrained at school. Your daycare
            negligence action plan. Signs of nursing home abuse checklist.
          </p>
          <div class="hub-author">
            <img src={stephanie.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">{stephanie.name.split(' ')[0]} makes it clear.</span>
          </div>
          <span class="hub-link">See what's next &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- ABUSE & NEGLIGENCE SPOTLIGHT   -->
  <!-- ============================== -->
  <section class="section spotlight-section">
    <div class="container">
      <div class="spotlight-content">
        <span class="spotlight-eyebrow">Focus Area</span>
        <h2 class="spotlight-heading">Nobody Else Is Covering This.</h2>
        <p class="spotlight-intro">
          Arizona's systems fail vulnerable people every day. Kids with
          disabilities restrained at school. Elders neglected in understaffed
          facilities. Daycares that haven't passed inspection.
        </p>
        <p class="spotlight-intro">
          We pull the public data. We name the patterns.
        </p>
      </div>
      <div class="spotlight-cards">
        <a href="/abuse-negligence/elder-abuse/" class="spotlight-card">
          <span class="spotlight-card-title">Elder Abuse</span>
          <span class="spotlight-card-desc">Understaffed facilities. Missing oversight. Real data on Arizona's elder care failures.</span>
          <span class="spotlight-card-link">Read &rarr;</span>
        </a>
        <a href="/abuse-negligence/school-abuse/" class="spotlight-card">
          <span class="spotlight-card-title">School Abuse</span>
          <span class="spotlight-card-desc">Restraint data, reporting gaps, and what Arizona districts aren't telling parents.</span>
          <span class="spotlight-card-link">Read &rarr;</span>
        </a>
        <a href="/abuse-negligence/daycare-negligence/" class="spotlight-card">
          <span class="spotlight-card-title">Daycare Negligence</span>
          <span class="spotlight-card-desc">DHS violations, inspection records, and the daycares with the worst track records.</span>
          <span class="spotlight-card-link">Read &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- PRACTICE AREAS + LOCATIONS     -->
  <!-- Grouped by cluster             -->
  <!-- ============================== -->
  <section class="section compact-section">
    <div class="container compact-grid">
      <div class="compact-left">
        <div class="section-header">
          <span class="section-eyebrow">How We Help</span>
          <div class="section-rule"></div>
        </div>
        {practiceAreaClusters.map((cluster) => (
          <div class="cluster-group">
            <h3 class="cluster-label">{cluster.label}</h3>
            <div class="practice-list">
              {cluster.areas.map((area) => (
                <a href={area.url} class="practice-link">
                  <span>{area.name}</span>
                  <span class="practice-arrow">&rarr;</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="compact-right">
        <div class="section-header">
          <span class="section-eyebrow">West Valley Offices</span>
          <div class="section-rule"></div>
        </div>
        <p class="locations-intro">
          Two offices. Five core service areas. One team that knows this
          part of Arizona.
        </p>
        <div class="locations-stack">
          {locations.map((loc) => (
            <a href={loc.url} class="location-row">
              <span class="location-name">{loc.name}</span>
              {loc.label && <span class="location-badge">{loc.label}</span>}
            </a>
          ))}
        </div>
        <div class="locations-cta">
          <a href="/contact/" class="btn btn-outline-sm">Visit an office &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- CASE RESULTS — editorial       -->
  <!-- ============================== -->
  <section class="section results-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Results That Matter</span>
        <div class="section-rule"></div>
      </div>
      <div class="results-row">
        {caseResults.map((result) => (
          <div class="result-item">
            <span class="result-amount">{result.amount}</span>
            <span class="result-type">{result.type}</span>
            <p class="result-desc">{result.description}</p>
          </div>
        ))}
      </div>
      <div class="results-footer">
        <a href="/case-results/" class="btn btn-secondary">See all results &rarr;</a>
        <p class="results-note">Past results do not guarantee future outcomes.</p>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- TEAM — editorial byline cards  -->
  <!-- ============================== -->
  <section class="section team-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">The Team</span>
        <div class="section-rule"></div>
      </div>
      <div class="team-row">
        <a href={brendan.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={brendan.photo} alt={brendan.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{brendan.name}</h3>
            <span class="team-title">{brendan.title}</span>
            <p class="team-bio">Covers West Valley crash data, public safety records, and community accountability.</p>
          </div>
        </a>
        <a href={brandon.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={brandon.photo} alt={brandon.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{brandon.name}</h3>
            <span class="team-title">{brandon.title}</span>
            <p class="team-bio">Reviews every legal guide for accuracy. Practices personal injury law across the West Valley.</p>
          </div>
        </a>
        <a href={stephanie.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={stephanie.photo} alt={stephanie.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{stephanie.name}</h3>
            <span class="team-title">{stephanie.title}</span>
            <p class="team-bio">Writes the guides that walk families through the process. Clear, step by step.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FINAL CTA — warm, not pushy    -->
  <!-- ============================== -->
  <section class="final-cta">
    <div class="container final-cta-inner">
      <h2 class="final-heading">You Deserve Answers.</h2>
      <p class="final-subtext">Tell us what happened. We'll tell you what's next.</p>
      <div class="final-actions">
        <a href="/free-case-review/" class="btn btn-primary btn-lg">Get My Free Consultation &rarr;</a>
        <a href={`tel:${siteConfig.phoneE164}`} class="final-phone">Or call {siteConfig.phoneFormatted}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     EDITORIAL HERO
     ======================================== */
  .hero {
    position: relative;
    padding: var(--space-20, 5rem) 0 var(--space-16, 4rem);
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 26, 26, 0.88) 0%,
      rgba(26, 26, 26, 0.75) 50%,
      rgba(26, 26, 26, 0.45) 100%
    );
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12, 3rem);
    align-items: center;
    max-width: 680px;
  }

  .hero-dateline {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold, #D4943A);
    margin-bottom: var(--space-4, 1rem);
    padding-bottom: var(--space-2, 0.5rem);
    border-bottom: 2px solid var(--color-gold, #D4943A);
  }

  .hero-h1 {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.0;
    color: #FFFFFF;
    margin-bottom: var(--space-6, 1.5rem);
  }

  .hero-deck {
    font-size: var(--text-lg, 1.125rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    margin-bottom: var(--space-8, 2rem);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    flex-wrap: wrap;
    margin-bottom: var(--space-10, 2.5rem);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    padding-top: var(--space-6, 1.5rem);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--color-gold, #D4943A);
    line-height: 1.2;
  }

  .hero-stat-label {
    display: block;
    font-size: var(--text-xs, 0.75rem);
    color: rgba(255, 255, 255, 0.65);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
  }

  /* ========================================
     SHARED SECTION STYLES
     ======================================== */
  .section { padding: var(--space-16, 4rem) 0; }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-4, 1rem);
    margin-bottom: var(--space-8, 2rem);
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold, #D4943A);
    white-space: nowrap;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--neutral-200, #E8DFD0);
  }

  /* ========================================
     FEATURED INVESTIGATION GRID — 1+2
     ======================================== */
  .featured-section {
    background: var(--color-white, #FFFFFF);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-4, 1rem);
    min-height: 460px;
  }

  .featured-main,
  .featured-secondary {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    background: var(--color-black, #1A1A1A);
    transition: transform 0.2s ease;
  }

  .featured-main:hover,
  .featured-secondary:hover {
    transform: translateY(-2px);
  }

  .featured-main {
    grid-row: 1 / 3;
  }

  .featured-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.92) 0%,
      rgba(26, 26, 26, 0.5) 50%,
      rgba(26, 26, 26, 0.25) 100%
    );
    z-index: 1;
  }

  .featured-card-content {
    position: relative;
    z-index: 2;
    padding: var(--space-6, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  .featured-badge {
    display: inline-block;
    align-self: flex-start;
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--color-red, #C23B22);
    padding: 0.25rem 0.75rem;
    border-radius: 3px;
  }

  .featured-main-headline {
    font-family: var(--font-heading);
    font-size: var(--text-3xl, 2rem);
    font-weight: 700;
    line-height: 1.15;
