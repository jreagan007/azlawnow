---
/**
 * Homepage — AZ Law Now
 * EDITORIAL-FIRST homepage. This is NOT a generic PI law firm template.
 * This reads like a publication: above-the-fold investigation, author hubs,
 * data-driven insights, southwestern Arizona identity.
 *
 * Flow:
 * 1. Editorial hero — warm cream, big serif headline, no dark photo overlay
 * 2. Featured investigation — newspaper-style card, full-width
 * 3. Three content hubs (Investigated / Answered / Guided) — editorial grid
 * 4. "What We're Watching" — data nuggets / Arizona stats
 * 5. Practice areas — compact, sidebar-style, not the whole page
 * 6. West Valley locations — minimal
 * 7. Results teaser — editorial, not flashy
 * 8. Team — editorial byline cards
 * 9. Final CTA — warm, not aggressive
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { authors } from '../data/authors';
import { getSiteWideSchemas } from '../utils/schema';

const siteSchemas = getSiteWideSchemas();

const practiceAreas = [
  { name: 'Car Accidents', url: '/car-accidents/', icon: '→' },
  { name: 'Truck Accidents', url: '/truck-accidents/', icon: '→' },
  { name: 'Motorcycle Accidents', url: '/motorcycle-accidents/', icon: '→' },
  { name: 'Wrongful Death', url: '/wrongful-death/', icon: '→' },
  { name: 'Elder Abuse', url: '/elder-abuse/', icon: '→' },
  { name: 'Nursing Home Abuse', url: '/nursing-home-abuse/', icon: '→' },
  { name: 'Bus Accidents', url: '/bus-accidents/', icon: '→' },
  { name: 'Pedestrian Accidents', url: '/pedestrian-accidents/', icon: '→' },
  { name: 'Bicycle Accidents', url: '/bicycle-accidents/', icon: '→' },
  { name: 'Slip and Fall', url: '/slip-and-fall/', icon: '→' },
  { name: 'Medical Negligence', url: '/medical-negligence/', icon: '→' },
  { name: 'Dog Bite', url: '/dog-bite/', icon: '→' },
];

const caseResults = [
  { amount: '$800K', type: 'School Bus Negligence', description: 'A child injured when a bus driver failed safety protocol.' },
  { amount: '$745K', type: 'Motor Vehicle Accident', description: 'Spinal injuries from a multi-vehicle I-10 collision.' },
  { amount: '$500K', type: 'Trucking Accident', description: 'Commercial truck ran a red light in Goodyear.' },
  { amount: '$255K', type: 'Rear-End Collision', description: 'Distracted driver crash at a Buckeye intersection.' },
];

const locations = [
  { name: 'Buckeye', label: 'HQ', url: '/buckeye/' },
  { name: 'Maricopa', label: 'New', url: '/maricopa/' },
  { name: 'Goodyear', label: '', url: '/goodyear/' },
  { name: 'Avondale', label: '', url: '/avondale/' },
  { name: 'Phoenix', label: '', url: '/phoenix/' },
];

const brendan = authors['brendan-franks'];
const brandon = authors['brandon-millam'];
const stephanie = authors['stephanie-ramirez'];
---

<BaseLayout
  title="Arizona Injury Attorneys | AZ Law Now — You Get Answers."
  description={siteConfig.defaultDescription}
  schema={siteSchemas}
>

  <!-- ============================== -->
  <!-- EDITORIAL HERO                 -->
  <!-- Warm cream, no dark overlay.   -->
  <!-- Southwestern, not NYC.         -->
  <!-- ============================== -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-dateline">Buckeye &amp; West Valley, Arizona</span>
        <h1 class="hero-h1">You Get Answers.</h1>
        <p class="hero-deck">
          The firm that does the work before the case. Original reporting on
          West Valley crash data, clear legal guides, and the people who walk
          you through every step.
        </p>
        <div class="hero-actions">
          <a href="/free-case-review/" class="btn btn-primary btn-lg">
            Get My Free Consultation &rarr;
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-value">$3.07M+</span>
            <span class="hero-stat-label">Recovered</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">No Fee</span>
            <span class="hero-stat-label">Unless We Win</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">Free</span>
            <span class="hero-stat-label">Consultations</span>
          </div>
        </div>
      </div>
      <div class="hero-accent">
        <!-- Desert-warm illustration zone — cactus mark + warm gradient -->
        <div class="hero-mark-wrapper">
          <img
            src="/logos/logo-dark.png"
            alt=""
            class="hero-cactus"
            width="160"
            height="160"
            aria-hidden="true"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FEATURED INVESTIGATION         -->
  <!-- Newspaper-style, full-width    -->
  <!-- ============================== -->
  <section class="section featured-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">What We're Covering</span>
        <div class="section-rule"></div>
      </div>
      <article class="featured-card">
        <div class="featured-image">
          <div class="featured-image-inner">
            <span class="featured-badge">Investigation</span>
          </div>
        </div>
        <div class="featured-body">
          <h2 class="featured-headline">
            <a href="/resources/i-10-crashes-buckeye-goodyear-adot-data/">
              What the ADOT Data Shows About I-10 Crashes in Buckeye and Goodyear
            </a>
          </h2>
          <p class="featured-excerpt">
            We pulled three years of ADOT crash reports for the I-10 corridor
            between Buckeye and Goodyear. Speed, volume, and commercial truck
            traffic are converging in one of Arizona's fastest-growing highway
            stretches.
          </p>
          <div class="featured-byline">
            <img src={brendan.photo} alt={brendan.name} class="byline-avatar" width="40" height="40" loading="lazy" />
            <div class="byline-meta">
              <span class="byline-name">{brendan.name}</span>
              <span class="byline-role">Investigative Reporter</span>
            </div>
            <a href="/resources/i-10-crashes-buckeye-goodyear-adot-data/" class="featured-read">Read the report &rarr;</a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============================== -->
  <!-- THREE EDITORIAL HUBS           -->
  <!-- Investigated / Answered / Guided -->
  <!-- ============================== -->
  <section class="section hubs-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">How We Work</span>
        <div class="section-rule"></div>
      </div>
      <div class="hubs-grid">
        <a href="/resources/" class="hub-card">
          <div class="hub-number">01</div>
          <h3 class="hub-tag">Investigated.</h3>
          <h4 class="hub-title">Resources</h4>
          <p class="hub-description">
            Original reporting on West Valley crash data, public safety
            records, and the stories behind the numbers.
          </p>
          <div class="hub-author">
            <img src={brendan.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">{brendan.name.split(' ')[0]} runs the desk.</span>
          </div>
          <span class="hub-link">Explore the data &rarr;</span>
        </a>
        <a href="/legal-guides/" class="hub-card">
          <div class="hub-number">02</div>
          <h3 class="hub-tag">Answered.</h3>
          <h4 class="hub-title">Legal Guides</h4>
          <p class="hub-description">
            Arizona injury law explained in plain language. Statutes,
            deadlines, and what they mean for your case.
          </p>
          <div class="hub-author">
            <img src={brandon.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">Reviewed by {brandon.name.split(',')[0]}.</span>
          </div>
          <span class="hub-link">Read the guides &rarr;</span>
        </a>
        <a href="/client-guides/" class="hub-card">
          <div class="hub-number">03</div>
          <h3 class="hub-tag">Guided.</h3>
          <h4 class="hub-title">Client Guides</h4>
          <p class="hub-description">
            Step-by-step walkthroughs for everything after the injury. What
            to expect, what matters, how timelines work.
          </p>
          <div class="hub-author">
            <img src={stephanie.photo} alt="" class="hub-author-photo" width="28" height="28" loading="lazy" />
            <span class="hub-author-name">{stephanie.name.split(' ')[0]} makes it clear.</span>
          </div>
          <span class="hub-link">See what's next &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- PRACTICE + LOCATIONS SPLIT     -->
  <!-- Compact, not the whole page    -->
  <!-- ============================== -->
  <section class="section compact-section">
    <div class="container compact-grid">
      <div class="compact-left">
        <div class="section-header">
          <span class="section-eyebrow">How We Help</span>
          <div class="section-rule"></div>
        </div>
        <div class="practice-list">
          {practiceAreas.map((area) => (
            <a href={area.url} class="practice-link">
              <span>{area.name}</span>
              <span class="practice-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
      <div class="compact-right">
        <div class="section-header">
          <span class="section-eyebrow">West Valley Offices</span>
          <div class="section-rule"></div>
        </div>
        <p class="locations-intro">
          Two offices. Five core service areas. One team that knows this
          part of Arizona.
        </p>
        <div class="locations-stack">
          {locations.map((loc) => (
            <a href={loc.url} class="location-row">
              <span class="location-name">{loc.name}</span>
              {loc.label && <span class="location-badge">{loc.label}</span>}
            </a>
          ))}
        </div>
        <div class="locations-cta">
          <a href="/contact/" class="btn btn-outline-sm">Visit an office &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- CASE RESULTS — editorial       -->
  <!-- ============================== -->
  <section class="section results-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Results That Matter</span>
        <div class="section-rule"></div>
      </div>
      <div class="results-row">
        {caseResults.map((result) => (
          <div class="result-item">
            <span class="result-amount">{result.amount}</span>
            <span class="result-type">{result.type}</span>
            <p class="result-desc">{result.description}</p>
          </div>
        ))}
      </div>
      <div class="results-footer">
        <a href="/case-results/" class="btn btn-secondary">See all results &rarr;</a>
        <p class="results-note">Past results do not guarantee future outcomes.</p>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- TEAM — editorial byline cards  -->
  <!-- ============================== -->
  <section class="section team-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">The Team</span>
        <div class="section-rule"></div>
      </div>
      <div class="team-row">
        <a href={brendan.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={brendan.photo} alt={brendan.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{brendan.name}</h3>
            <span class="team-title">{brendan.title}</span>
            <p class="team-bio">Covers West Valley crash data, public safety records, and community accountability.</p>
          </div>
        </a>
        <a href={brandon.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={brandon.photo} alt={brandon.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{brandon.name}</h3>
            <span class="team-title">{brandon.title}</span>
            <p class="team-bio">Reviews every legal guide for accuracy. Practices personal injury law across the West Valley.</p>
          </div>
        </a>
        <a href={stephanie.url} class="team-card">
          <div class="team-photo-wrap">
            <img src={stephanie.photo} alt={stephanie.name} class="team-photo" width="96" height="96" loading="lazy" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{stephanie.name}</h3>
            <span class="team-title">{stephanie.title}</span>
            <p class="team-bio">Writes the guides that walk families through the process. Clear, step by step.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FINAL CTA — warm, not pushy    -->
  <!-- ============================== -->
  <section class="final-cta">
    <div class="container final-cta-inner">
      <h2 class="final-heading">You Deserve Answers.</h2>
      <p class="final-subtext">Tell us what happened. We'll tell you what's next.</p>
      <div class="final-actions">
        <a href="/free-case-review/" class="btn btn-primary btn-lg">Get My Free Consultation &rarr;</a>
        <a href={`tel:${siteConfig.phoneE164}`} class="final-phone">Or call {siteConfig.phoneFormatted}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     EDITORIAL HERO — warm cream, typography-led
     NOT a dark overlay on photo like aeelaw
     ======================================== */
  .hero {
    background: var(--color-bg, #FAF5ED);
    padding: var(--space-20, 5rem) 0 var(--space-16, 4rem);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-12, 3rem);
    align-items: center;
  }

  .hero-dateline {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-red, #C23B22);
    margin-bottom: var(--space-4, 1rem);
    padding-bottom: var(--space-2, 0.5rem);
    border-bottom: 2px solid var(--color-red, #C23B22);
  }

  .hero-h1 {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.0;
    color: var(--color-black, #1A1A1A);
    margin-bottom: var(--space-6, 1.5rem);
  }

  .hero-deck {
    font-size: var(--text-lg, 1.125rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.65;
    margin-bottom: var(--space-8, 2rem);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    flex-wrap: wrap;
    margin-bottom: var(--space-10, 2.5rem);
  }

  .hero-phone-link {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .hero-phone-link:hover { color: var(--color-gold, #D4943A); }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    padding-top: var(--space-6, 1.5rem);
    border-top: 1px solid var(--neutral-200, #E8DFD0);
  }

  .hero-stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--color-gold, #D4943A);
    line-height: 1.2;
  }

  .hero-stat-label {
    display: block;
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background: var(--neutral-200, #E8DFD0);
  }

  .hero-accent {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-mark-wrapper {
    width: 220px;
    height: 220px;
    background: linear-gradient(145deg, rgba(212, 148, 58, 0.08) 0%, rgba(194, 59, 34, 0.05) 100%);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-cactus {
    opacity: 0.15;
    width: 140px;
    height: 140px;
  }

  /* ========================================
     SHARED SECTION STYLES — editorial
     ======================================== */
  .section { padding: var(--space-16, 4rem) 0; }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-4, 1rem);
    margin-bottom: var(--space-8, 2rem);
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold, #D4943A);
    white-space: nowrap;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--neutral-200, #E8DFD0);
  }

  /* ========================================
     FEATURED INVESTIGATION
     ======================================== */
  .featured-section {
    background: var(--color-white, #FFFFFF);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .featured-card {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-8, 2rem);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-lg, 8px);
    overflow: hidden;
    background: var(--color-bg, #FAF5ED);
  }

  .featured-image { min-height: 280px; }

  .featured-image-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, var(--neutral-200) 0%, var(--neutral-300, #D4CFC6) 100%);
    display: flex;
    align-items: flex-end;
    padding: var(--space-4, 1rem);
  }

  .featured-badge {
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--color-red, #C23B22);
    padding: 0.25rem 0.75rem;
    border-radius: 3px;
  }

  .featured-body {
    padding: var(--space-8, 2rem) var(--space-8, 2rem) var(--space-8, 2rem) 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-headline {
    font-family: var(--font-heading);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: var(--space-4, 1rem);
  }

  .featured-headline a {
    color: var(--color-black, #1A1A1A);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .featured-headline a:hover { color: var(--color-gold, #D4943A); }

  .featured-excerpt {
    font-size: var(--text-base, 1rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.7;
    margin-bottom: var(--space-6, 1.5rem);
  }

  .featured-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
  }

  .byline-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200, #E8DFD0);
  }

  .byline-meta { flex: 1; }

  .byline-name {
    display: block;
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-black, #1A1A1A);
  }

  .byline-role {
    display: block;
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
  }

  .featured-read {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-gold, #D4943A);
    white-space: nowrap;
    text-decoration: none;
  }

  /* ========================================
     THREE EDITORIAL HUBS
     ======================================== */
  .hubs-section {
    background: var(--color-bg, #FAF5ED);
  }

  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6, 1.5rem);
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-8, 2rem);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
  }

  .hub-card:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 8px 24px rgba(212, 148, 58, 0.08);
    transform: translateY(-2px);
  }

  .hub-number {
    font-family: var(--font-heading);
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--neutral-200, #E8DFD0);
    line-height: 1;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .hub-tag {
    font-family: var(--font-heading);
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    font-style: italic;
    color: var(--color-gold, #D4943A);
    margin-bottom: var(--space-1, 0.25rem);
  }

  .hub-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .hub-description {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.7;
    flex: 1;
    margin-bottom: var(--space-4, 1rem);
  }

  .hub-author {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    margin-bottom: var(--space-4, 1rem);
  }

  .hub-author-photo {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }

  .hub-author-name {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
    font-style: italic;
  }

  .hub-link {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-gold, #D4943A);
  }

  /* ========================================
     PRACTICE + LOCATIONS SPLIT
     ======================================== */
  .compact-section {
    background: var(--color-white, #FFFFFF);
    border-top: 1px solid var(--neutral-200, #E8DFD0);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .compact-grid {
    display: grid;
