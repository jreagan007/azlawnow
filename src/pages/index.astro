    align-items: center;
    justify-content: center;
    gap: var(--space-12);
    flex-wrap: wrap;
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--neutral-100, #F5EDE0);
    margin-bottom: var(--space-10);
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    text-align: center;
  }

  .proof-stat__value {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    line-height: 1;
  }

  .proof-stat__stars {
    display: flex;
    gap: 1px;
    margin-top: var(--space-1);
  }

  .proof-stat__label {
    font-size: var(--text-xs);
    color: var(--color-slate, #4A5859);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .social-proof__heading {
    display: flex;
    align-items: center;
    gap: var(--space-4, 1rem);
    margin: 0 0 var(--space-8, 2rem);
  }

  .social-proof__quotes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
    max-width: 920px;
    margin: 0 auto;
  }

  .proof-quote {
    background: var(--color-bg, #FAF5ED);
    border-left: 3px solid var(--color-gold, #D4943A);
    padding: var(--space-6);
    margin: 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .proof-quote__stars {
    display: flex;
    gap: 1px;
    margin-bottom: var(--space-3);
  }

  .proof-quote__text {
    font-size: var(--text-sm);
    color: var(--color-slate, #4A5859);
    line-height: 1.6;
    margin: 0 0 var(--space-3);
    font-style: normal;
  }

  .proof-quote__author {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-style: normal;
  }

  .social-proof__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-10);
    flex-wrap: wrap;
  }

  .social-proof__link {
    color: var(--color-black, #1A1A1A);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--color-gold, #D4943A);
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }

  .social-proof__link:hover {
    color: var(--color-sienna, #8B4513);
  }

  .social-proof__sep {
    color: var(--neutral-300);
  }

  @media (max-width: 768px) {
    .social-proof__stats {
      gap: var(--space-6);
    }

    .social-proof__quotes {
      grid-template-columns: 1fr;
    }

    .proof-stat__value {
      font-size: var(--text-3xl);
    }
  }

  /* ========================================
     FEATURED CLUSTER — 1 lead + 2 supporting
     All three voices on the same topic
     ======================================== */
  /* ========================================
     LATEST INVESTIGATIONS strip — 6-card auto-grid
     ======================================== */
  .latest-investigations {
    background: var(--neutral-50, #FAF7F0);
  }
  .latest-header {
    margin-bottom: var(--space-6, 1.5rem);
  }
  .latest-heading {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 1.875rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0.25rem 0 0;
  }
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .latest-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display: flex;
    flex-direction: column;
  }
  .latest-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(26, 26, 26, 0.08);
  }
  .latest-card-thumb {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }
  .latest-card-body {
    padding: 1rem 1.125rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .latest-card-date {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gold-text, #8B4513);
  }
  .latest-card-title {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.3;
    margin: 0;
    flex: 1;
  }
  .latest-card-link {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
    margin-top: 0.25rem;
  }
  .latest-all {
    display: inline-block;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
    text-decoration: none;
  }
  .latest-all:hover {
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .latest-heading {
      font-size: 1.5rem;
    }
    .latest-card-thumb {
      height: 140px;
    }
  }

  .featured-section {
    background: var(--color-white, #FFFFFF);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .featured-header {
    margin-bottom: var(--space-10, 2.5rem);
    max-width: 720px;
  }

  .featured-cluster-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl, 2rem), 4vw, var(--text-5xl, 3rem));
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin: var(--space-3, 0.75rem) 0 var(--space-3, 0.75rem);
    line-height: 1.1;
  }

  .featured-cluster-intro {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-lg, 1.125rem);
    line-height: 1.6;
    margin: 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-5, 1.25rem);
    min-height: 540px;
  }

  /* Big card: Brendan's investigation (dark, image background) */
  .featured-main {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    background: var(--color-black, #1A1A1A);
    grid-row: 1 / 3;
    transition: transform 0.2s ease;
  }

  .featured-main:hover {
    transform: translateY(-2px);
  }

  .featured-card-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .featured-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.95) 0%,
      rgba(26, 26, 26, 0.65) 45%,
      rgba(26, 26, 26, 0.25) 100%
    );
    z-index: 1;
  }

  .featured-main .featured-card-content {
    position: relative;
    z-index: 2;
    padding: var(--space-8, 2rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
  }

  /* Secondary cards: light, voice-coded */
  .featured-secondary {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    background: var(--color-bg, #FAF5ED);
    border: 1px solid var(--neutral-200, #E8DFD0);
    transition: all 0.2s ease;
    position: relative;
  }

  .featured-secondary::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-gold, #D4943A);
    border-top-left-radius: var(--radius-lg, 8px);
    border-top-right-radius: var(--radius-lg, 8px);
  }

  .featured-secondary:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 8px 24px rgba(212, 148, 58, 0.12);
    transform: translateY(-2px);
  }

  .featured-secondary .featured-card-content {
    padding: var(--space-6, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    height: 100%;
  }

  /* Voice-coded badges */
  .featured-badge {
    display: inline-block;
    align-self: flex-start;
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 3px;
  }

  .featured-badge--on-record {
    background: var(--color-red, #C23B22);
    color: #fff;
  }

  .featured-badge--answered {
    background: var(--color-sienna, #8B4513);
    color: #fff;
  }

  .featured-badge--guided {
    background: var(--color-gold, #D4943A);
    color: var(--color-black, #1A1A1A);
  }

  /* Headlines */
  .featured-main-headline {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl, 1.5rem), 3vw, var(--text-4xl, 2.5rem));
    font-weight: 700;
    line-height: 1.15;
    color: #FFFFFF;
    margin: 0;
  }

  .featured-secondary-headline {
    font-family: var(--font-heading);
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-black, #1A1A1A);
    margin: 0;
  }

  /* Descriptions */
  .featured-main-desc {
    font-size: var(--text-base, 1rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.55;
    margin: 0;
  }

  .featured-secondary-desc {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  /* Bylines */
  .featured-byline-inline {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    margin-top: var(--space-2, 0.5rem);
  }

  .byline-avatar-sm {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .featured-main .byline-avatar-sm {
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .featured-secondary .byline-avatar-sm {
    border: 2px solid var(--neutral-200);
  }

  .byline-name-sm {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 700;
  }

  .featured-main .byline-name-sm {
    color: rgba(255, 255, 255, 0.95);
  }

  .featured-secondary .byline-name-sm {
    color: var(--color-black, #1A1A1A);
  }

  .byline-role-sm {
    font-size: var(--text-xs, 0.75rem);
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Read links */
  .featured-card-link {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 700;
    margin-top: var(--space-2, 0.5rem);
  }

  .featured-main .featured-card-link {
    color: var(--color-gold, #D4943A);
  }

  .featured-secondary .featured-card-link {
    color: var(--color-gold-text, #8B4513);
  }

  .featured-secondary:hover .featured-card-link {
    color: var(--color-sienna, #8B4513);
  }

  @media (max-width: 968px) {
    .featured-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: 0;
    }

    .featured-main {
      grid-row: auto;
      min-height: 320px;
    }
  }

  /* ========================================
     WHAT WE'RE WATCHING — dark data strip
     ======================================== */
  .watching-section {
    background: var(--color-black, #1A1A1A);
    padding: var(--space-16, 4rem) 0 var(--space-12, 3rem);
    border-top: 3px solid var(--color-gold, #D4943A);
  }

  .watching-header {
    margin-bottom: var(--space-10, 2.5rem);
    max-width: 720px;
  }

  .watching-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #FFD27A;
    margin-bottom: var(--space-3, 0.75rem);
  }

  .watching-headline {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1.1;
    margin: 0 0 var(--space-3, 0.75rem);
  }

  .watching-deck {
    font-size: var(--text-base, 1rem);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.6;
    margin: 0;
    max-width: 56ch;
  }

  .watching-cta {
    margin-top: var(--space-8, 2rem);
    text-align: left;
  }
  .watching-cta-link {
    display: inline-block;
    color: #FFD27A;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-sm, 0.875rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-bottom: 2px solid #FFD27A;
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
    min-height: 44px;
  }
  .watching-cta-link:hover,
  .watching-cta-link:focus-visible {
    color: #FFFFFF;
    border-color: #FFFFFF;
  }

  .watching-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6, 1.5rem);
  }

  .watching-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-6, 1.5rem) var(--space-4, 1rem);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .watching-stat:first-child { border-left: none; }

  .watching-stat:hover {
    border-color: var(--color-gold, #D4943A);
  }

  .watching-value {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl, 2rem), 4vw, var(--text-4xl, 2.5rem));
    font-weight: 700;
    color: var(--color-gold, #D4943A);
    line-height: 1;
  }

  .watching-label {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-bg, #FAF5ED);
    line-height: 1.4;
  }

  .watching-source {
    font-size: var(--text-xs, 0.75rem);
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ========================================
     THREE EDITORIAL HUBS — tab strip
     ======================================== */
  .hubs-section {
    background: var(--color-bg, #FAF5ED);
    padding-bottom: var(--space-8, 2rem);
  }

  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4, 1rem);
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-5, 1.25rem) var(--space-6, 1.5rem);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-top: 3px solid transparent;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hub-card--on-record { border-top-color: var(--color-red, #C23B22); }
  .hub-card--answered { border-top-color: var(--color-gold, #D4943A); }
  .hub-card--guided { border-top-color: var(--color-slate, #4A5859); }

  .hub-card:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 4px 16px rgba(212, 148, 58, 0.06);
  }
  .hub-card--on-record:hover { border-top-color: var(--color-red, #C23B22); }
  .hub-card--answered:hover { border-top-color: var(--color-gold, #D4943A); }
  .hub-card--guided:hover { border-top-color: var(--color-slate, #4A5859); }

  .hub-tag {
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    font-style: italic;
    color: var(--color-black, #1A1A1A);
  }

  .hub-desc {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.5;
  }

  .hub-link {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
  }

  /* ========================================
     THREE VOICES — section fronts
     ======================================== */
  .voices-section {
    background: var(--color-bg, #FAF5ED);
    padding-top: 0;
    padding-bottom: var(--space-16, 4rem);
  }

  .voices-eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold-text, #8B4513);
    text-align: center;
    margin-bottom: var(--space-3, 0.75rem);
  }

  .voices-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(var(--text-2xl, 1.5rem), 3.5vw, var(--text-4xl, 2.5rem));
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    text-align: center;
    margin: 0 0 var(--space-3, 0.75rem);
  }

  .voices-deck {
    text-align: center;
    color: var(--color-slate, #4A5859);
    font-size: var(--text-base, 1rem);
    line-height: 1.6;
    max-width: 56ch;
    margin: 0 auto var(--space-12, 3rem);
  }

  .voice-role {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.55;
    margin: 0 0 var(--space-5, 1.25rem);
  }

  .voice-lead-eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-slate, #4A5859);
    margin: 0 0 4px;
  }

  .voices-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .voice-column {
    padding: 0 var(--space-6, 1.5rem);
    border-right: 1px solid var(--neutral-200, #E8DFD0);
  }

  .voice-column:first-child { padding-left: 0; }
  .voice-column:last-child { padding-right: 0; border-right: none; }

  .voice-accent {
    height: 3px;
    margin-bottom: var(--space-4, 1rem);
  }

  .voice-accent--red { background: var(--color-red, #C23B22); }
  .voice-accent--gold { background: var(--color-gold, #D4943A); }
  .voice-accent--slate { background: var(--color-slate, #4A5859); }

  .voice-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-4, 1rem);
  }

  .voice-label--red { color: var(--color-red, #C23B22); }
  .voice-label--gold { color: var(--color-gold-text, #8B4513); }
  .voice-label--slate { color: var(--color-slate, #4A5859); }

  .voice-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    margin-bottom: var(--space-5, 1.25rem);
    padding-bottom: var(--space-4, 1rem);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .voice-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200, #E8DFD0);
    flex-shrink: 0;
  }

  .voice-byline-text {
    display: flex;
    flex-direction: column;
  }

  .voice-author-name {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-black, #1A1A1A);
    line-height: 1.2;
  }

  .voice-author-title {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
  }

  .voice-lead-wrap {
    display: block;
    text-decoration: none;
    margin-bottom: var(--space-5, 1.25rem);
  }

  .voice-lead-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .voice-lead {
    display: block;
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
