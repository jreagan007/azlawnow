---
/**
 * Homepage. AZ Law Now.
 * EDITORIAL-FIRST homepage. Front page of a publication.
 *
 * Flow:
 * 1. Editorial hero. Warm cream, big serif headline, no dark photo overlay.
 * 2. Featured investigation grid. 1+2 newspaper layout.
 * 3. "What We're Watching" data nuggets, dark strip.
 * 4. Three content hubs (On Record / Answered / Guided) editorial grid.
 * 5. Abuse & Negligence Spotlight. Editorial callout, vermillion accent.
 * 6. Practice areas grouped by cluster with subheadings.
 * 7. West Valley locations.
 * 8. Results teaser. Editorial, not flashy.
 * 9. Team. Editorial byline cards.
 * 10. Final CTA. Warm, not aggressive.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { authors } from '../data/authors';
import { getSiteWideSchemas } from '../utils/schema';

const siteSchemas = getSiteWideSchemas();

/* Map slug to hero image path. Handles mixed .png/.webp extensions. */
const heroImageMap: Record<string, string> = {
  'car-accidents': '/images/heroes/car-accidents.webp',
  'truck-accidents': '/images/heroes/truck-accidents.webp',
  'motorcycle-accidents': '/images/heroes/motorcycle-accidents.webp',
  'pedestrian-accidents': '/images/heroes/pedestrian-accidents.webp',
