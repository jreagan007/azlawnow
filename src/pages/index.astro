---

<BaseLayout
  title={siteConfig.defaultTitle}
  description={siteConfig.defaultDescription}
  schema={siteSchemas}
>

  <!-- ============================== -->
  <!-- EDITORIAL HERO                 -->
  <!-- ============================== -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="/images/heroes/homepage-hero.webp"
        alt="AZ Law Now office, family at reception"
        class="hero-bg-img"
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-dateline">Serving Arizona from Buckeye &amp; Maricopa</span>
        <h1 class="hero-h1">You Get Answers.</h1>
        <p class="hero-deck">
          Arizona injury cases, handled differently. An investigator who pulls
          the data. An attorney who fights the law. A guide who walks you
          through every step.
        </p>
        <div class="hero-actions">
          <a href="/free-case-review/" class="btn btn-primary btn-lg">
            Get answers on your case &rarr;
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-value">On Record</span>
            <span class="hero-stat-label">The data's pulled. The facts are clear.</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">Answered</span>
            <span class="hero-stat-label">The confusion stops here.</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">Guided</span>
            <span class="hero-stat-label">You don't figure this out alone.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- SOCIAL PROOF                   -->
  <!-- Stats strip + review excerpts  -->
  <!-- ============================== -->
  <section class="social-proof" aria-label="Trust and reviews">
    <div class="container">
      <div class="social-proof__stats">
        <div class="proof-stat">
          <span class="proof-stat__value">5.0</span>
          <div class="proof-stat__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
        </div>
        <div class="proof-stat">
          <span class="proof-stat__value">89</span>
          <span class="proof-stat__label">Google Reviews</span>
        </div>
        <div class="proof-stat">
          <span class="proof-stat__value">$3.07M+</span>
          <span class="proof-stat__label">Recovered</span>
        </div>
        <div class="proof-stat">
          <span class="proof-stat__value">26</span>
          <span class="proof-stat__label">Cases Resolved</span>
        </div>
      </div>

      <div class="social-proof__quotes">
        <blockquote class="proof-quote">
          <div class="proof-quote__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="proof-quote__text">"Brendan was at the crash scene before I even left the hospital. Quick to respond, kept me informed, made the whole process so much easier."</p>
          <cite class="proof-quote__author">Avalon C., via Google</cite>
        </blockquote>

        <blockquote class="proof-quote">
          <div class="proof-quote__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="proof-quote__text">"From the consult to the final check, the team was incredible. Professional, warm, helpful. Made me feel comfortable and important."</p>
          <cite class="proof-quote__author">A. Martin, via Google</cite>
        </blockquote>

        <blockquote class="proof-quote">
          <div class="proof-quote__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="proof-quote__text">"Truly made a horrible situation seamless. Brendan kept me updated, was time efficient, and even gave me a great orthopedic surgeon referral."</p>
          <cite class="proof-quote__author">Cheyanne A., via Google</cite>
        </blockquote>
      </div>

      <div class="social-proof__cta">
        <a href="/reviews/" class="social-proof__link">Read All 89 Reviews →</a>
        <span class="social-proof__sep" aria-hidden="true">·</span>
        <a href="/case-results/" class="social-proof__link">See Our Case Results →</a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FEATURED CLUSTER                -->
  <!-- 1 investigation + 2 supporting  -->
  <!-- All three voices on same topic  -->
  <!-- ============================== -->
  <section class="section featured-section">
    <div class="container">
      <div class="featured-header">
        <div>
          <span class="section-eyebrow">What We're Covering</span>
          <h2 class="featured-cluster-title">School &amp; Child Safety in Arizona</h2>
          <p class="featured-cluster-intro">
            Three voices on one story. The data investigator pulls the records.
            The attorney explains the law. The client guide walks families through
            what comes next. This is what editorial coverage looks like when you
            stop pretending one voice can do the whole job.
          </p>
        </div>
      </div>

      <div class="featured-grid">
        <!-- Big card: Brendan's investigation (the data-led story) -->
        <a href="/investigations/arizona-school-restraint-data/" class="featured-main">
          <img src="/images/heroes/dj-school-bus-route.webp" alt="Arizona school bus on a desert road" class="featured-card-bg" loading="lazy" />
          <div class="featured-card-overlay" aria-hidden="true"></div>
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--on-record">On Record · Investigation</span>
            <h3 class="featured-main-headline">4,200+ Students Restrained in Arizona Schools. Most Were Kids With Disabilities.</h3>
            <p class="featured-main-desc">
              Arizona schools reported over 4,200 physical restraint and seclusion incidents last year. ADE data shows West Valley districts with some of the highest rates per student in the state.
            </p>
            <div class="featured-byline-inline">
              <img src={brendan.photo} alt="Brendan Franks" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brendan.name}</span>
              <span class="byline-role-sm">Editor-in-Chief</span>
            </div>
            <span class="featured-card-link">Read the investigation →</span>
          </div>
        </a>

        <!-- Secondary card 1: Brandon's legal guide -->
        <a href="/legal-guides/suing-school-district-arizona/" class="featured-secondary">
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--answered">Answered · Legal Guide</span>
            <h3 class="featured-secondary-headline">Suing a School District in Arizona: The 180-Day Deadline</h3>
            <p class="featured-secondary-desc">
              ARS 12-821.01 gives you 180 days to file a Notice of Claim against a public entity. Miss it and the case is barred. Brandon explains the rule.
            </p>
            <div class="featured-byline-inline">
              <img src={brandon.photo} alt="Brandon Millam" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brandon.name}</span>
            </div>
            <span class="featured-card-link">Read the guide →</span>
          </div>
        </a>

        <!-- Secondary card 2: Stephanie's client guide -->
        <a href="/client-guides/child-injured-at-school/" class="featured-secondary">
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--guided">Guided · Client Resource</span>
            <h3 class="featured-secondary-headline">Your Child Was Hurt at School: What to Do Next</h3>
            <p class="featured-secondary-desc">
              First steps for parents. Documenting the incident, requesting records, filing complaints, and the timeline that protects your options.
            </p>
            <div class="featured-byline-inline">
              <img src={stephanie.photo} alt="Stephanie Ramirez" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{stephanie.name}</span>
            </div>
            <span class="featured-card-link">Read the resource →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- WHAT WE'RE WATCHING — data     -->
  <!-- ============================== -->
  <section class="watching-section">
    <div class="container">
      <div class="watching-header">
        <span class="watching-eyebrow">What We're Watching</span>
      </div>
      <div class="watching-row">
        {dataStats.map((stat) => (
          <a href={stat.url} class="watching-stat">
            <span class="watching-value">{stat.value}</span>
            <span class="watching-label">{stat.label}</span>
            <span class="watching-source">{stat.source}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- THREE EDITORIAL HUBS — tabs    -->
  <!-- ============================== -->
  <section class="section hubs-section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">How We Work</span>
        <div class="section-rule"></div>
      </div>
      <div class="hubs-grid">
        <a href="/investigations/" class="hub-card hub-card--on-record">
          <span class="hub-tag">On Record.</span>
          <span class="hub-desc">The data's pulled. The facts are clear.</span>
          <span class="hub-link">Explore &rarr;</span>
        </a>
        <a href="/legal-guides/" class="hub-card hub-card--answered">
          <span class="hub-tag">Answered.</span>
          <span class="hub-desc">The confusion stops here.</span>
          <span class="hub-link">Explore &rarr;</span>
        </a>
        <a href="/client-guides/" class="hub-card hub-card--guided">
          <span class="hub-tag">Guided.</span>
          <span class="hub-desc">You don't figure this out alone.</span>
          <span class="hub-link">Explore &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- THREE VOICES — section fronts  -->
  <!-- ============================== -->
  <section class="section voices-section">
    <div class="container">
      <h2 class="voices-heading">Three Voices. Your Whole Case.</h2>
      <div class="voices-grid">

        <!-- ON RECORD — Brendan -->
        <div class="voice-column voice-column--on-record">
          <div class="voice-accent voice-accent--red"></div>
          <span class="voice-label voice-label--red">On Record</span>
          <div class="voice-byline">
            <img src={brendan.photo} alt="Brendan Franks" class="voice-avatar" width="32" height="32" loading="lazy" />
            <div class="voice-byline-text">
              <span class="voice-author-name">{brendan.name}</span>
              <span class="voice-author-title">{brendan.title}</span>
            </div>
          </div>
          <a href="/investigations/arizona-school-restraint-data/" class="voice-lead-wrap">
            <img src="/images/cards/arizona-school-restraint-data.webp" alt="Arizona school restraint data investigation" class="voice-lead-img" loading="lazy" />
            <span class="voice-lead">Arizona Schools Restrained 4,200+ Students Last Year</span>
          </a>
          <div class="voice-stories">
            <a href="/investigations/arizona-daycare-violations/" class="voice-story">
              Maricopa County Daycares With the Most DHS Violations
            </a>
            <a href="/investigations/sr-347-crash-corridor/" class="voice-story">
              The SR-347 Problem: Maricopa's Most Dangerous Corridor
            </a>
            <a href="/investigations/i-10-crash-data-buckeye-goodyear/" class="voice-story">
              What ADOT Data Shows About I-10 Crashes
            </a>
          </div>
          <a href="/investigations/" class="voice-all voice-all--red">Read all investigations &rarr;</a>
        </div>

        <!-- ANSWERED — Brandon -->
        <div class="voice-column voice-column--answered">
          <div class="voice-accent voice-accent--gold"></div>
          <span class="voice-label voice-label--gold">Answered</span>
          <div class="voice-byline">
            <img src={brandon.photo} alt="Brandon Millam" class="voice-avatar" width="32" height="32" loading="lazy" />
            <div class="voice-byline-text">
              <span class="voice-author-name">{brandon.name}</span>
              <span class="voice-author-title">{brandon.title}</span>
            </div>
          </div>
          <a href="/legal-guides/arizona-car-accident-law/" class="voice-lead-wrap">
            <img src="/images/cards/arizona-car-accident-law.webp" alt="Arizona car accident law guide" class="voice-lead-img" loading="lazy" />
            <span class="voice-lead">Arizona Car Accident Law: Fault, Insurance, and Deadlines</span>
          </a>
          <div class="voice-stories">
            <a href="/legal-guides/suing-school-district-arizona/" class="voice-story">
              Suing a School District: The 180-Day Deadline
            </a>
