---
/**
 * Homepage. AZ Law Now.
 * EDITORIAL-FIRST homepage. Front page of a publication.
 *
 * Flow:
 * 1. Editorial hero. Warm cream, big serif headline, no dark photo overlay.
 * 2. Featured investigation grid. 1+2 newspaper layout.
 * 3. "What We're Watching" data nuggets, dark strip.
 * 4. Three content hubs (On Record / Answered / Guided) editorial grid.
 * 5. Abuse & Negligence Spotlight. Editorial callout, vermillion accent.
 * 6. Practice areas grouped by cluster with subheadings.
 * 7. West Valley locations.
 * 8. Results teaser. Editorial, not flashy.
 * 9. Team. Editorial byline cards.
 * 10. Final CTA. Warm, not aggressive.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site-config';
import { authors } from '../data/authors';
// Homepage gets site-wide schemas via BaseLayout automatically.
// Don't double-inject here (caused 6 JSON-LD blocks instead of 3).

// Pull all investigations sorted by publishedAt descending. Use for both the
// featured-cluster headline and the new "Latest Investigations" strip below.
// Brand-new stories surface on the homepage automatically the moment they ship,
// no editorial template change required.
const allInvestigations = await getCollection('investigations');
const investigationsByDate = allInvestigations.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredInvestigations = investigationsByDate.filter((e) => e.data.featured);
const headlineStory = featuredInvestigations[0] ?? investigationsByDate[0];
const latestInvestigations = investigationsByDate
  .filter((e) => e.id !== headlineStory.id)
  .slice(0, 6);
const voicesLatestThree = investigationsByDate
  .filter((e) => e.id !== headlineStory.id)
  .slice(0, 3);

function formatPublishedShort(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

/* Map slug to hero image path. Handles mixed .png/.webp extensions. */
const heroImageMap: Record<string, string> = {
  'car-accidents': '/images/heroes/car-accidents.webp',
  'truck-accidents': '/images/heroes/truck-accidents.webp',
  'motorcycle-accidents': '/images/heroes/motorcycle-accidents.webp',
  'pedestrian-accidents': '/images/heroes/pedestrian-accidents.webp',
  'bus-accidents': '/images/heroes/bus-accidents.webp',
  'bicycle-accidents': '/images/heroes/bicycle-accidents.webp',
  'rideshare-accidents': '/images/heroes/rideshare-accidents.webp',
  'elder-abuse': '/images/heroes/elder-abuse.webp',
  'nursing-home-abuse': '/images/heroes/nursing-home-abuse.webp',
  'child-abuse': '/images/heroes/child-abuse.webp',
  'daycare-negligence': '/images/heroes/daycare-negligence.webp',
  'school-abuse': '/images/heroes/school-abuse.webp',
  'medical-negligence': '/images/heroes/medical-negligence.webp',
  'slip-and-fall': '/images/heroes/slip-and-fall.webp',
  'wrongful-death': '/images/heroes/wrongful-death.webp',
  'dog-bite': '/images/heroes/dog-bite.webp',
  'premises-liability': '/images/heroes/premises-liability.webp',
};

const practiceAreaClusters = [
  {
    label: 'Vehicle Crashes',
    areas: [
      { name: 'Car Accidents', url: '/car-accidents/' },
      { name: 'Truck Accidents', url: '/truck-accidents/' },
      { name: 'Motorcycle Accidents', url: '/motorcycle-accidents/' },
      { name: 'Pedestrian Accidents', url: '/pedestrian-accidents/' },
      { name: 'Bus Accidents', url: '/bus-accidents/' },
      { name: 'Bicycle Accidents', url: '/bicycle-accidents/' },
      { name: 'Rideshare Accidents', url: '/rideshare-accidents/' },
    ],
  },
  {
    label: 'Abuse & Negligence',
    areas: [
      { name: 'Elder Abuse', url: '/elder-abuse/' },
      { name: 'Nursing Home Abuse', url: '/nursing-home-abuse/' },
      { name: 'Child Abuse', url: '/child-abuse/' },
      { name: 'Daycare Negligence', url: '/daycare-negligence/' },
      { name: 'School Abuse', url: '/school-abuse/' },
      { name: 'Medical Negligence', url: '/medical-negligence/' },
    ],
  },
  {
    label: 'Other Claims',
    areas: [
      { name: 'Slip and Fall', url: '/slip-and-fall/' },
      { name: 'Wrongful Death', url: '/wrongful-death/' },
      { name: 'Dog Bite', url: '/dog-bite/' },
      { name: 'Premises Liability', url: '/premises-liability/' },
    ],
  },
];

const caseResults = [
  { amount: '$800K', type: 'School Bus Negligence', description: 'A child injured when a bus driver failed safety protocol.' },
  { amount: '$745K', type: 'Motor Vehicle Accident', description: 'Spinal injuries from a multi-vehicle I-10 collision.' },
  { amount: '$500K', type: 'Trucking Accident', description: 'Commercial truck ran a red light in Goodyear.' },
  { amount: '$255K', type: 'Rear-End Collision', description: 'Distracted driver crash at a Buckeye intersection.' },
];

const locations = [
  { name: 'Buckeye', label: 'HQ', url: '/buckeye/' },
  { name: 'Maricopa', label: 'New', url: '/maricopa/' },
  { name: 'Goodyear', label: '', url: '/goodyear/' },
  { name: 'Avondale', label: '', url: '/avondale/' },
  { name: 'Phoenix', label: '', url: '/phoenix/' },
];

const dataStats = [
  { value: '4,200+', label: 'Students restrained in AZ schools last year', source: 'ADE Data', url: '/investigations/arizona-school-restraint-data/' },
  { value: '88,094', label: 'Crashes in Maricopa County 2024', source: 'ADOT', url: '/investigations/i-10-crash-data-buckeye-goodyear/' },
  { value: '47%', label: 'Nursing homes below average staffing', source: 'CMS', url: '/investigations/arizona-nursing-home-violations/' },
  { value: '$800K', label: 'Settlement, school bus negligence', source: 'AZ Law Now', url: '/case-results/' },
];

const brendan = authors['brendan-franks'];
const brandon = authors['brandon-millam'];
const stephanie = authors['stephanie-ramirez'];

// Topic clusters. Each topic has 3 voices (Brendan / Brandon / Stephanie).
const topicClusters = [
  {
    title: 'Motor Vehicle Crashes',
    intro: 'I-10 corridor data, Arizona crash law, and what to do in the first 48 hours.',
    onRecord: {
      title: 'I-10 Crash Data: Buckeye to Goodyear',
      byline: 'Brendan Franks',
      href: '/investigations/i-10-crash-data-buckeye-goodyear/',
    },
    answered: {
      title: 'Arizona Car Accident Law: Fault and Deadlines',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-car-accident-law/',
    },
    guided: {
      title: 'Your First 48 Hours After an Arizona Car Crash',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/car-accident-first-48-hours/',
    },
  },
  {
    title: 'Motorcycle Safety',
    intro: 'Arizona motorcyclists die at five times the rate of other drivers. The data, the law, the action plan.',
    onRecord: {
      title: "Arizona's Motorcycle Fatality Report",
      byline: 'Brendan Franks',
      href: '/investigations/arizona-motorcycle-fatality-report/',
    },
    answered: {
      title: 'Arizona Motorcycle Law: Helmet, Insurance, Fault',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-motorcycle-law/',
    },
    guided: {
      title: 'After a Motorcycle Crash: Your Action Plan',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/motorcycle-crash-action-plan/',
    },
  },
  {
    title: 'Impaired Driving',
    intro: 'Phoenix DUI patterns, dram shop liability, and what victims and families need to know.',
    onRecord: {
      title: 'Phoenix DUI Crashes: The Data Nobody Wants to See',
      byline: 'Brendan Franks',
      href: '/investigations/phoenix-dui-crashes-data/',
    },
    answered: {
      title: 'Arizona Dram Shop and Social Host Liability',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-dram-shop-liability/',
    },
    guided: {
      title: 'Hit by a Drunk Driver in Arizona: What to Do',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/hit-by-drunk-driver/',
    },
  },
  {
    title: 'Pedestrian Safety',
    intro: 'Arizona intersection patterns, pedestrian rights, and the action plan after a crash.',
    onRecord: {
      title: "West Valley's Most Dangerous Intersections",
      byline: 'Brendan Franks',
      href: '/investigations/west-valley-dangerous-intersections/',
    },
    answered: {
      title: 'Arizona Pedestrian Rights and Driver Liability',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-pedestrian-law/',
    },
    guided: {
      title: 'Hit by a Car While Walking: Your Action Plan',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/pedestrian-crash-action-plan/',
    },
  },
  {
    title: 'Elder & Nursing Home Care',
    intro: 'CMS facility data, ARS 46-451, and how families spot and report nursing home abuse.',
    onRecord: {
      title: 'Arizona Nursing Homes With the Most Federal Violations',
      byline: 'Brendan Franks',
      href: '/investigations/arizona-nursing-home-violations/',
    },
    answered: {
      title: 'Arizona Elder Abuse Law: ARS 46-451',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-elder-abuse-law/',
    },
    guided: {
      title: 'Signs of Nursing Home Abuse and How to Report It',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/nursing-home-abuse-signs-reporting/',
    },
  },
  {
    title: 'School & Child Safety',
    intro: '4,200+ students restrained in Arizona schools, the 180-day notice deadline, and what parents do next.',
    onRecord: {
      title: '4,200+ Students Restrained in Arizona Schools',
      byline: 'Brendan Franks',
      href: '/investigations/arizona-school-restraint-data/',
    },
    answered: {
      title: 'Suing a School District in Arizona: The Deadline',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/suing-school-district-arizona/',
    },
    guided: {
      title: 'Your Child Was Hurt at School: What to Do Next',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/child-injured-at-school/',
    },
  },
  {
    title: 'Daycare Negligence',
    intro: 'DHS violation patterns, Arizona daycare law, and how parents vet a facility before enrolling.',
    onRecord: {
      title: 'Maricopa County Daycares With the Most DHS Violations',
      byline: 'Brendan Franks',
      href: '/investigations/arizona-daycare-violations/',
    },
    answered: {
      title: 'Arizona Daycare Negligence Law: Liability and Duty of Care',
      byline: 'Brandon Millam, J.D.',
      href: '/legal-guides/arizona-daycare-negligence-law/',
    },
    guided: {
      title: 'How to Vet an Arizona Daycare: Red Flags and Reports',
      byline: 'Stephanie Ramirez',
      href: '/client-guides/how-to-vet-arizona-daycare/',
    },
  },
];
---

<BaseLayout
  title={siteConfig.defaultTitle}
  description={siteConfig.defaultDescription}
>

  <!-- ============================== -->
  <!-- EDITORIAL HERO                 -->
  <!-- ============================== -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="/images/heroes/homepage-hero.webp"
        alt="AZ Law Now office, family at reception"
        class="hero-bg-img"
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-dateline">Hurt in Arizona? Free. 24/7. Talk to us today.</span>
        <h1 class="hero-h1">You Get Answers.</h1>
        <p class="hero-deck">
          Arizona personal injury attorneys serving Phoenix, Buckeye, Maricopa,
          and the West Valley. $3.07M+ recovered for Arizona families. Free,
          confidential consultation in minutes. No fee unless we win.
        </p>
        <div class="hero-actions">
          <a href="/free-case-review/" class="btn btn-primary btn-lg" data-event="hero-form-cta" aria-label="Review my case">
            Review My Case &rarr;
          </a>
          <a href={`tel:${siteConfig.phoneE164}`} class="btn btn-outline-light btn-lg hero-call" data-event="hero-call-cta" aria-label={`Call AZ Law Now at ${siteConfig.phoneFormatted}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:8px;flex-shrink:0;">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {siteConfig.phoneFormatted}
          </a>
        </div>
        <p class="hero-microcopy">
          Free, no obligation. Available 24/7. We come to you.
        </p>
      </div>
      <aside class="hero-trust" aria-label="Why families choose AZ Law Now">
        <div class="hero-trust__stat">
          <span class="hero-trust__value">{siteConfig.trustStats.totalRecovered}</span>
          <span class="hero-trust__label">Recovered for Arizona families</span>
        </div>
        <div class="hero-trust__stat">
          <span class="hero-trust__value">
            <span class="hero-trust__rating">{siteConfig.trustStats.googleRating.toFixed(1)}</span>
            <span class="hero-trust__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </span>
          <span class="hero-trust__label">{siteConfig.trustStats.googleReviewCount} verified Google reviews</span>
        </div>
        <div class="hero-trust__stat">
          <span class="hero-trust__value">No Fee</span>
          <span class="hero-trust__label">Unless we win your case</span>
        </div>
        <blockquote class="hero-trust__quote">
          <span class="hero-trust__quote-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>&ldquo;Brendan was at the crash scene before I even left the hospital.&rdquo;</p>
          <cite>Avalon C., Google review</cite>
        </blockquote>
      </aside>
    </div>
  </section>

  <!-- ============================== -->
  <!-- SOCIAL PROOF — voice of client -->
  <!-- Trust trio + dollars live in   -->
  <!-- the hero panel. Section here   -->
  <!-- is real-client testimony only. -->
  <!-- ============================== -->
  <section class="social-proof" aria-label="Client testimonials">
    <div class="container">
      <div class="social-proof__heading">
        <h2 class="section-eyebrow">What Arizona Families Say</h2>
        <div class="section-rule"></div>
      </div>

      <div class="social-proof__quotes">
        <blockquote class="proof-quote">
          <div class="proof-quote__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="proof-quote__text">&ldquo;From the consult to the final check, the team was incredible. Professional, warm, helpful. Made me feel comfortable and important.&rdquo;</p>
          <cite class="proof-quote__author">A. Martin, via Google</cite>
        </blockquote>

        <blockquote class="proof-quote">
          <div class="proof-quote__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#D4943A">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="proof-quote__text">&ldquo;Truly made a horrible situation seamless. Brendan kept me updated, was time efficient, and even gave me a great orthopedic surgeon referral.&rdquo;</p>
          <cite class="proof-quote__author">Cheyanne A., via Google</cite>
        </blockquote>
      </div>

      <div class="social-proof__cta">
        <a href="/reviews/" class="social-proof__link">Read all {siteConfig.trustStats.googleReviewCount} reviews &rarr;</a>
        <span class="social-proof__sep" aria-hidden="true">&middot;</span>
        <a href="/case-results/" class="social-proof__link">See Our Case Results &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- WHAT WE'RE WATCHING — data     -->
  <!-- Promoted to second screen. The -->
  <!-- firm's strongest unique asset  -->
  <!-- is the Arizona injury data we  -->
  <!-- track. Each stat links into an -->
  <!-- investigation for deep dwell.  -->
  <!-- ============================== -->
  <section class="watching-section">
    <div class="container">
      <div class="watching-header">
        <span class="watching-eyebrow">What We&rsquo;re Watching in Arizona</span>
        <h2 class="watching-headline">The data behind the cases.</h2>
        <p class="watching-deck">
          Real Arizona injury patterns from public records and state filings. Every
          number links to the full investigation.
        </p>
      </div>
      <div class="watching-row">
        {dataStats.map((stat) => (
          <a href={stat.url} class="watching-stat">
            <span class="watching-value">{stat.value}</span>
            <span class="watching-label">{stat.label}</span>
            <span class="watching-source">{stat.source}</span>
          </a>
        ))}
      </div>
      <div class="watching-cta">
        <a href="/investigations/" class="watching-cta-link">Read every investigation &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- FEATURED CLUSTER                -->
  <!-- 1 investigation + 2 supporting  -->
  <!-- All three voices on same topic  -->
  <!-- ============================== -->
  <section class="section featured-section">
    <div class="container">
      <div class="featured-header">
        <div>
          <span class="section-eyebrow">What We're Covering</span>
          <h2 class="featured-cluster-title">School &amp; Child Safety in Arizona</h2>
          <p class="featured-cluster-intro">
            One Arizona story, three perspectives. We pull the public records,
            explain the law, and walk families through what to do next.
          </p>
        </div>
      </div>

      <div class="featured-grid">
        <!-- Big card: Brendan's most recent featured investigation (auto-pulled). -->
        <a href={`/investigations/${headlineStory.id}/`} class="featured-main">
          <img src={headlineStory.data.image || '/images/heroes/dj-school-bus-route.webp'} alt={headlineStory.data.title} class="featured-card-bg" loading="lazy" />
          <div class="featured-card-overlay" aria-hidden="true"></div>
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--on-record">On Record · Investigation</span>
            <h3 class="featured-main-headline">{headlineStory.data.title}</h3>
            <p class="featured-main-desc">{headlineStory.data.description}</p>
            <div class="featured-byline-inline">
              <img src={brendan.photo} alt="Brendan Franks" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brendan.name}</span>
              <span class="byline-role-sm">Editor-in-Chief</span>
            </div>
            <span class="featured-card-link">Read the investigation →</span>
          </div>
        </a>

        <!-- Secondary card 1: Brandon's legal guide -->
        <a href="/legal-guides/suing-school-district-arizona/" class="featured-secondary">
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--answered">Answered · Legal Guide</span>
            <h3 class="featured-secondary-headline">Suing a School District in Arizona: The 180-Day Deadline</h3>
            <p class="featured-secondary-desc">
              ARS 12-821.01 gives you 180 days to file a Notice of Claim against a public entity. Miss it and the case is barred. Brandon explains the rule.
            </p>
            <div class="featured-byline-inline">
              <img src={brandon.photo} alt="Brandon Millam" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{brandon.name}</span>
            </div>
            <span class="featured-card-link">Read the guide →</span>
          </div>
        </a>

        <!-- Secondary card 2: Stephanie's client guide -->
        <a href="/client-guides/child-injured-at-school/" class="featured-secondary">
          <div class="featured-card-content">
            <span class="featured-badge featured-badge--guided">Guided · Client Resource</span>
            <h3 class="featured-secondary-headline">Your Child Was Hurt at School: What to Do Next</h3>
            <p class="featured-secondary-desc">
              First steps for parents. Documenting the incident, requesting records, filing complaints, and the timeline that protects your options.
            </p>
            <div class="featured-byline-inline">
              <img src={stephanie.photo} alt="Stephanie Ramirez" class="byline-avatar-sm" width="28" height="28" loading="lazy" />
              <span class="byline-name-sm">{stephanie.name}</span>
            </div>
            <span class="featured-card-link">Read the resource →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- LATEST INVESTIGATIONS strip    -->
  <!-- Auto-pulled, sorted by date.   -->
  <!-- ============================== -->
  <section class="section latest-investigations">
    <div class="container">
      <div class="latest-header">
        <span class="section-eyebrow">Latest Investigations</span>
        <h2 class="latest-heading">What we're reporting on this week in Arizona</h2>
      </div>
      <div class="latest-grid">
        {latestInvestigations.map((story) => (
          <a href={`/investigations/${story.id}/`} class="latest-card">
            <img
              src={story.data.image || '/images/heroes/practice-area-default.webp'}
              alt={story.data.title}
              class="latest-card-thumb"
              loading="lazy"
            />
            <div class="latest-card-body">
              <span class="latest-card-date">{formatPublishedShort(story.data.publishedAt)}</span>
              <h3 class="latest-card-title">{story.data.title}</h3>
              <span class="latest-card-link">Read →</span>
            </div>
          </a>
        ))}
      </div>
      <a href="/investigations/" class="latest-all">See every investigation &rarr;</a>
    </div>
  </section>

  <!-- ============================== -->
  <!-- WHAT WE'RE WATCHING moved up to second screen.                        -->
  <!-- The data we're tracking is the firm's strongest unique asset and earns -->
  <!-- the highest-attention real estate after the hero + testimonials.       -->
  <!-- See section right below social-proof (above Featured Cluster).         -->

  <!-- ============================== -->
  <!-- THREE EDITORIAL HUBS — tabs    -->
  <!-- ============================== -->
  <section class="section hubs-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-eyebrow">How We Cover Every Case</h2>
        <div class="section-rule"></div>
      </div>
      <div class="hubs-grid">
        <a href="/investigations/" class="hub-card hub-card--on-record">
          <span class="hub-tag">On Record.</span>
          <span class="hub-desc">Public records, crash data, settlement intel. The facts before the case.</span>
          <span class="hub-link">Read investigations &rarr;</span>
        </a>
        <a href="/legal-guides/" class="hub-card hub-card--answered">
          <span class="hub-tag">Answered.</span>
          <span class="hub-desc">Arizona statutes, deadlines, and case law explained in plain English.</span>
          <span class="hub-link">Read legal guides &rarr;</span>
        </a>
        <a href="/client-guides/" class="hub-card hub-card--guided">
          <span class="hub-tag">Guided.</span>
          <span class="hub-desc">First-48-hour playbooks. Process timelines. The steps families actually need.</span>
