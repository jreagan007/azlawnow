    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold, #D4943A);
  }

  .watching-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6, 1.5rem);
  }

  .watching-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-6, 1.5rem) var(--space-4, 1rem);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .watching-stat:first-child { border-left: none; }

  .watching-stat:hover {
    border-color: var(--color-gold, #D4943A);
  }

  .watching-value {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl, 2rem), 4vw, var(--text-4xl, 2.5rem));
    font-weight: 700;
    color: var(--color-gold, #D4943A);
    line-height: 1;
  }

  .watching-label {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-bg, #FAF5ED);
    line-height: 1.4;
  }

  .watching-source {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ========================================
     THREE EDITORIAL HUBS — tab strip
     ======================================== */
  .hubs-section {
    background: var(--color-bg, #FAF5ED);
    padding-bottom: var(--space-8, 2rem);
  }

  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4, 1rem);
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-5, 1.25rem) var(--space-6, 1.5rem);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-top: 3px solid transparent;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hub-card--on-record { border-top-color: var(--color-red, #C23B22); }
  .hub-card--answered { border-top-color: var(--color-gold, #D4943A); }
  .hub-card--guided { border-top-color: var(--color-slate, #4A5859); }

  .hub-card:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 4px 16px rgba(212, 148, 58, 0.06);
  }
  .hub-card--on-record:hover { border-top-color: var(--color-red, #C23B22); }
  .hub-card--answered:hover { border-top-color: var(--color-gold, #D4943A); }
  .hub-card--guided:hover { border-top-color: var(--color-slate, #4A5859); }

  .hub-tag {
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    font-style: italic;
    color: var(--color-black, #1A1A1A);
  }

  .hub-desc {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.5;
  }

  .hub-link {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
  }

  /* ========================================
     THREE VOICES — section fronts
     ======================================== */
  .voices-section {
    background: var(--color-bg, #FAF5ED);
    padding-top: 0;
    padding-bottom: var(--space-16, 4rem);
  }

  .voices-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(var(--text-2xl, 1.5rem), 3.5vw, var(--text-4xl, 2.5rem));
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    text-align: center;
    margin-bottom: var(--space-10, 2.5rem);
  }

  .voices-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .voice-column {
    padding: 0 var(--space-6, 1.5rem);
    border-right: 1px solid var(--neutral-200, #E8DFD0);
  }

  .voice-column:first-child { padding-left: 0; }
  .voice-column:last-child { padding-right: 0; border-right: none; }

  .voice-accent {
    height: 3px;
    margin-bottom: var(--space-4, 1rem);
  }

  .voice-accent--red { background: var(--color-red, #C23B22); }
  .voice-accent--gold { background: var(--color-gold, #D4943A); }
  .voice-accent--slate { background: var(--color-slate, #4A5859); }

  .voice-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-4, 1rem);
  }

  .voice-label--red { color: var(--color-red, #C23B22); }
  .voice-label--gold { color: var(--color-gold-text, #8B4513); }
  .voice-label--slate { color: var(--color-slate, #4A5859); }

  .voice-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    margin-bottom: var(--space-5, 1.25rem);
    padding-bottom: var(--space-4, 1rem);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .voice-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200, #E8DFD0);
    flex-shrink: 0;
  }

  .voice-byline-text {
    display: flex;
    flex-direction: column;
  }

  .voice-author-name {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-black, #1A1A1A);
    line-height: 1.2;
  }

  .voice-author-title {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
  }

  .voice-lead-wrap {
    display: block;
    text-decoration: none;
    margin-bottom: var(--space-5, 1.25rem);
  }

  .voice-lead-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .voice-lead {
    display: block;
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-black, #1A1A1A);
    transition: color 0.15s ease;
  }

  .voice-lead-wrap:hover .voice-lead {
    color: var(--color-gold-text, #8B4513);
  }

  .voice-stories {
    display: flex;
    flex-direction: column;
  }

  .voice-story {
    display: block;
    padding: var(--space-3, 0.75rem) 0;
    border-top: 1px solid var(--neutral-200, #E8DFD0);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-black, #1A1A1A);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .voice-story:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .voice-all {
    display: inline-block;
    margin-top: var(--space-5, 1.25rem);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .voice-all:hover { opacity: 0.8; }

  .voice-all--red { color: var(--color-red, #C23B22); }
  .voice-all--gold { color: var(--color-gold-text, #8B4513); }
  .voice-all--slate { color: var(--color-slate, #4A5859); }

  /* ========================================
     TOPIC CLUSTERS — Three voices per topic
     ======================================== */
  .cluster-section {
    background: var(--color-bg, #FAF5ED);
    border-top: 3px solid var(--color-red, #C23B22);
  }

  .cluster-header {
    max-width: 720px;
    margin: 0 auto var(--space-12, 3rem);
    text-align: center;
  }

  .cluster-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .cluster-heading {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl, 2rem), 4vw, var(--text-5xl, 3rem));
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin-bottom: var(--space-4, 1rem);
    line-height: 1.1;
  }

  .cluster-subhead {
    font-size: var(--text-lg, 1.125rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.6;
  }

  .cluster-row {
    margin-bottom: var(--space-12, 3rem);
    padding-bottom: var(--space-12, 3rem);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .cluster-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .cluster-row__heading {
    margin-bottom: var(--space-6, 1.5rem);
    max-width: 720px;
  }

  .cluster-row__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin: 0 0 var(--space-2, 0.5rem);
    line-height: 1.2;
  }

  .cluster-row__intro {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-base, 1rem);
    line-height: 1.6;
    margin: 0;
  }

  .cluster-row__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5, 1.25rem);
  }

  .cluster-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    padding: var(--space-6, 1.5rem);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
  }

  .cluster-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-gold, #D4943A);
    border-top-left-radius: var(--radius-lg, 8px);
    border-top-right-radius: var(--radius-lg, 8px);
  }

  .cluster-card:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 8px 24px rgba(212, 148, 58, 0.12);
    transform: translateY(-2px);
  }

  .cluster-card__voice {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .voice--on-record { color: var(--color-red, #C23B22); }
  .voice--answered { color: var(--color-sienna, #8B4513); }
  .voice--guided { color: var(--color-gold-text, #8B4513); }

  .cluster-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    line-height: 1.3;
    margin: 0;
    flex: 1;
  }

  .cluster-card__byline {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
    letter-spacing: 0.01em;
    margin: 0;
    font-style: italic;
  }

  .cluster-card__author {
    font-style: normal;
    font-weight: 600;
    color: var(--color-black, #1A1A1A);
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .cluster-card:hover .cluster-card__author {
    border-bottom-color: var(--color-gold-text, #8B4513);
  }

  .cluster-card__link {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
    margin-top: var(--space-2, 0.5rem);
  }

  .cluster-card:hover .cluster-card__link {
    color: var(--color-sienna, #8B4513);
  }

  @media (max-width: 968px) {
    .cluster-row__grid {
      grid-template-columns: 1fr;
      gap: var(--space-4, 1rem);
    }
  }

  /* ========================================
     PRACTICE AREAS + LOCATIONS — clustered
     ======================================== */
  .compact-section {
    background: var(--color-white, #FFFFFF);
    border-top: 1px solid var(--neutral-200, #E8DFD0);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .compact-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-16, 4rem);
  }

  .cluster-group {
    margin-bottom: var(--space-8, 2rem);
  }

  .cluster-group:last-child {
    margin-bottom: 0;
  }

  .cluster-label {
    font-family: var(--font-body);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold-text, #8B4513);
    padding-bottom: var(--space-2, 0.5rem);
    border-bottom: 1px solid var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .practice-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  .practice-link {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
    text-decoration: none;
    color: var(--color-black, #1A1A1A);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .practice-link span:first-of-type {
    flex: 1;
  }

  .pa-link-thumb {
    width: 36px;
    height: 36px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .practice-link:hover { color: var(--color-gold-text, #8B4513); }

  .practice-arrow {
    color: var(--neutral-300, #D4CFC6);
    transition: all 0.15s ease;
  }

  .practice-link:hover .practice-arrow {
    color: var(--color-gold-text, #8B4513);
    transform: translateX(2px);
  }

  .locations-intro {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.6;
    margin-bottom: var(--space-6, 1.5rem);
  }

  .locations-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .location-row {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .location-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
  }

  .location-row:hover .location-name { color: var(--color-gold-text, #8B4513); }

  .location-badge {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-red, #C23B22);
    background: rgba(194, 59, 34, 0.08);
    padding: 0.125rem 0.5rem;
    border-radius: 3px;
  }

  .locations-cta { margin-top: var(--space-6, 1.5rem); }

  /* ========================================
     RESULTS — editorial
     ======================================== */
  .results-section {
    background: var(--color-bg, #FAF5ED);
  }

  .results-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6, 1.5rem);
  }

  .result-item {
    text-align: center;
    padding: var(--space-6, 1.5rem) var(--space-4, 1rem);
    border-left: 1px solid var(--neutral-200, #E8DFD0);
  }

  .result-item:first-child { border-left: none; }

  .result-amount {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--color-gold-text, #8B4513);
    line-height: 1;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .result-type {
    display: block;
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-black, #1A1A1A);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .result-desc {
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.5;
  }

  .results-footer {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    margin-top: var(--space-8, 2rem);
    padding-top: var(--space-6, 1.5rem);
    border-top: 1px solid var(--neutral-200, #E8DFD0);
  }

  .results-note {
    font-size: var(--text-xs, 0.75rem);
    color: var(--neutral-400, #B0A696);
    font-style: italic;
  }

  /* ========================================
     TEAM — editorial byline cards
     ======================================== */
  .team-section {
    background: var(--color-white, #FFFFFF);
    border-bottom: 1px solid var(--neutral-200, #E8DFD0);
  }

  .team-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6, 1.5rem);
  }

  .team-card {
    display: flex;
    gap: var(--space-4, 1rem);
    padding: var(--space-6, 1.5rem);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-lg, 8px);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .team-card:hover {
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 4px 16px rgba(212, 148, 58, 0.06);
  }

  .team-photo-wrap { flex-shrink: 0; }

  .team-photo {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200, #E8DFD0);
  }

  .team-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin-bottom: 0.125rem;
  }

  .team-title {
    display: block;
    font-size: var(--text-xs, 0.75rem);
    color: var(--color-gold-text, #8B4513);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .team-bio {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.5;
  }

  /* ========================================
     FINAL CTA — warm gold band
     ======================================== */
  .final-cta {
    background: var(--color-black, #1A1A1A);
    padding: var(--space-20, 5rem) 0;
    text-align: center;
  }

  .final-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final-heading {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-5xl, 3rem));
    font-weight: 700;
    color: var(--neutral-50, #FAF5ED);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .final-subtext {
    font-size: var(--text-lg, 1.125rem);
    color: var(--neutral-400, #B0A696);
    margin-bottom: var(--space-8, 2rem);
  }

  .final-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6, 1.5rem);
    flex-wrap: wrap;
    justify-content: center;
  }

  .final-phone {
    color: var(--neutral-400, #B0A696);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .final-phone:hover { color: var(--color-gold, #D4943A); }

  /* ========================================
     RESPONSIVE — tablet
     ======================================== */
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; }
    .featured-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      min-height: auto;
    }
    .featured-main {
      grid-row: auto;
      min-height: 300px;
    }
    .featured-secondary {
      min-height: 200px;
    }
    .watching-row { grid-template-columns: repeat(2, 1fr); }
    .hubs-grid { grid-template-columns: 1fr; gap: var(--space-3, 0.75rem); }
    .voices-grid { grid-template-columns: 1fr; gap: var(--space-10, 2.5rem); }
    .voice-column { padding: 0; border-right: none; }
    .spotlight-cards { grid-template-columns: 1fr; gap: var(--space-4, 1rem); }
    .compact-grid { grid-template-columns: 1fr; gap: var(--space-10, 2.5rem); }
    .results-row { grid-template-columns: repeat(2, 1fr); }
    .result-item:nth-child(3) { border-left: none; }
    .team-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .hero { padding: var(--space-16, 4rem) 0 var(--space-12, 3rem); min-height: 400px; }
    .hero-h1 { font-size: 3rem; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
