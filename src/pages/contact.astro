---
/**
 * Contact — AZ Law Now
 * Phone, email, address, Netlify form, map placeholder
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { getContactPageSchema } from '../utils/schema';

const contactSchema = getContactPageSchema();
---

<BaseLayout
  title="Contact"
  description="Contact AZ Law Now for a free consultation. Call (602) 654-0202. Buckeye office open Mon-Fri 8am-6pm. Personal injury attorneys serving the West Valley."
  canonical="/contact/"
  schema={contactSchema}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container container-narrow">
      <h1>Let's Talk.</h1>
      <p class="hero-subtitle">
        You've got questions about your case. We've got answers. Call us, fill out the form, or walk into our Buckeye office. Free consultation, no obligation.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container" style="max-width: 1000px;">
      <div class="contact-grid">
        <!-- Left: Contact Info -->
        <div class="contact-info">
          <div class="contact-block">
            <h2 style="font-size: var(--text-2xl); margin-bottom: var(--space-6);">Get in Touch</h2>

            <div class="contact-item">
              <p class="contact-label">Phone</p>
              <a href={`tel:${siteConfig.phoneE164}`} class="phone-cta" style="font-size: var(--text-3xl);">
                {siteConfig.phoneFormatted}
              </a>
            </div>

            <div class="contact-item">
              <p class="contact-label">Email</p>
              <a href={`mailto:${siteConfig.email}`} style="font-size: var(--text-lg);">
                {siteConfig.email}
              </a>
            </div>

            <div class="contact-item">
              <p class="contact-label">Buckeye Office (HQ)</p>
              <p style="color: var(--color-black); font-weight: 500;">
                {siteConfig.address.street}<br />
                {siteConfig.address.city}, {siteConfig.address.state} {siteConfig.address.zip}
              </p>
            </div>

            <div class="contact-item">
              <p class="contact-label">Hours</p>
              <p style="color: var(--color-black); font-weight: 500;">
                Monday - Friday: 8:00 AM - 6:00 PM<br />
                Saturday - Sunday: Closed
              </p>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="contact-map" aria-label="Map showing AZ Law Now office location">
            <div class="contact-map__placeholder">
              <p style="color: var(--neutral-500); font-size: var(--text-sm);">Map loading...</p>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="contact-form-wrapper">
          <div class="card card-elevated" style="padding: var(--space-10);">
            <h2 style="font-size: var(--text-2xl); margin-bottom: var(--space-2);">Send Us a Message</h2>
            <p style="margin-bottom: var(--space-6); color: var(--color-slate);">
              Tell us about your situation. We'll get back to you within one business day.
            </p>

            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              action="/thank-you/"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="sr-only">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="form-field">
                <label for="name" class="form-label">Your Name</label>
                <input type="text" id="name" name="name" class="form-input" required placeholder="Full name" />
              </div>

              <div class="form-field">
                <label for="phone" class="form-label">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="form-input" required placeholder="(555) 555-5555" />
              </div>

              <div class="form-field">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="you@email.com" />
              </div>

              <div class="form-field">
                <label for="case-type" class="form-label">Type of Case</label>
                <select id="case-type" name="case-type" class="form-select">
                  <option value="">Select a case type...</option>
                  <option value="car-crash">Car Crash</option>
                  <option value="truck-crash">Truck Crash</option>
                  <option value="motorcycle-crash">Motorcycle Crash</option>
                  <option value="pedestrian">Pedestrian Injury</option>
                  <option value="bicycle">Bicycle Crash</option>
                  <option value="wrongful-death">Wrongful Death</option>
                  <option value="slip-fall">Slip and Fall</option>
                  <option value="medical-negligence">Medical Negligence</option>
                  <option value="school-bus">School Bus Crash</option>
                  <option value="elder-abuse">Elder Abuse</option>
                  <option value="nursing-home">Nursing Home Abuse</option>
                  <option value="dog-bite">Dog Bite</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="form-field">
                <label for="message" class="form-label">What Happened?</label>
                <textarea id="message" name="message" class="form-textarea" rows="5" placeholder="Brief description of your injury or incident..."></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-lg form-submit-full">
                Send Message →
              </button>

              <p style="font-size: var(--text-xs); color: var(--neutral-500); margin-top: var(--space-4); text-align: center;">
                Free consultation. No obligation. Your information stays confidential.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Prefer to Talk?</h2>
      <p>Skip the form. Call us directly for an immediate conversation about your case.</p>
      <div class="cta-buttons">
        <a href={`tel:${siteConfig.phoneE164}`} class="btn btn-primary btn-lg">
          Call {siteConfig.phoneFormatted} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contact-item {
    margin-bottom: var(--space-6);
  }

  .contact-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: var(--space-1);
  }

  .contact-map {
    margin-top: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--neutral-200);
  }

  .contact-map__placeholder {
    width: 100%;
    height: 200px;
    background: var(--neutral-100);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Full-width submit button inside form context */
  .form-submit-full {
    width: 100%;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
