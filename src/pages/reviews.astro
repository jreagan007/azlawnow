---
/**
 * Client Reviews — AZ Law Now
 * Placeholder testimonials with review cards
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { getReviewPageSchema } from '../utils/schema';

// Real Google reviews from azlawnow.com GMB profile
// Place ID: ChIJh-Cdb4E1K4cRtAyu8aMUr1Q
// Total: 89 reviews, 5.0 average (verified Apr 9, 2026)
const reviews = [
  {
    name: 'Jonathan Blackmore',
    rating: 5,
    text: 'Brendan is great at what he does. A+ quality service, great communication, definitely the resource you need in your corner. Thanks again Brendan.',
    source: 'Google',
    timeAgo: '3 months ago',
  },
  {
    name: 'Cheyanne Andrews',
    rating: 5,
    text: 'Brendan and his team have been absolutely incredible to me. Brendan is very informative and keeps you updated along the way. Also very time efficient. He was able to give me a great orthopedic surgeon referral. Truly made a horrible situation seamless and a good ending to a true nightmare.',
    source: 'Google',
    timeAgo: '4 months ago',
  },
  {
    name: 'A. Martin',
    rating: 5,
    text: 'From the consult to the final check, the team at AZ Law Now Injury Attorneys was incredible. They were professional, warm, helpful, and made me feel comfortable and important. Totally awesome. 100% recommend.',
    source: 'Google',
    timeAgo: '5 months ago',
  },
  {
    name: 'Eugene Kwon',
    rating: 5,
    text: 'I had a great experience with AZ Law Now Injury Attorneys. They were professional, responsive, and made the process easy. I really appreciated how they kept me updated and worked hard to get results. 10/10 recommend.',
    source: 'Google',
    timeAgo: '7 months ago',
  },
  {
    name: 'Avalon Curtin',
    rating: 5,
    text: 'AZ Law Now was amazing to work with after my car accident. Brendan and the team were quick to respond, kept me informed, and made the whole process so much easier. They were personable, professional, and got me a great outcome. Highly recommend.',
    source: 'Google',
    timeAgo: '9 months ago',
  },
];

// Aggregate stats from Google Business Profile
const reviewStats = {
  total: 89,
  average: 5.0,
  source: 'Google',
};

const reviewSchema = getReviewPageSchema(reviews, { total: reviewStats.total, average: reviewStats.average });
---

<BaseLayout
  title="Client Reviews"
  description="Read what our clients say about AZ Law Now. 5-star reviews from West Valley injury clients in Buckeye, Goodyear, Avondale, and Maricopa."
  canonical="/reviews/"
  schema={reviewSchema}
>
  <!-- Hero -->
  <section class="hero hero-centered">
    <div class="container container-narrow">
      <p class="uppercase text-gold-text mb-4" style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.1em; color: var(--color-gold-text, #8B4513);">Client Reviews</p>
      <h1>What Our Clients Say</h1>
      <div class="reviews-stats" aria-label="Review statistics">
        <div class="reviews-stat">
          <span class="reviews-stat__value">{reviewStats.average.toFixed(1)}</span>
          <div class="reviews-stat__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="var(--color-gold)">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
              </svg>
            ))}
          </div>
        </div>
        <div class="reviews-stat-divider" aria-hidden="true"></div>
        <div class="reviews-stat">
          <span class="reviews-stat__value">{reviewStats.total}</span>
          <span class="reviews-stat__label">Google Reviews</span>
        </div>
      </div>
      <p class="hero-subtitle" style="margin-left: auto; margin-right: auto;">
        Real feedback from real clients. Every review represents someone who trusted us with their case and got the result they deserved.
      </p>
    </div>
  </section>

  <!-- Reviews Grid -->
  <section class="section">
    <div class="container" style="max-width: 1000px;">
      <div class="reviews-grid">
        {reviews.map((review) => (
          <div class="review-card card card-elevated">
            <div class="review-card__stars" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: review.rating }).map(() => (
                <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--color-gold)" aria-hidden="true">
                  <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/>
                </svg>
              ))}
            </div>
            <blockquote class="review-card__text">
              "{review.text}"
            </blockquote>
            <div class="review-card__author">
              <span class="review-card__name">{review.name}</span>
              <span class="review-card__location">via {review.source} · {review.timeAgo}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>You Deserve Answers.</h2>
      <p>Tell us what happened. We'll tell you what's next.</p>
      <div class="cta-buttons">
        <a href="/free-case-review/" class="btn btn-primary btn-lg">
          Get My Free Consultation →
        </a>
        <a href={`tel:${siteConfig.phoneE164}`} class="phone-cta">
          {siteConfig.phoneFormatted}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .review-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .review-card__stars {
    display: flex;
    gap: var(--space-1);
  }

  .review-card__text {
    color: var(--color-slate);
    line-height: 1.7;
    font-style: normal;
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    flex-grow: 1;
  }

  .review-card__author {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-4);
    border-top: 1px solid var(--neutral-200);
  }

  .review-card__name {
    font-weight: 700;
    color: var(--color-black);
  }

  .review-card__location {
    font-size: var(--text-sm);
    color: var(--neutral-500);
  }

  /* Reviews stats strip in hero */
  .reviews-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    margin: var(--space-6) 0 var(--space-8);
  }

  .reviews-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .reviews-stat__value {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-black);
    line-height: 1;
  }

  .reviews-stat__stars {
    display: flex;
    gap: 2px;
  }

  .reviews-stat__label {
    font-size: var(--text-xs);
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .reviews-stat-divider {
    width: 1px;
    height: 48px;
    background: var(--neutral-300);
  }

  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
