---
/**
 * Blog Hub — AZ Law Now
 * Combined feed from all content authors
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
import { getCollection } from 'astro:content';
import { authors } from '../../data/authors';

// Pull all three collections
const [resources, legalGuides, clientGuides] = await Promise.all([
  getCollection('resources'),
  getCollection('legal-guides'),
  getCollection('client-guides'),
]);

// Tag each entry with its section path
const tagged = [
  ...resources.map((e) => ({ id: e.id, data: e.data, basePath: '/resources/' as const })),
  ...legalGuides.map((e) => ({ id: e.id, data: e.data, basePath: '/legal-guides/' as const })),
  ...clientGuides.map((e) => ({ id: e.id, data: e.data, basePath: '/client-guides/' as const })),
];

// Sort all by publishedAt descending
const sorted = tagged.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Category labels for badges
const categoryLabels: Record<string, string> = {
  'investigation': 'Investigation',
  'legal-guide': 'Legal Guide',
  'client-guide': 'Client Guide',
};
---

<BaseLayout
  title="Blog"
  description="AZ Law Now blog. Injury law insights, West Valley crash analysis, and practical guidance for injured clients across Arizona."
  canonical="/blog/"
>
  <!-- Hero -->
  <section class="hero hero-centered">
    <div class="container container-narrow">
      <p class="uppercase text-gold mb-4" style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.1em;">Blog</p>
      <h1>Insights from Our Team</h1>
      <p class="hero-subtitle" style="margin-left: auto; margin-right: auto;">
        Investigation reports, legal analysis, and practical guidance from the AZ Law Now team. Written for real people with real questions.
      </p>
    </div>
  </section>

  <!-- Category Links -->
  <section class="section-sm">
    <div class="container container-narrow">
      <div class="hub-links">
        <p style="text-align: center; color: var(--color-slate); margin-bottom: var(--space-4); font-size: var(--text-sm);">Browse by category:</p>
        <div style="display: flex; justify-content: center; gap: var(--space-4); flex-wrap: wrap;">
          <a href="/resources/" class="btn btn-secondary">Resources</a>
          <a href="/legal-guides/" class="btn btn-secondary">Legal Guides</a>
          <a href="/client-guides/" class="btn btn-secondary">Client Guides</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Grid -->
  <section class="section">
    <div class="container container-narrow">
      {sorted.length === 0 ? (
        <div class="hub-placeholder">
          <p style="color: var(--color-slate); text-align: center; font-size: var(--text-lg);">
            Blog posts coming soon. Call <a href="tel:+16026540202">(602) 654-0202</a> with questions about your case.
          </p>
        </div>
      ) : (
        <div class="article-list">
          {sorted.map((entry) => {
            const author = authors[entry.data.author] || authors['brendan-franks'];
            const date = new Date(entry.data.publishedAt).toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            const badge = categoryLabels[entry.data.category] || entry.data.category;
            const href = `${entry.basePath}${entry.id}/`;
            return (
              <article class="article-card">
                {entry.data.image && (
                  <a href={href} class="article-card__image-link">
                    <img
                      src={entry.data.image}
                      alt={entry.data.title}
                      class="article-card__image"
                      width="600"
                      height="338"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="article-card__content">
                  <div class="article-card__meta">
                    <span class="article-card__badge">{badge}</span>
                    <span class="article-card__sep">·</span>
                    <span class="article-card__author">{author.name}</span>
                    <span class="article-card__sep">·</span>
                    <time datetime={entry.data.publishedAt}>{date}</time>
                    {entry.data.readingTime && (
                      <>
                        <span class="article-card__sep">·</span>
                        <span>{entry.data.readingTime}</span>
                      </>
                    )}
                  </div>
                  <h2 class="article-card__title">
                    <a href={href}>{entry.data.title}</a>
                  </h2>
                  <p class="article-card__desc">{entry.data.description}</p>
                  <a href={href} class="article-card__link">Read →</a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>{siteConfig.messaging.l7FormHeadline}</h2>
      <p>{siteConfig.messaging.l7FormSubhead}</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn btn-primary btn-lg">
          {siteConfig.messaging.l8Primary} →
        </a>
        <a href={`tel:${siteConfig.phoneE164}`} class="phone-cta">
          {siteConfig.phoneFormatted}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hub-placeholder {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--neutral-200);
    border-bottom: 1px solid var(--neutral-200);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .article-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--neutral-200);
  }

  .article-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (min-width: 640px) {
    .article-card {
      grid-template-columns: 280px 1fr;
    }
  }

  .article-card__image-link {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .article-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .article-card__image-link:hover .article-card__image {
    transform: scale(1.03);
  }

  .article-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--neutral-500);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .article-card__badge {
    background: rgba(212, 148, 58, 0.15);
    color: #D4943A;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px 6px;
    border-radius: 3px;
  }

  .article-card__author {
    font-weight: 600;
    color: var(--neutral-600);
  }

  .article-card__sep {
    color: var(--neutral-300);
  }

  .article-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: var(--space-2);
  }

  .article-card__title a {
    color: #1A1A1A;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .article-card__title a:hover {
    color: var(--color-gold);
  }

  .article-card__desc {
    font-size: var(--text-sm);
    color: #4A5859;
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .article-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .article-card__link:hover {
    color: var(--color-gold-hover);
  }
</style>
