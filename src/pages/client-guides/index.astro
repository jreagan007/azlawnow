---
/**
 * Client Guides Hub — AZ Law Now
 * Stephanie's client-facing guidance content
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
---

<BaseLayout
  title="Client Guides"
  description="Step-by-step guides for injury clients. What to expect during your case, how to work with insurance, and how to prepare for each stage."
  canonical="/client-guides/"
>
  <!-- Hero -->
  <section class="hero hero-centered">
    <div class="container container-narrow">
      <p class="uppercase text-gold mb-4" style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.1em;">Client Guides</p>
      <h1>Your Roadmap Through the Process</h1>
      <p class="hero-subtitle" style="margin-left: auto; margin-right: auto;">
        Stephanie walks you through what happens at every stage of your case. No surprises. No confusion. Just clear next steps.
      </p>
    </div>
  </section>

  <!-- Content Placeholder -->
  <section class="section">
    <div class="container container-narrow">
      <div class="hub-placeholder">
        <p style="color: var(--color-slate); text-align: center; font-size: var(--text-lg);">
          Guides coming soon. Call <a href="tel:+16026540202">(602) 654-0202</a> and Stephanie will answer your questions personally.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>{siteConfig.messaging.l7FormHeadline}</h2>
      <p>{siteConfig.messaging.l7FormSubhead}</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn btn-primary btn-lg">
          {siteConfig.messaging.l8Primary} →
        </a>
        <a href={`tel:${siteConfig.phoneE164}`} class="phone-cta">
          {siteConfig.phoneFormatted}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hub-placeholder {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--neutral-200);
    border-bottom: 1px solid var(--neutral-200);
  }
</style>
