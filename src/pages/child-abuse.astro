---
import { getEntry, render } from 'astro:content';
import PracticeAreaLayout from '../layouts/PracticeAreaLayout.astro';

const entry = await getEntry('practice-areas', 'child-abuse');
if (!entry) return Astro.redirect('/404');
const { Content, headings } = await render(entry);
---
<PracticeAreaLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical="/child-abuse/"
  practiceArea={entry.data.practiceArea}
  heroTitle={entry.data.heroTitle}
  heroSubtitle={entry.data.heroSubtitle}
  heroImage={entry.data.heroImage}
  faqs={entry.data.faqs}
  cluster={entry.data.cluster}
  clusterLabel={entry.data.clusterLabel}
  keyTakeaway={entry.data.keyTakeaway}
  dataSources={entry.data.dataSources}
  headings={headings}
  updated={entry.data.updatedAt}
>
  <Content />
</PracticeAreaLayout>
