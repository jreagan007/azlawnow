---
/**
 * Insights Hub — AZ Law Now
 * Newspaper front page layout for Brendan's data-led journalism
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
import { getCollection } from 'astro:content';
import { authors } from '../../data/authors';

let entries: any[] = [];
try {
  entries = await getCollection('insights');
} catch {
  entries = [];
}

const published = entries
  .filter((e) => !e.data.draft)
  .sort((a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );

const featured = published.find((e) => e.data.featured) || published[0] || null;
const rest = published.filter((e) => e !== featured);

const categoryLabels: Record<string, string> = {
  'crash-data': 'Crash Data',
  'safety-analysis': 'Safety Analysis',
  'abuse-investigation': 'Abuse Investigation',
  'negligence-report': 'Negligence Report',
  'infrastructure': 'Infrastructure',
  'policy': 'Policy',
};

const categories = Object.keys(categoryLabels);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const brendan = authors['brendan-franks'];

/* Placeholder content for empty state */
const placeholderFeatured = {
  title: 'Arizona Schools Restrained 4,200+ Students Last Year',
  category: 'abuse-investigation',
  description: 'Public records reveal the scope of physical restraint incidents in Maricopa County schools. The data tells a story that most families never hear.',
};

const placeholderCards = [
  {
    title: 'Maricopa County Daycares With the Most DHS Violations',
    category: 'negligence-report',
    date: 'Coming Soon',
    image: '/images/cards/arizona-daycare-violations.webp',
  },
  {
    title: "The SR-347 Problem: Maricopa's Most Dangerous Corridor",
    category: 'crash-data',
    date: 'Coming Soon',
    image: '/images/cards/sr-347-crash-corridor.webp',
  },
  {
    title: "88,094 Crashes: What Maricopa County's 2025 Data Tells Us",
    category: 'crash-data',
    date: 'Coming Soon',
    image: '/images/cards/i-10-crash-data-buckeye-goodyear.webp',
  },
  {
    title: 'West Valley Elder Care Facilities Under Review',
    category: 'abuse-investigation',
    date: 'Coming Soon',
    image: '/images/heroes/elder-abuse.webp',
  },
];

/* Use frontmatter image field directly — every article has a unique hero */
---

<BaseLayout
  title="Investigations"
  description="Data-led investigations into Arizona public safety, crash data, and institutional accountability. We pull the records. We name the patterns."
  canonical="/insights/"
>
  <!-- ============================================
       PAGE HEADER — Editorial masthead
       ============================================ -->
  <section class="inv-header">
    <div class="container container-narrow">
      <p class="inv-eyebrow">Investigations</p>
      <h1 class="inv-headline">Data-Led Reporting for Arizona Families</h1>
      <p class="inv-subtitle">
        We pull the public data. We name the patterns. We give families the information they need before they even know they need a lawyer.
      </p>
    </div>
  </section>

  <!-- ============================================
       CATEGORY FILTER PILLS
       ============================================ -->
  <section class="inv-filters">
    <div class="container">
      <div class="inv-pills">
        <button class="inv-pill inv-pill--active" aria-current="true">All</button>
        {categories.map((cat) => (
          <button class="inv-pill" data-category={cat}>
            {categoryLabels[cat]}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURED INVESTIGATION — Top Story split card
       ============================================ -->
  <section class="inv-featured-section">
    <div class="container">
      <p class="inv-featured-eyebrow">Top Investigation</p>
      {featured ? (
        <a href={`/insights/${featured.id}/`} class="inv-featured-card">
          <div class="inv-featured-media">
            <img
              src={featured.data.image || '/images/heroes/practice-area-default.webp'}
              alt=""
              class="inv-featured-image"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="inv-featured-body">
            <div class="inv-featured-badge">
              <span class="inv-badge">
                {categoryLabels[featured.data.category] || 'Investigation'}
              </span>
              {featured.data.readingTime && (
                <span class="inv-reading-time">{featured.data.readingTime}</span>
              )}
            </div>
            <h2 class="inv-featured-title">{featured.data.title}</h2>
            <p class="inv-featured-desc">{featured.data.description}</p>
            <div class="inv-featured-byline">
              <img
                src={brendan.photo}
                alt={brendan.name}
                class="inv-featured-avatar"
                width="40"
                height="40"
                loading="lazy"
              />
              <div class="inv-featured-byline-meta">
                <span class="inv-featured-author">{brendan.name}</span>
                <span class="inv-featured-byline-sub">
                  Editor-in-Chief
                  <span class="inv-featured-sep" aria-hidden="true">·</span>
                  <time datetime={featured.data.publishedAt}>
                    {formatDate(featured.data.publishedAt)}
                  </time>
                </span>
              </div>
            </div>
            <span class="inv-featured-cta" aria-hidden="true">
              Read the investigation <span class="inv-featured-cta-arrow">&rarr;</span>
            </span>
          </div>
        </a>
      ) : (
        <div class="inv-featured-card inv-featured-card--placeholder">
          <div class="inv-featured-media">
            <img
              src="/images/cards/arizona-school-restraint-data.webp"
              alt=""
              class="inv-featured-image"
              loading="lazy"
            />
          </div>
          <div class="inv-featured-body">
            <div class="inv-featured-badge">
              <span class="inv-badge">
                {categoryLabels[placeholderFeatured.category] || 'Investigation'}
              </span>
              <span class="inv-coming-soon">Coming Soon</span>
            </div>
            <h2 class="inv-featured-title">{placeholderFeatured.title}</h2>
            <p class="inv-featured-desc">{placeholderFeatured.description}</p>
            <div class="inv-featured-byline">
              <img
                src={brendan.photo}
                alt={brendan.name}
                class="inv-featured-avatar"
                width="40"
                height="40"
                loading="lazy"
              />
              <div class="inv-featured-byline-meta">
                <span class="inv-featured-author">{brendan.name}</span>
                <span class="inv-featured-byline-sub">Editor-in-Chief</span>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================
       INVESTIGATION GRID
       ============================================ -->
  <section class="inv-grid-section">
    <div class="container">
      <h2 class="inv-grid-heading">Recent Investigations</h2>

      {rest.length > 0 ? (
        <div class="inv-grid">
          {rest.map((entry) => (
            <a href={`/insights/${entry.id}/`} class="inv-card">
              <img
                src={entry.data.image || '/images/heroes/practice-area-default.webp'}
                alt=""
                class="inv-card-thumb"
                loading="lazy"
              />
              <span class="inv-card-badge">
                {categoryLabels[entry.data.category] || entry.data.category}
              </span>
              <h3 class="inv-card-title">{entry.data.title}</h3>
              <p class="inv-card-desc">{entry.data.description}</p>
              <div class="inv-card-meta">
                <time datetime={entry.data.publishedAt}>
                  {formatDate(entry.data.publishedAt)}
                </time>
                {entry.data.readingTime && (
                  <>
                    <span class="inv-card-sep">·</span>
                    <span>{entry.data.readingTime}</span>
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="inv-grid">
          {placeholderCards.map((card) => (
            <div class="inv-card inv-card--placeholder">
              <img
                src={card.image}
                alt=""
                class="inv-card-thumb"
                loading="lazy"
              />
              <span class="inv-card-badge">
                {categoryLabels[card.category] || card.category}
              </span>
              <h3 class="inv-card-title">{card.title}</h3>
              <div class="inv-card-meta">
                <span class="inv-coming-soon">{card.date}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================
     PAGE HEADER
     ============================================ */
  .inv-header {
    padding: var(--space-16) 0 var(--space-10);
    background: var(--color-bg);
    text-align: center;
  }

  .inv-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-4);
  }

  .inv-headline {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .inv-subtitle {
    font-size: var(--text-lg);
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ============================================
     CATEGORY FILTER PILLS
     ============================================ */
  .inv-filters {
    padding: 0 0 var(--space-8);
    background: var(--color-bg);
  }

  .inv-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  .inv-pill {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--neutral-500);
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .inv-pill:hover {
    border-color: var(--color-gold-text, #8B4513);
    color: var(--color-gold-text, #8B4513);
  }

  .inv-pill--active {
    background: var(--color-gold);
    color: var(--color-white);
    border-color: var(--color-gold);
  }

  .inv-pill--active:hover {
    background: var(--color-gold-hover);
    border-color: var(--color-gold-hover);
    color: var(--color-white);
  }

  /* ============================================
     FEATURED INVESTIGATION — Top Story split card
     ============================================ */
  .inv-featured-section {
    padding: 0 0 var(--space-12);
    background: var(--color-bg);
  }

  .inv-featured-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold-text, #8B4513);
    margin: 0 0 var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
  }

  .inv-featured-card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--transition-base),
                border-color var(--transition-base),
                transform var(--transition-base);
  }

  @media (min-width: 900px) {
    .inv-featured-card {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    }
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .inv-featured-card--placeholder {
    cursor: default;
    opacity: 0.92;
  }

  /* Media column */
  .inv-featured-media {
    position: relative;
    overflow: hidden;
    background: var(--neutral-100);
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 900px) {
    .inv-featured-media {
      aspect-ratio: auto;
      min-height: 380px;
    }
  }

  .inv-featured-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-image {
    transform: scale(1.03);
  }

  /* Body column */
  .inv-featured-body {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
    gap: var(--space-4);
  }

  @media (min-width: 900px) {
    .inv-featured-body {
      padding: var(--space-10);
      justify-content: center;
    }
  }

  .inv-featured-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
  }

  .inv-badge {
    display: inline-block;
    background: rgba(212, 148, 58, 0.12);
    color: var(--color-gold-hover, #C2842E);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .inv-coming-soon {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .inv-reading-time {
    font-size: var(--text-xs);
    color: var(--neutral-500);
    font-weight: 500;
  }

  .inv-featured-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 2.8vw, var(--text-4xl));
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-title {
    color: var(--color-gold-text, #8B4513);
  }

  .inv-featured-desc {
    font-size: var(--text-base);
    color: var(--color-slate);
    line-height: 1.65;
    margin: 0;
  }

  .inv-featured-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-slate);
    margin-top: var(--space-2);
  }

  .inv-featured-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200);
    flex-shrink: 0;
  }

  .inv-featured-byline-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .inv-featured-author {
    font-weight: 600;
    color: var(--color-black);
    font-size: var(--text-sm);
  }

  .inv-featured-byline-sub {
    font-size: var(--text-xs);
    color: var(--neutral-500);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1-5, 6px);
  }

  .inv-featured-sep {
    color: var(--neutral-300);
  }

  .inv-featured-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-gold-text, #8B4513);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .inv-featured-cta-arrow {
    transition: transform var(--transition-base);
    display: inline-block;
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-cta-arrow {
    transform: translateX(4px);
  }

  /* ============================================
     INVESTIGATION GRID
     ============================================ */
  .inv-grid-section {
    padding: 0 0 var(--space-16);
    background: var(--color-bg);
  }

  .inv-grid-heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--neutral-200);
  }

  .inv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .inv-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    padding: 0;
    text-decoration: none;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .inv-card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .inv-card-badge,
  .inv-card-title,
  .inv-card-desc,
  .inv-card-meta {
    padding-left: var(--space-6);
    padding-right: var(--space-6);
  }

  .inv-card-badge {
    margin-top: var(--space-4);
  }

  .inv-card-meta {
    padding-bottom: var(--space-6);
  }

  a.inv-card:hover {
    border-color: var(--color-gold-text, #8B4513);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .inv-card--placeholder {
    cursor: default;
    opacity: 0.7;
  }

  .inv-card--placeholder:hover {
    transform: none;
    box-shadow: none;
  }

  .inv-card-badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(212, 148, 58, 0.1);
    color: var(--color-gold-hover);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem var(--space-2);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .inv-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.25;
    margin-bottom: var(--space-3);
    flex: 1;
  }

  a.inv-card:hover .inv-card-title {
    color: var(--color-gold-text, #8B4513);
  }

  .inv-card-desc {
    font-size: var(--text-sm);
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .inv-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--neutral-500);
    margin-top: auto;
  }

  .inv-card-sep {
    color: var(--neutral-300);
  }

  /* ============================================
     DARK CTA BAND
     ============================================ */
  .inv-cta {
    background: linear-gradient(135deg, var(--color-black) 0%, rgba(212, 148, 58, 0.12) 100%);
  }

  .inv-cta-heading {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 700;
    color: var(--neutral-50);
    margin-bottom: var(--space-4);
  }

  .inv-cta-text {
    color: var(--neutral-400);
    font-size: var(--text-lg);
    max-width: 560px;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }

  .inv-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .inv-cta-phone {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gold-hover, #C2842E);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .inv-cta-phone:hover {
    color: var(--color-gold-text, #8B4513);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .inv-header {
      padding: var(--space-10) 0 var(--space-8);
    }

    .inv-featured-card {
      padding: var(--space-6);
    }

    .inv-grid {
      grid-template-columns: 1fr;
    }

    .inv-cta-actions {
      flex-direction: column;
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .inv-pills {
      gap: var(--space-1);
    }

    .inv-pill {
      font-size: 0.6875rem;
      padding: var(--space-1) var(--space-3);
    }
  }
</style>
