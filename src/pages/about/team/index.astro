---
/**
 * Our Team — AZ Law Now
 * Three team member cards with Person schema
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../data/site-config';
import { getTeamPageSchema } from '../../../utils/schema';

const attorneys = [
  {
    name: 'Brendan Franks',
    title: 'Investigator',
    slug: 'brendan-franks',
    bio: 'Brendan goes to the crash scene the day you hire us. He photographs evidence, identifies witnesses, pulls surveillance footage, and builds the case file that gives your claim its foundation. While other firms wait for police reports, Brendan is already documenting what they\'ll miss.',
    photo: '/images/team/brendan-franks.jpg',
  },
  {
    name: 'Brandon Millam, J.D.',
    title: 'Attorney',
    slug: 'brandon-millam',
    bio: 'Brandon handles every legal dimension of your case. From initial demand letters to courtroom litigation, he builds strategy on Brendan\'s evidence file and fights for the full value of your claim. He prepares every case as if it\'s going to trial, because that preparation changes how insurance companies negotiate.',
    photo: '/images/team/brandon-millam.jpg',
  },
  {
    name: 'Stephanie Ramirez',
    title: 'Client Advocate',
    slug: 'stephanie-ramirez',
    bio: 'Stephanie is your direct point of contact from the moment you sign with us until your case resolves. She coordinates medical appointments, tracks deadlines, and keeps you updated so you\'re never left wondering what\'s happening. When you call, you get Stephanie.',
    photo: '/images/team/stephanie-ramirez.jpg',
  },
];

const teamSchema = getTeamPageSchema(attorneys.map(a => ({
  name: a.name,
  title: a.title,
  slug: a.slug,
})));
---

<BaseLayout
  title="Our Team"
  description="Meet the team at AZ Law Now. Brendan investigates. Brandon litigates. Stephanie guides. Three people working your case from day one."
  canonical="/about/team/"
  schema={teamSchema}
>
  <!-- Hero -->
  <section class="hero hero-centered">
    <div class="container container-narrow">
      <p class="uppercase text-gold mb-4" style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.1em;">Our Team</p>
      <h1>Three People. Your Whole Case.</h1>
      <p class="hero-subtitle" style="margin-left: auto; margin-right: auto;">
        Every client gets the same dedicated team. An investigator, an attorney, and a guide who keeps you informed at every step.
      </p>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="section">
    <div class="container" style="max-width: 1000px;">
      <div class="team-grid">
        {attorneys.map((member) => (
          <div class="team-card card card-elevated">
            <div class="team-card__photo">
              <div class="team-card__placeholder" aria-label={`Photo of ${member.name}`}>
                <span class="team-card__initials">
                  {member.name.split(' ').map(n => n[0]).join('').replace(',', '')}
                </span>
              </div>
            </div>
            <div class="team-card__info">
              <h2 class="team-card__name">{member.name}</h2>
              <p class="team-card__title">{member.title}</p>
              <p class="team-card__bio">{member.bio}</p>
              <a href={`/about/team/${member.slug}/`} class="btn btn-ghost">
                Read full bio →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Meet Your Team?</h2>
      <p>Call us for a free consultation. You'll talk to real people, not a call center.</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn btn-primary btn-lg">
          {siteConfig.messaging.l8Primary} →
        </a>
        <a href={`tel:${siteConfig.phoneE164}`} class="phone-cta">
          {siteConfig.phoneFormatted}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .team-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .team-card__photo {
    width: 200px;
    height: 240px;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .team-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-black) 0%, var(--neutral-800) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .team-card__initials {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-gold);
  }

  .team-card__name {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }

  .team-card__title {
    color: var(--color-gold);
    font-weight: 600;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .team-card__bio {
    color: var(--color-slate);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .team-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .team-card__photo {
      width: 160px;
      height: 200px;
      margin: 0 auto;
    }
  }
</style>
