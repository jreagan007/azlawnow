---
/**
 * /about/team/ → /about/#the-editors (301, consolidated April 2026)
 *
 * The standalone team page was merged into the editorial /about/ page.
 * Production redirects are handled at the Netlify edge via netlify.toml (301).
 * This stub exists as a fallback so dev, preview deploys, and any environment
 * that bypasses Netlify's redirect layer still send visitors to the right place.
 */
const target = '/about/#the-editors';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to About | AZ Law Now</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={`https://azlawnow.com${target}`} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script set:html={`window.location.replace(${JSON.stringify(target)});`} />
  </head>
  <body>
    <p>This page has moved. Redirecting to <a href={target}>our about page</a>…</p>
  </body>
</html>
