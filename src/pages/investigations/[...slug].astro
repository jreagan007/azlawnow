---
/**
 * Dynamic route: /investigations/[slug]
 * Renders MDX articles from the insights content collection (Brendan's data journalism)
 */

import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('investigations');
  return entries
    .filter((e) => !e.data.draft)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  author={entry.data.author}
  reviewedBy={entry.data.reviewedBy}
  category="investigation"
  tags={entry.data.tags}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  image={entry.data.image}
  ogImage={entry.data.ogImage}
  readingTime={entry.data.readingTime}
  schemaType={entry.data.schemaType as 'Article' | 'NewsArticle'}
  keyTakeaway={entry.data.keyTakeaway}
  faqs={entry.data.faqs}
  dataSources={entry.data.dataSources}
  headings={headings}
>
  <Content />
</ArticleLayout>
