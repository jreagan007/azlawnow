---
/**
 * Insights Hub — AZ Law Now
 * Newspaper front page layout for Brendan's data-led journalism
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
import { getCollection } from 'astro:content';
import { authors } from '../../data/authors';

let entries: any[] = [];
try {
  entries = await getCollection('investigations');
} catch {
  entries = [];
}

const published = entries
  .filter((e) => !e.data.draft)
  .sort((a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );

const featured = published.find((e) => e.data.featured) || published[0] || null;
const rest = published.filter((e) => e !== featured);

const categoryLabels: Record<string, string> = {
  'crash-data': 'Crash Data',
  'safety-analysis': 'Safety Analysis',
  'abuse-investigation': 'Abuse Investigation',
  'negligence-report': 'Negligence Report',
  'infrastructure': 'Infrastructure',
  'policy': 'Policy',
  'firm-news': 'Firm News',
  'community': 'Community',
};

const categories = Object.keys(categoryLabels);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

/**
 * Pull the first numeric-led sentence from a string. Falls back to the
 * first sentence if nothing starts with a digit. Used to surface the
 * bomb stat above the headline on every card.
 */
function extractBombStat(...sources: Array<string | undefined>): string | null {
  for (const src of sources) {
    if (!src) continue;
    // Split on sentence boundaries, prefer the first one that opens with a
    // number, percent, dollar amount, or starts a digit-led clause.
    const sentences = src.split(/(?<=[.!?])\s+/);
    const numeric = sentences.find((s) => /\b\d[\d,.]*/.test(s));
    if (numeric) return numeric.trim();
  }
  // No digits anywhere — fall back to the first sentence of the first source.
  for (const src of sources) {
    if (!src) continue;
    const first = src.split(/(?<=[.!?])\s+/)[0];
    if (first) return first.trim();
  }
  return null;
}

const brendan = authors['brendan-franks'];

/* Placeholder content for empty state */
const placeholderFeatured = {
  title: 'Arizona Schools Restrained 4,200+ Students Last Year',
  category: 'abuse-investigation',
  description: 'Public records reveal the scope of physical restraint incidents in Maricopa County schools. The data tells a story that most families never hear.',
};

const placeholderCards = [
  {
    title: 'Maricopa County Daycares With the Most DHS Violations',
    category: 'negligence-report',
    date: 'Coming Soon',
    image: '/images/cards/arizona-daycare-violations.webp',
  },
  {
    title: "The SR-347 Problem: Maricopa's Most Dangerous Corridor",
    category: 'crash-data',
    date: 'Coming Soon',
    image: '/images/cards/sr-347-crash-corridor.webp',
  },
  {
    title: "88,094 Crashes: What Maricopa County's 2025 Data Tells Us",
    category: 'crash-data',
    date: 'Coming Soon',
    image: '/images/cards/i-10-crash-data-buckeye-goodyear.webp',
  },
  {
    title: 'West Valley Elder Care Facilities Under Review',
    category: 'abuse-investigation',
    date: 'Coming Soon',
    image: '/images/heroes/elder-abuse.webp',
  },
];

/* Use frontmatter image field directly — every article has a unique hero */
---

<BaseLayout
  title="Investigations"
  description="Data-led investigations into Arizona public safety, crash data, and institutional accountability. We pull the records. We name the patterns."
  canonical="/investigations/"
>
  <!-- ============================================
       PAGE HEADER — Editorial masthead
       ============================================ -->
  <section class="inv-header">
    <div class="container container-narrow">
      <p class="inv-eyebrow">Investigations</p>
      <h1 class="inv-headline">Data-Led Reporting for Arizona Families</h1>
      <p class="inv-subtitle">
        We pull the public data. We name the patterns. We give families the information they need before they even know they need a lawyer.
      </p>
    </div>
  </section>

  <!-- ============================================
       CATEGORY FILTER PILLS
       ============================================ -->
  <section class="inv-filters">
    <div class="container">
      <div class="inv-pills">
        <button class="inv-pill inv-pill--active" aria-current="true">All</button>
        {categories.map((cat) => (
          <button class="inv-pill" data-category={cat}>
            {categoryLabels[cat]}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURED INVESTIGATION — Top Story split card
       ============================================ -->
  <section class="inv-featured-section">
    <div class="container">
      <p class="inv-featured-eyebrow">Top Investigation</p>
      {featured ? (() => {
        const featuredBomb = extractBombStat(
          (featured.data as any).keyTakeaway,
          featured.data.description,
        );
        const featuredHasMethod = !!(featured.data as any).methodology;
        const featuredCategoryClass = `cat--${featured.data.category}`;
        return (
        <a
          href={`/investigations/${featured.id}/`}
          class={`inv-featured-card ${featuredCategoryClass}`}
          data-category={featured.data.category}
        >
          <div class="inv-featured-media">
            <img
              src={featured.data.image || '/images/heroes/practice-area-default.webp'}
              alt={featured.data.title}
              class="inv-featured-image"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="inv-featured-body">
            <span class="inv-featured-category" data-category={featured.data.category}>
              {categoryLabels[featured.data.category] || 'Investigation'}
            </span>
            {featuredBomb && (
              <p class="inv-featured-bomb">{featuredBomb}</p>
            )}
            <h2 class="inv-featured-title">{featured.data.title}</h2>
            <p class="inv-featured-desc">{featured.data.description}</p>
            <div class="inv-featured-byline">
              <img
                src={brendan.photo}
                alt={brendan.name}
                class="inv-featured-avatar"
                width="40"
                height="40"
                loading="lazy"
              />
              <div class="inv-featured-byline-meta">
                <span class="inv-featured-author">{brendan.name}</span>
                <span class="inv-featured-byline-sub">
                  Editor-in-Chief
                  <span class="inv-featured-sep" aria-hidden="true">·</span>
                  <time datetime={featured.data.publishedAt}>
                    {formatDate(featured.data.publishedAt)}
                  </time>
                  {featured.data.readingTime && (
                    <>
                      <span class="inv-featured-sep" aria-hidden="true">·</span>
                      <span>{featured.data.readingTime}</span>
                    </>
                  )}
                  {featuredHasMethod && (
                    <>
                      <span class="inv-featured-sep" aria-hidden="true">·</span>
                      <span
                        class="inv-method-pill"
                        title="Includes methodology"
                        aria-label="Includes methodology"
                      >
                        <span class="inv-method-pill__glyph" aria-hidden="true">§</span>
                        Methodology
                      </span>
                    </>
                  )}
                </span>
              </div>
            </div>
            <span class="inv-featured-cta" aria-hidden="true">
              Read the investigation <span class="inv-featured-cta-arrow">&rarr;</span>
            </span>
          </div>
        </a>
        );
      })() : (
        <div class="inv-featured-card inv-featured-card--placeholder">
          <div class="inv-featured-media">
            <img
              src="/images/cards/arizona-school-restraint-data.webp"
              alt={placeholderFeatured.title}
              class="inv-featured-image"
              loading="lazy"
            />
          </div>
          <div class="inv-featured-body">
            <div class="inv-featured-badge">
              <span class="inv-badge">
                {categoryLabels[placeholderFeatured.category] || 'Investigation'}
              </span>
              <span class="inv-coming-soon">Coming Soon</span>
            </div>
            <h2 class="inv-featured-title">{placeholderFeatured.title}</h2>
            <p class="inv-featured-desc">{placeholderFeatured.description}</p>
            <div class="inv-featured-byline">
              <img
                src={brendan.photo}
                alt={brendan.name}
                class="inv-featured-avatar"
                width="40"
                height="40"
                loading="lazy"
              />
              <div class="inv-featured-byline-meta">
                <span class="inv-featured-author">{brendan.name}</span>
                <span class="inv-featured-byline-sub">Editor-in-Chief</span>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================
       INVESTIGATION GRID
       ============================================ -->
  <section class="inv-grid-section">
    <div class="container">
      <h2 class="inv-grid-heading">Recent Investigations</h2>

      {rest.length > 0 ? (
        <div class="inv-grid">
          {rest.map((entry) => {
            const bomb = extractBombStat(
              (entry.data as any).keyTakeaway,
              entry.data.description,
            );
            const hasMethod = !!(entry.data as any).methodology;
            return (
              <a
                href={`/investigations/${entry.id}/`}
                class={`inv-card cat--${entry.data.category}`}
                data-category={entry.data.category}
              >
                <img
                  src={entry.data.image || '/images/heroes/practice-area-default.webp'}
                  alt={entry.data.title}
                  class="inv-card-thumb"
                  loading="lazy"
                />
                <div class="inv-card-body">
                  <span class="inv-card-category" data-category={entry.data.category}>
                    {categoryLabels[entry.data.category] || entry.data.category}
                  </span>
                  {bomb && <p class="inv-card-bomb">{bomb}</p>}
                  <h3 class="inv-card-title">{entry.data.title}</h3>
                  <p class="inv-card-desc">{entry.data.description}</p>
                  <div class="inv-card-meta">
                    <time datetime={entry.data.publishedAt}>
                      {formatDate(entry.data.publishedAt)}
                    </time>
                    {entry.data.readingTime && (
                      <>
                        <span class="inv-card-sep">·</span>
                        <span>{entry.data.readingTime}</span>
                      </>
                    )}
                    {hasMethod && (
                      <>
                        <span class="inv-card-sep">·</span>
                        <span class="inv-method-pill" title="Includes methodology">
                          <span class="inv-method-pill__glyph" aria-hidden="true">§</span>
                          Methodology
                        </span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="inv-grid">
          {placeholderCards.map((card) => (
            <div class={`inv-card inv-card--placeholder cat--${card.category}`} data-category={card.category}>
              <img
                src={card.image}
                alt={card.title}
                class="inv-card-thumb"
                loading="lazy"
              />
              <div class="inv-card-body">
                <span class="inv-card-category" data-category={card.category}>
                  {categoryLabels[card.category] || card.category}
                </span>
                <h3 class="inv-card-title">{card.title}</h3>
                <div class="inv-card-meta">
                  <span class="inv-coming-soon">{card.date}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <script>
    /**
     * Category filter pills — toggle visibility of cards by data-category.
     * No framework, runs once on DOMContentLoaded. The featured card stays
     * visible regardless because its hierarchy is too high to hide.
     */
    (() => {
      const pills = document.querySelectorAll<HTMLButtonElement>('.inv-pill');
      const cards = document.querySelectorAll<HTMLElement>(
        '.inv-card, .inv-featured-card'
      );
      if (pills.length === 0 || cards.length === 0) return;

      pills.forEach((pill) => {
        pill.addEventListener('click', () => {
          const target = pill.getAttribute('data-category');
          pills.forEach((p) => {
            p.classList.remove('inv-pill--active');
            p.removeAttribute('aria-current');
          });
          pill.classList.add('inv-pill--active');
          pill.setAttribute('aria-current', 'true');

          cards.forEach((card) => {
            // Featured card never hides — it's the lede.
            if (card.classList.contains('inv-featured-card')) {
              card.removeAttribute('hidden');
              return;
            }
            if (!target) {
              card.removeAttribute('hidden');
              return;
            }
            const cat = card.getAttribute('data-category');
            if (cat === target) {
              card.removeAttribute('hidden');
            } else {
              card.setAttribute('hidden', '');
            }
          });
        });
      });
    })();
  </script>

</BaseLayout>

<style>
  /* ============================================
     PAGE HEADER
     ============================================ */
  .inv-header {
    padding: var(--space-16) 0 var(--space-10);
    background: var(--color-bg);
    text-align: center;
  }

  .inv-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-4);
  }

  .inv-headline {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .inv-subtitle {
    font-size: var(--text-lg);
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ============================================
     CATEGORY FILTER PILLS
     ============================================ */
  .inv-filters {
    padding: 0 0 var(--space-8);
    background: var(--color-bg);
  }

  .inv-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  .inv-pill {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--neutral-500);
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .inv-pill:hover {
    border-color: var(--color-gold-text, #8B4513);
    color: var(--color-gold-text, #8B4513);
  }

  .inv-pill--active {
    background: var(--color-gold);
    color: var(--color-white);
    border-color: var(--color-gold);
  }

  .inv-pill--active:hover {
    background: var(--color-gold-hover);
    border-color: var(--color-gold-hover);
    color: var(--color-white);
  }

  /* ============================================
     FEATURED INVESTIGATION — Top Story split card
     ============================================ */
  .inv-featured-section {
    padding: 0 0 var(--space-12);
    background: var(--color-bg);
  }

  .inv-featured-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold-text, #8B4513);
    margin: 0 0 var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-gold);
    display: inline-block;
  }

  .inv-featured-card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--transition-base),
                border-color var(--transition-base),
                transform var(--transition-base);
  }

  @media (min-width: 900px) {
    .inv-featured-card {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    }
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .inv-featured-card--placeholder {
    cursor: default;
    opacity: 0.92;
  }

  /* Media column */
  .inv-featured-media {
    position: relative;
    overflow: hidden;
    background: var(--neutral-100);
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 900px) {
    .inv-featured-media {
      aspect-ratio: auto;
      min-height: 380px;
    }
  }

  .inv-featured-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-image {
    transform: scale(1.03);
  }

  /* Body column */
  .inv-featured-body {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
    gap: var(--space-4);
  }

  @media (min-width: 900px) {
    .inv-featured-body {
      padding: var(--space-10);
      justify-content: center;
    }
  }

  .inv-featured-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
  }

  .inv-badge {
    display: inline-block;
    background: rgba(212, 148, 58, 0.12);
    color: var(--color-gold-hover, #C2842E);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  /* ============================================
     CATEGORY LABEL (small uppercase, no chip bg)
     Per-category color comes from cat--{slug} class
     ============================================ */
  .inv-featured-category,
  .inv-card-category {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #8B4513;
    margin: 0;
  }

  /* Per-category accent colors inside the Sunset palette */
  .cat--crash-data .inv-featured-category,
  .cat--crash-data .inv-card-category {
    color: #C23B22;
  }
  .cat--safety-analysis .inv-featured-category,
  .cat--safety-analysis .inv-card-category {
    color: #8B4513;
  }
  .cat--abuse-investigation .inv-featured-category,
  .cat--abuse-investigation .inv-card-category {
    color: #A83220;
  }
  .cat--negligence-report .inv-featured-category,
  .cat--negligence-report .inv-card-category {
    color: #D4943A;
  }
  .cat--infrastructure .inv-featured-category,
  .cat--infrastructure .inv-card-category {
    color: #4A5859;
  }
  .cat--policy .inv-featured-category,
  .cat--policy .inv-card-category {
    color: #C2842E;
  }
  .cat--firm-news .inv-featured-category,
  .cat--firm-news .inv-card-category {
    color: #6B6458;
  }
  .cat--community .inv-featured-category,
  .cat--community .inv-card-category {
    color: #8C8474;
  }

  /* Category accent stripe on the left edge of grid cards */
  .inv-card {
    border-left-width: 3px !important;
    border-left-style: solid !important;
    border-left-color: var(--neutral-200) !important;
  }
  .cat--crash-data { border-left-color: #C23B22 !important; }
  .cat--safety-analysis { border-left-color: #8B4513 !important; }
  .cat--abuse-investigation { border-left-color: #A83220 !important; }
  .cat--negligence-report { border-left-color: #D4943A !important; }
  .cat--infrastructure { border-left-color: #4A5859 !important; }
  .cat--policy { border-left-color: #C2842E !important; }
  .cat--firm-news { border-left-color: #6B6458 !important; }
  .cat--community { border-left-color: #8C8474 !important; }

  /* ============================================
     BOMB STAT — Cormorant Garamond, headline-first
     ============================================ */
  .inv-featured-bomb {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.4vw, 2.2rem);
    font-weight: 600;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .cat--crash-data .inv-featured-bomb,
  .cat--abuse-investigation .inv-featured-bomb {
    color: #1A1A1A;
  }

  .inv-card-bomb {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0 0 var(--space-2);
    letter-spacing: -0.005em;
  }

  /* ============================================
     METHODOLOGY PILL — Golden Hour, tiny
     ============================================ */
  .inv-method-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold-hover, #C2842E);
    background: rgba(212, 148, 58, 0.1);
    padding: 2px 8px;
    border-radius: 100px;
    border: 1px solid rgba(212, 148, 58, 0.25);
    line-height: 1.2;
  }

  .inv-method-pill__glyph {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-gold-text, #8B4513);
    transform: translateY(-1px);
  }

  .inv-coming-soon {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .inv-reading-time {
    font-size: var(--text-xs);
    color: var(--neutral-500);
    font-weight: 500;
  }

  .inv-featured-title {
    font-family: var(--font-body);
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    font-weight: 500;
    color: var(--color-black);
    line-height: 1.3;
    margin: 0;
    letter-spacing: -0.005em;
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-title {
    color: var(--color-gold-text, #8B4513);
  }

  .inv-featured-desc {
    font-size: var(--text-base);
    color: var(--color-slate);
    line-height: 1.65;
    margin: 0;
  }

  .inv-featured-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-slate);
    margin-top: var(--space-2);
  }

  .inv-featured-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200);
    flex-shrink: 0;
  }

  .inv-featured-byline-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .inv-featured-author {
    font-weight: 600;
    color: var(--color-black);
    font-size: var(--text-sm);
  }

  .inv-featured-byline-sub {
    font-size: var(--text-xs);
