---
/**
 * Investigations Hub — AZ Law Now
 * Newspaper front page layout for Brendan's data-led investigations
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
import { getCollection } from 'astro:content';
import { authors } from '../../data/authors';

let entries: any[] = [];
try {
  entries = await getCollection('investigations');
} catch {
  entries = [];
}

const published = entries
  .filter((e) => !e.data.draft)
  .sort((a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );

const featured = published.find((e) => e.data.featured) || published[0] || null;
const rest = published.filter((e) => e !== featured);

const categoryLabels: Record<string, string> = {
  'crash-data': 'Crash Data',
  'safety-analysis': 'Safety Analysis',
  'abuse-investigation': 'Abuse Investigation',
  'negligence-report': 'Negligence Report',
  'infrastructure': 'Infrastructure',
  'policy': 'Policy',
};

const categories = Object.keys(categoryLabels);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const brendan = authors['brendan-franks'];

/* Placeholder content for empty state */
const placeholderFeatured = {
  title: 'Arizona Schools Restrained 4,200+ Students Last Year',
  category: 'abuse-investigation',
  description: 'Public records reveal the scope of physical restraint incidents in Maricopa County schools. The data tells a story that most families never hear.',
};

const placeholderCards = [
  {
    title: 'Maricopa County Daycares With the Most DHS Violations',
    category: 'negligence-report',
    date: 'Coming Soon',
  },
  {
    title: "The SR-347 Problem: Maricopa's Most Dangerous Corridor",
    category: 'crash-data',
    date: 'Coming Soon',
  },
  {
    title: "88,094 Crashes: What Maricopa County's 2025 Data Tells Us",
    category: 'crash-data',
    date: 'Coming Soon',
  },
  {
    title: 'West Valley Elder Care Facilities Under Review',
    category: 'abuse-investigation',
    date: 'Coming Soon',
  },
];
---

<BaseLayout
  title="Investigations"
  description="Data-led investigations into Arizona public safety, crash data, and institutional accountability. We pull the records. We name the patterns."
  canonical="/investigations/"
>
  <!-- ============================================
       PAGE HEADER — Editorial masthead
       ============================================ -->
  <section class="inv-header">
    <div class="container container-narrow">
      <p class="inv-eyebrow">Investigations</p>
      <h1 class="inv-headline">Data-Led Reporting for Arizona Families</h1>
      <p class="inv-subtitle">
        We pull the public data. We name the patterns. We give families the information they need before they even know they need a lawyer.
      </p>
    </div>
  </section>

  <!-- ============================================
       CATEGORY FILTER PILLS
       ============================================ -->
  <section class="inv-filters">
    <div class="container">
      <div class="inv-pills">
        <button class="inv-pill inv-pill--active" aria-current="true">All</button>
        {categories.map((cat) => (
          <button class="inv-pill" data-category={cat}>
            {categoryLabels[cat]}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURED INVESTIGATION
       ============================================ -->
  <section class="inv-featured-section">
    <div class="container">
      {featured ? (
        <a href={`/investigations/${featured.id}/`} class="inv-featured-card">
          <div class="inv-featured-badge">
            <span class="inv-badge">Investigation</span>
            {featured.data.readingTime && (
              <span class="inv-reading-time">{featured.data.readingTime}</span>
            )}
          </div>
          <h2 class="inv-featured-title">{featured.data.title}</h2>
          <p class="inv-featured-desc">{featured.data.description}</p>
          <div class="inv-featured-byline">
            <img
              src={brendan.photo}
              alt={brendan.name}
              class="inv-featured-avatar"
              width="36"
              height="36"
              loading="lazy"
            />
            <span class="inv-featured-author">{brendan.name}</span>
            <span class="inv-featured-sep">/</span>
            <time datetime={featured.data.publishedAt}>
              {formatDate(featured.data.publishedAt)}
            </time>
          </div>
        </a>
      ) : (
        <div class="inv-featured-card inv-featured-card--placeholder">
          <div class="inv-featured-badge">
            <span class="inv-badge">Investigation</span>
            <span class="inv-coming-soon">Coming Soon</span>
          </div>
          <h2 class="inv-featured-title">{placeholderFeatured.title}</h2>
          <p class="inv-featured-desc">{placeholderFeatured.description}</p>
          <div class="inv-featured-byline">
            <img
              src={brendan.photo}
              alt={brendan.name}
              class="inv-featured-avatar"
              width="36"
              height="36"
              loading="lazy"
            />
            <span class="inv-featured-author">{brendan.name}</span>
            <span class="inv-featured-sep">/</span>
            <span class="inv-featured-date-placeholder">Editor-in-Chief</span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================
       INVESTIGATION GRID
       ============================================ -->
  <section class="inv-grid-section">
    <div class="container">
      <h2 class="inv-grid-heading">Recent Investigations</h2>

      {rest.length > 0 ? (
        <div class="inv-grid">
          {rest.map((entry) => (
            <a href={`/investigations/${entry.id}/`} class="inv-card">
              <span class="inv-card-badge">
                {categoryLabels[entry.data.category] || entry.data.category}
              </span>
              <h3 class="inv-card-title">{entry.data.title}</h3>
              <p class="inv-card-desc">{entry.data.description}</p>
              <div class="inv-card-meta">
                <time datetime={entry.data.publishedAt}>
                  {formatDate(entry.data.publishedAt)}
                </time>
                {entry.data.readingTime && (
                  <>
                    <span class="inv-card-sep">·</span>
                    <span>{entry.data.readingTime}</span>
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="inv-grid">
          {placeholderCards.map((card) => (
            <div class="inv-card inv-card--placeholder">
              <span class="inv-card-badge">
                {categoryLabels[card.category] || card.category}
              </span>
              <h3 class="inv-card-title">{card.title}</h3>
              <div class="inv-card-meta">
                <span class="inv-coming-soon">{card.date}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ============================================
       DARK CTA BAND
       ============================================ -->
  <section class="inv-cta section-dark section">
    <div class="container text-center">
      <h2 class="inv-cta-heading">Know Something We Should Investigate?</h2>
      <p class="inv-cta-text">
        If you have a tip, a public record, or a pattern we should look into, reach out. We take data seriously.
      </p>
      <div class="inv-cta-actions">
        <a href="/contact/" class="btn btn-primary btn-lg">
          Send a Tip →
        </a>
        <a href={`tel:${siteConfig.phoneE164}`} class="inv-cta-phone">
          {siteConfig.phoneFormatted}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================
     PAGE HEADER
     ============================================ */
  .inv-header {
    padding: var(--space-16) 0 var(--space-10);
    background: var(--color-bg);
    text-align: center;
  }

  .inv-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }

  .inv-headline {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .inv-subtitle {
    font-size: var(--text-lg);
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ============================================
     CATEGORY FILTER PILLS
     ============================================ */
  .inv-filters {
    padding: 0 0 var(--space-8);
    background: var(--color-bg);
  }

  .inv-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  .inv-pill {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--neutral-500);
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .inv-pill:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .inv-pill--active {
    background: var(--color-gold);
    color: var(--color-white);
    border-color: var(--color-gold);
  }

  .inv-pill--active:hover {
    background: var(--color-gold-hover);
    border-color: var(--color-gold-hover);
    color: var(--color-white);
  }

  /* ============================================
     FEATURED INVESTIGATION
     ============================================ */
  .inv-featured-section {
    padding: 0 0 var(--space-12);
    background: var(--color-bg);
  }

  .inv-featured-card {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-10) var(--space-8);
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .inv-featured-card--placeholder {
    cursor: default;
    opacity: 0.85;
  }

  .inv-featured-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .inv-badge {
    display: inline-block;
    background: rgba(212, 148, 58, 0.15);
    color: var(--color-gold-hover);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .inv-coming-soon {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .inv-reading-time {
    font-size: var(--text-xs);
    color: var(--neutral-500);
  }

  .inv-featured-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .inv-featured-card:not(.inv-featured-card--placeholder):hover .inv-featured-title {
    color: var(--color-gold);
  }

  .inv-featured-desc {
    font-size: var(--text-base);
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 700px;
    margin-bottom: var(--space-6);
  }

  .inv-featured-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--neutral-500);
  }

  .inv-featured-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200);
  }

  .inv-featured-author {
    font-weight: 600;
    color: var(--neutral-700);
  }

  .inv-featured-sep {
    color: var(--neutral-300);
  }

  .inv-featured-date-placeholder {
    color: var(--neutral-400);
  }

  /* ============================================
     INVESTIGATION GRID
     ============================================ */
  .inv-grid-section {
    padding: 0 0 var(--space-16);
    background: var(--color-bg);
  }

  .inv-grid-heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--neutral-200);
  }

  .inv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .inv-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  a.inv-card:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .inv-card--placeholder {
    cursor: default;
    opacity: 0.7;
  }

  .inv-card--placeholder:hover {
    transform: none;
    box-shadow: none;
  }

  .inv-card-badge {
    display: inline-block;
    align-self: flex-start;
    background: rgba(212, 148, 58, 0.1);
    color: var(--color-gold-hover);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem var(--space-2);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .inv-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.25;
    margin-bottom: var(--space-3);
    flex: 1;
  }

  a.inv-card:hover .inv-card-title {
    color: var(--color-gold);
  }

  .inv-card-desc {
    font-size: var(--text-sm);
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .inv-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--neutral-500);
    margin-top: auto;
  }

  .inv-card-sep {
    color: var(--neutral-300);
  }

  /* ============================================
     DARK CTA BAND
     ============================================ */
  .inv-cta {
    background: linear-gradient(135deg, var(--color-black) 0%, rgba(212, 148, 58, 0.12) 100%);
  }

  .inv-cta-heading {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 700;
    color: var(--neutral-50);
    margin-bottom: var(--space-4);
  }

  .inv-cta-text {
    color: var(--neutral-400);
    font-size: var(--text-lg);
    max-width: 560px;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }

  .inv-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .inv-cta-phone {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .inv-cta-phone:hover {
    color: var(--color-gold-hover);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .inv-header {
      padding: var(--space-10) 0 var(--space-8);
    }

    .inv-featured-card {
      padding: var(--space-6);
    }

    .inv-grid {
      grid-template-columns: 1fr;
    }

    .inv-cta-actions {
      flex-direction: column;
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .inv-pills {
      gap: var(--space-1);
    }

    .inv-pill {
      font-size: 0.6875rem;
      padding: var(--space-1) var(--space-3);
    }
  }
</style>
