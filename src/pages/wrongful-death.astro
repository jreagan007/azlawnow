---
import { getEntry, render } from 'astro:content';
import PracticeAreaLayout from '../layouts/PracticeAreaLayout.astro';

const entry = await getEntry('practice-areas', 'wrongful-death');
if (!entry) return Astro.redirect('/404');
const { Content } = await render(entry);
---
<PracticeAreaLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical="/wrongful-death/"
  practiceArea={entry.data.practiceArea}
  heroTitle={entry.data.heroTitle}
  heroSubtitle={entry.data.heroSubtitle}
  heroImage={entry.data.heroImage}
  faqs={entry.data.faqs}
  cluster={entry.data.cluster}
  clusterLabel={entry.data.clusterLabel}
>
  <div class="container content-section">
    <Content />
  </div>
</PracticeAreaLayout>
