---
/**
 * Case Results — AZ Law Now
 * Notable verdicts and settlements
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site-config';
import { getResultsPageSchema } from '../../utils/schema';

// Real case results from live azlawnow.com/our-results/
// Verified Apr 9, 2026. Total: 26 cases, $3.07M+ recovered.
const results = [
  { amount: '$800,000', insurer: 'Hartford', type: 'School Bus Negligence', desc: 'A five-year-old boy with special needs left on a school bus for six hours. Settlement secured after investigation documented the failures.' },
  { amount: '$250,000', insurer: 'Nationwide', type: 'T-Bone Collision', desc: 'Severe T-bone collision. Secured maximum UIM limits for a fractured tibia.' },
  { amount: '$225,000', insurer: 'Allstate', type: 'Highway Rear-End', desc: 'Rear-ended at highway speeds. Client sustained a torn rotator cuff requiring surgery.' },
  { amount: '$200,000', insurer: 'Travelers', type: 'Underinsured Motorist', desc: 'UIM claim settled for limits due to lumbar disc herniation.' },
  { amount: '$175,000', insurer: 'State Farm', type: 'Intersection Collision', desc: "Intersection dispute. Proved liability for client's arthroscopic knee surgery." },
  { amount: '$150,000', insurer: 'Liberty Mutual', type: 'Slip and Fall', desc: 'Slip and fall on ice at a private residence resulting in a fractured elbow.' },
  { amount: '$125,000', insurer: 'Mercury Insurance', type: 'Stop Sign Crash', desc: 'Driver ran a stop sign striking our client. Covered non-surgical orthopedic care.' },
  { amount: '$115,000', insurer: 'Farmers', type: 'Side-Impact Collision', desc: 'Side-impact collision causing back pain. Client underwent epidural steroid injections.' },
  { amount: '$100,000', insurer: 'Progressive', type: 'Pedestrian', desc: 'Pedestrian clipped by a side-mirror. Settlement for shoulder contusion and shock.' },
  { amount: '$100,000', insurer: 'The Hartford', type: 'Bicycle Dooring', desc: 'Dooring accident involving a bicyclist requiring dental restoration.' },
  { amount: '$95,000', insurer: 'USAA', type: 'Head-On Collision', desc: 'Head-on collision in a residential zone resulting in a hairline wrist fracture.' },
  { amount: '$85,000', insurer: 'Allstate', type: 'High-Impact Rear-End', desc: 'High-impact rear-end collision. MRI revealed disc protrusions requiring care.' },
  { amount: '$80,000', insurer: 'Geico', type: 'Motorcycle Crash', desc: 'Motorcyclist cut off in traffic. Settlement covered road rash and knee therapy.' },
  { amount: '$75,000', insurer: 'State Farm', type: 'Dog Bite', desc: 'Dog bite incident resulting in puncture wounds and scarring on the calf.' },
  { amount: '$65,000', insurer: 'Travelers', type: 'Distracted Driver', desc: 'Rear-ended by a distracted driver. Client required trigger point injections.' },
  { amount: '$60,000', insurer: 'Nationwide', type: 'Slip and Fall', desc: 'Slip and fall on wet tile in a grocery store causing a severe ankle sprain.' },
  { amount: '$50,000', insurer: 'AAA', type: 'T-Bone Collision', desc: 'T-bone collision causing a concussion and cervical strain.' },
  { amount: '$50,000', insurer: 'Liberty Mutual', type: 'Cyclist Struck', desc: 'Cyclist struck by a turning vehicle. Settled for full policy limits.' },
  { amount: '$50,000', insurer: 'Esurance', type: 'Uninsured Motorist', desc: 'UM claim settled for limits after at-fault driver fled.' },
  { amount: '$42,000', insurer: 'Farmers', type: 'Chain-Reaction', desc: 'Rear-end accident pushing client into the car ahead. Resolved without litigation.' },
  { amount: '$35,000', insurer: 'Mercury Insurance', type: 'Intersection Collision', desc: 'Intersection collision. Settlement covered ER visit and physical therapy.' },
  { amount: '$30,000', insurer: 'Progressive', type: 'Highway Side-Swipe', desc: 'Side-swipe on the highway resulting in soft tissue shoulder injuries.' },
  { amount: '$28,000', insurer: 'Allstate', type: 'Parking Lot', desc: 'Low-speed parking lot accident causing neck strain and headaches.' },
  { amount: '$25,000', insurer: 'USAA', type: 'Failure to Yield', desc: 'Passenger in a vehicle struck by a driver failing to yield. Policy limits paid.' },
  { amount: '$25,000', insurer: 'State Farm', type: 'Rear-End Collision', desc: 'Our client was rear-ended. Secured full bodily injury policy limits.' },
  { amount: '$15,000', insurer: 'Geico', type: 'Red Light Rear-End', desc: 'Rear-end collision at a red light requiring chiropractic care.' },
];

const resultsSchema = getResultsPageSchema(results);
---

<BaseLayout
  title="Case Results"
  description="AZ Law Now case results. Over $3.07 million recovered for injured Arizona clients. Car crashes, truck crashes, wrongful death, and more."
  canonical="/case-results/"
  schema={resultsSchema}
>
  <!-- Hero -->
  <section class="hero hero-centered">
    <div class="container container-narrow">
      <p class="uppercase text-gold mb-4" style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.1em;">Case Results</p>
      <h1>Results That Speak for Themselves</h1>
      <p class="hero-subtitle" style="margin-left: auto; margin-right: auto;">
        Over $3.07 million recovered for injured clients across Arizona. Every dollar represents a real person who got the compensation they deserved.
      </p>
    </div>
  </section>

  <!-- Results List -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="results-list">
        {results.map((result) => (
          <div class="result-card card">
            <div class="result-card__amount">
              <span class="stat-number" style="font-size: var(--text-4xl);">{result.amount}</span>
              <span class="result-card__insurer">vs. {result.insurer}</span>
            </div>
            <div class="result-card__info">
              <h2 class="result-card__type">{result.type}</h2>
              <p class="result-card__desc">{result.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Disclaimer -->
      <div class="callout callout-warning" style="margin-top: var(--space-12);">
        <p class="callout-title">Important Disclaimer</p>
        <p class="callout-text">
          Prior results don't guarantee a similar outcome. Every case is different. The results listed above depended on the specific facts and circumstances of each case. Your case may result in a higher or lower recovery.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .result-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .result-card__amount {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .result-card__insurer {
    font-size: var(--text-xs);
    color: var(--neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .result-card__type {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .result-card__desc {
    color: var(--color-slate);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .result-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .result-card__amount {
      padding-bottom: var(--space-2);
      border-bottom: 1px solid var(--neutral-200);
    }
  }
</style>
