---
/**
 * Practice Area Layout — AZ Law Now
 * EDITORIAL section page — warm cream hero, NOT dark overlay like AEE Law
 * Vermillion accent bar, serif headline, editorial breadcrumbs
 * Southwestern warmth, not NYC authority
 */

import BaseLayout from './BaseLayout.astro';
import AutoLinker from '../components/AutoLinker.astro';
import { siteConfig } from '../data/site-config';
import {
  generateServiceSchema,
  generateFAQSchema,
  generateBreadcrumbSchema,
} from '../utils/schema';

interface Props {
  title: string;
  description: string;
  canonical: string;
  practiceArea: string;
  heroTitle: string;
  heroSubtitle: string;
  heroImage?: string;
  heroImageAlt?: string;
  faqs?: Array<{ question: string; answer: string }>;
  schema?: object;
  showMidCta?: boolean;
  /** Cluster slug for breadcrumb nesting (e.g. 'vehicle-crashes') */
  cluster?: string;
  /** Cluster display label (e.g. 'Vehicle Crashes') */
  clusterLabel?: string;
}

const {
  title,
  description,
  canonical,
  practiceArea,
  heroTitle,
  heroSubtitle,
  heroImage = '/images/heroes/practice-area-default.webp',
  heroImageAlt = `${practiceArea} attorney in the West Valley`,
  faqs = [],
  schema: extraSchema,
  showMidCta = true,
  cluster,
  clusterLabel,
} = Astro.props;

// Build breadcrumbs — optionally nest under cluster hub
const breadcrumbs = [
  { name: 'Home', url: '/' },
  ...(cluster && clusterLabel
    ? [{ name: clusterLabel, url: `/${cluster}/` }]
    : []),
  { name: practiceArea, url: canonical },
];

// Assemble schemas
const serviceSchema = generateServiceSchema(practiceArea, heroImage, canonical);
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const faqSchema = faqs.length > 0 ? generateFAQSchema(faqs) : null;

const schemas = [
  serviceSchema,
  breadcrumbSchema,
  ...(faqSchema ? [faqSchema] : []),
  ...(extraSchema ? [extraSchema] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={heroImage}
  schema={schemas}
>
  <!-- ============================================
       HERO — Editorial section header (warm cream)
       NOT a dark overlay like AEE Law
       ============================================ -->
  <section class="pa-hero" aria-label={`${practiceArea} hero`}>
    <div class="pa-hero__accent" aria-hidden="true"></div>
    <div class="pa-hero__content container">
      <!-- Breadcrumbs — editorial style -->
      <nav class="pa-breadcrumbs" aria-label="Breadcrumb">
        <ol>
          {breadcrumbs.map((crumb, i) => (
            <li>
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.url}>{crumb.name}</a>
              ) : (
                <span aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="pa-hero__grid">
        <div class="pa-hero__text">
          <h1 class="pa-hero__title" data-speakable="headline">{heroTitle}</h1>
          <p class="pa-hero__subtitle" data-speakable="summary">{heroSubtitle}</p>

          <!-- CTA -->
          <div class="pa-hero__cta">
            <a href="/free-case-review/" class="btn btn-primary btn-lg">
              {siteConfig.messaging.l8Primary} &rarr;
            </a>
            <a href={`tel:${siteConfig.phoneE164}`} class="pa-hero__phone-link">
              Or call {siteConfig.phoneFormatted}
            </a>
          </div>
        </div>

        <!-- Trust sidebar — three voices -->
        <aside class="pa-trust-sidebar">
          <div class="pa-trust-stat">
            <span class="pa-trust-stat__value">On Record</span>
            <span class="pa-trust-stat__label">The data's pulled. The facts are clear.</span>
          </div>
          <div class="pa-trust-stat">
            <span class="pa-trust-stat__value">Answered</span>
            <span class="pa-trust-stat__label">The confusion stops here.</span>
          </div>
          <div class="pa-trust-stat">
            <span class="pa-trust-stat__value">Guided</span>
            <span class="pa-trust-stat__label">You don't figure this out alone.</span>
          </div>
        </aside>
      </div>
    </div>
    {heroImage && (
      <div class="pa-hero__image-strip">
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="pa-hero__bg"
          loading="eager"
          decoding="async"
          width="1600"
          height="280"
        />
      </div>
    )}
  </section>

  <!-- ============================================
       CONTENT AREA
       ============================================ -->
  <section class="pa-content section">
    <div class="container container-narrow">
      <AutoLinker currentPath={canonical} maxLinks={10}>
        <slot />
      </AutoLinker>
    </div>
  </section>

  <!-- ============================================
       FAQ SECTION
       ============================================ -->
  {faqs.length > 0 && (
    <section class="pa-faq section" aria-label="Frequently asked questions">
      <div class="container container-narrow">
        <h2 class="pa-faq__heading">Frequently Asked Questions</h2>
        <div class="pa-faq__list">
          {faqs.map((faq) => (
            <details class="pa-faq__item">
              <summary class="pa-faq__question">
                <span>{faq.question}</span>
                <svg class="pa-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>
              <div class="pa-faq__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================
       RELATED RESOURCES (placeholder)
       ============================================ -->
  <!-- TODO: Related resources component (practice area cross-links, blog posts) -->

</BaseLayout>

<style>
  /* ============================================
     HERO — Editorial warm cream header
     ============================================ */
  .pa-hero {
    background: var(--color-bg, #FAF5ED);
    position: relative;
    overflow: hidden;
  }

  .pa-hero__accent {
    height: 4px;
    background: linear-gradient(90deg, #C23B22 0%, #D4943A 100%);
  }

  .pa-hero__content {
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }

  .pa-hero__grid {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: var(--space-10);
    align-items: start;
  }

  .pa-hero__title {
    color: var(--color-black, #1A1A1A);
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .pa-hero__subtitle {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-lg);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 580px;
  }

  /* Breadcrumbs — editorial warm */
  .pa-breadcrumbs {
    margin-bottom: var(--space-6);
  }

  .pa-breadcrumbs ol {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--text-sm);
  }

  .pa-breadcrumbs li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--neutral-300, #D4CFC6);
  }

  .pa-breadcrumbs a {
    color: var(--color-slate, #4A5859);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pa-breadcrumbs a:hover { color: var(--color-gold, #D4943A); }

  .pa-breadcrumbs span[aria-current] {
    color: var(--color-gold, #D4943A);
    font-weight: 600;
  }

  /* Trust sidebar */
  .pa-trust-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-lg, 8px);
  }

  .pa-trust-stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    text-align: center;
  }

  .pa-trust-stat__value {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-gold, #D4943A);
  }

  .pa-trust-stat__label {
    font-size: var(--text-xs);
    color: var(--color-slate, #4A5859);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Hero CTA */
  .pa-hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .pa-hero__phone-link {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pa-hero__phone-link:hover { color: var(--color-gold, #D4943A); }

  /* Hero image strip — optional, below text */
  .pa-hero__image-strip {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .pa-hero__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ============================================
     CONTENT AREA — Article-style prose
     ============================================ */
  .pa-content {
    background: var(--color-bg);
  }

  .pa-content :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    font-weight: 700;
    color: #1A1A1A;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .pa-content :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #1A1A1A;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .pa-content :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: #4A5859;
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  .pa-content :global(strong) {
    color: #1A1A1A;
    font-weight: 700;
  }

  .pa-content :global(a) {
    color: #D4943A;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .pa-content :global(a:hover) {
    color: var(--color-gold-hover);
    text-decoration: underline;
  }

  .pa-content :global(ul),
  .pa-content :global(ol) {
    color: #4A5859;
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .pa-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.7;
  }

  .pa-content :global(blockquote) {
    border-left: 4px solid var(--color-gold);
    background: var(--neutral-100);
    padding: var(--space-6);
    margin: var(--space-8) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: #4A5859;
  }

  /* ============================================
     MID-CONTENT CTA
     ============================================ */
  .pa-mid-cta {
    padding: var(--space-12) 0;
    background: var(--color-bg);
  }

  .pa-mid-cta__box {
    background: var(--color-white);
    border-left: 4px solid var(--color-gold);
    padding: var(--space-8) var(--space-8);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    box-shadow: var(--shadow-md);
  }

  .pa-mid-cta__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--space-2);
  }

  .pa-mid-cta__text {
    color: var(--color-slate);
    font-size: var(--text-base);
    margin-bottom: var(--space-6);
    max-width: 480px;
    line-height: 1.6;
  }

  .pa-mid-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ============================================
     FAQ SECTION
     ============================================ */
  .pa-faq {
    background: #F5EDE0;
  }

  .pa-faq__heading {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: var(--space-8);
  }

  .pa-faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .pa-faq__item {
    border-bottom: 1px solid var(--neutral-300);
  }

  .pa-faq__item:first-child {
    border-top: 1px solid var(--neutral-300);
  }

  .pa-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 600;
    color: #1A1A1A;
    transition: color var(--transition-base);
  }

  .pa-faq__question::-webkit-details-marker {
    display: none;
  }

  .pa-faq__question::marker {
    content: '';
  }

  .pa-faq__question:hover {
    color: #D4943A;
  }

  .pa-faq__chevron {
    color: #D4943A;
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .pa-faq__item[open] .pa-faq__chevron {
    transform: rotate(180deg);
  }

  .pa-faq__answer {
    padding: 0 0 var(--space-6);
  }

  .pa-faq__answer p {
    color: #4A5859;
    font-size: var(--text-base);
    line-height: 1.7;
  }


  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .pa-hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .pa-trust-sidebar {
      flex-direction: row;
      justify-content: space-around;
    }

    .pa-hero__image-strip {
      height: 180px;
    }

    .pa-hero__cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .pa-mid-cta__box {
      padding: var(--space-6) var(--space-5);
    }

  }

  @media (max-width: 480px) {
    .pa-trust-sidebar {
      flex-direction: column;
    }
  }
</style>
