---
/**
 * Practice Area Layout — AZ Law Now
 * EDITORIAL section page — warm cream hero, NOT dark overlay like AEE Law
 * Vermillion accent bar, serif headline, editorial breadcrumbs
 * Southwestern warmth, not NYC authority
 */

import BaseLayout from './BaseLayout.astro';
import AutoLinker from '../components/AutoLinker.astro';
import ArticleToC from '../components/ArticleToC.astro';
import ArticleSources from '../components/ArticleSources.astro';
import ArticleFAQ from '../components/ArticleFAQ.astro';
import { siteConfig } from '../data/site-config';
import {
  generateServiceSchema,
  generateFAQSchema,
  generateBreadcrumbSchema,
} from '../utils/schema';
import type { MarkdownHeading } from 'astro';

interface Source {
  label: string;
  url: string;
  publisher?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  practiceArea: string;
  heroTitle: string;
  heroSubtitle: string;
  heroImage?: string;
  heroImageAlt?: string;
  faqs?: Array<{ question: string; answer: string }>;
  schema?: object;
  showMidCta?: boolean;
  /** Cluster slug for breadcrumb nesting (e.g. 'vehicle-crashes') */
  cluster?: string;
  /** Cluster display label (e.g. 'Vehicle Crashes') */
  clusterLabel?: string;
  /** Editorial byline — shown under H1. Defaults to Brandon (the "Answered" voice). */
  editor?: { name: string; role: string; href?: string };
  /** ISO date the page was last substantively updated. Drives dateline. */
  updated?: string;
  /** Legacy sources prop — prefer `dataSources` frontmatter + ArticleSources component. */
  sources?: Source[];
  /** Optional TL;DR / key takeaway rendered as a callout above the body. */
  keyTakeaway?: string;
  /** Numbered references list rendered by ArticleSources component. "Publisher. Title. https://url" format. */
  dataSources?: string[];
  /** Astro headings array from `render(entry)` — drives the "On this page" ToC in the right rail. */
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  canonical,
  practiceArea,
  heroTitle,
  heroSubtitle,
  heroImage = '/images/heroes/practice-area-default.webp',
  heroImageAlt = `${practiceArea} attorney in the West Valley`,
  faqs = [],
  schema: extraSchema,
  showMidCta = true,
  cluster,
  clusterLabel,
  editor = { name: 'Brandon Millam, J.D.', role: 'Answered · Legal Editor', href: '/about/#brandon-millam' },
  updated,
  sources = [],
  keyTakeaway,
  dataSources = [],
  headings = [],
} = Astro.props;

// Format the dateline. Falls back to build time if not specified.
const updatedDate = updated ? new Date(updated) : new Date();
const formattedDate = updatedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = updatedDate.toISOString().split('T')[0];

// Build breadcrumbs — optionally nest under cluster hub
const breadcrumbs = [
  { name: 'Home', url: '/' },
  ...(cluster && clusterLabel
    ? [{ name: clusterLabel, url: `/${cluster}/` }]
    : []),
  { name: practiceArea, url: canonical },
];

// Assemble schemas
const serviceSchema = generateServiceSchema(practiceArea, heroImage, canonical);
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);
const faqSchema = faqs.length > 0 ? generateFAQSchema(faqs) : null;

const schemas = [
  serviceSchema,
  breadcrumbSchema,
  ...(faqSchema ? [faqSchema] : []),
  ...(extraSchema ? [extraSchema] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={heroImage}
  schema={schemas}
>
  <!-- ============================================
       HERO — Editorial section header (warm cream)
       NOT a dark overlay like AEE Law
       ============================================ -->
  <section class="pa-hero" aria-label={`${practiceArea} hero`}>
    <div class="pa-hero__accent" aria-hidden="true"></div>
    <div class="pa-hero__content container">
      <!-- Breadcrumbs — editorial style -->
      <nav class="pa-breadcrumbs" aria-label="Breadcrumb">
        <ol>
          {breadcrumbs.map((crumb, i) => (
            <li>
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.url}>{crumb.name}</a>
              ) : (
                <span aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="pa-hero__text">
        <h1 class="pa-hero__title" data-speakable="headline">{heroTitle}</h1>

        <!-- Editorial byline + dateline -->
        <p class="pa-byline">
          Edited by{' '}
          {editor.href ? (
            <a href={editor.href} class="pa-byline__author">{editor.name}</a>
          ) : (
            <span class="pa-byline__author">{editor.name}</span>
          )}
          <span class="pa-byline__sep" aria-hidden="true">·</span>
          <span class="pa-byline__role">{editor.role}</span>
          <span class="pa-byline__sep" aria-hidden="true">·</span>
          <span class="pa-byline__updated">
            Updated <time datetime={isoDate}>{formattedDate}</time>
          </span>
        </p>

        <p class="pa-hero__subtitle" data-speakable="summary">{heroSubtitle}</p>

        <!-- CTA -->
        <div class="pa-hero__cta">
          <a href="/free-case-review/" class="btn btn-primary btn-lg">
            {siteConfig.messaging.l8Primary} &rarr;
          </a>
          <a href={`tel:${siteConfig.phoneE164}`} class="pa-hero__phone-link">
            Or call {siteConfig.phoneFormatted}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURED IMAGE (editorial 16:9 like ArticleLayout)
       ============================================ -->
  {heroImage && (
    <div class="pa-featured-image">
      <div class="container container-article">
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="pa-featured-image__img"
          width="1200"
          height="675"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  )}

  <!-- ============================================
       BODY + RIGHT RAIL (two-column on lg+, matches ArticleLayout)
       ============================================ -->
  <div class="pa-body section">
    <div class="container container-article">
      <div class="pa-grid">
        <!-- ── MAIN COLUMN ── -->
        <div class="pa-main">
          {keyTakeaway && (
            <aside class="pa-takeaway" aria-label="Key takeaway" data-speakable="takeaway">
              <span class="pa-takeaway__label">Key takeaway</span>
              <p class="pa-takeaway__text">{keyTakeaway}</p>
            </aside>
          )}

          <div class="pa-content" data-speakable="summary">
            <AutoLinker currentPath={canonical} maxLinks={20}>
              <slot />
            </AutoLinker>
          </div>

          <ArticleFAQ faqs={faqs} />

          <ArticleSources dataSources={dataSources} />

          {/* Legacy sources prop fallback — only renders if dataSources is empty and sources[] was passed */}
          {dataSources.length === 0 && sources.length > 0 && (
            <section class="pa-sources-legacy" aria-labelledby="pa-sources-legacy-heading">
              <h2 id="pa-sources-legacy-heading" class="pa-sources-legacy__heading">Sources &amp; references</h2>
              <ol class="pa-sources-legacy__list">
                {sources.map((source) => (
                  <li class="pa-sources-legacy__item">
                    <a href={source.url} class="pa-sources-legacy__link" target="_blank" rel="nofollow noopener">
                      {source.label}
                    </a>
                    {source.publisher && (
                      <span class="pa-sources-legacy__publisher"> — {source.publisher}</span>
                    )}
                  </li>
                ))}
              </ol>
            </section>
          )}
        </div>

        <!-- ── RIGHT RAIL (sticky on lg+) ── -->
        <aside class="pa-rail" aria-label="Page tools and intake">
          <div class="pa-rail__sticky">
            <ArticleToC headings={headings} />

            <!-- Compact intake CTA — voice-safe, matches editorial article rail -->
            <div class="rail-cta">
              <span class="rail-cta__eyebrow">Answers start here.</span>
              <p class="rail-cta__copy">Tell us what happened. The editors will tell you what's next.</p>
              <a href="/free-case-review/" class="rail-cta__button">
                Get answers on your case
                <span aria-hidden="true">→</span>
              </a>
              <a
                href={`tel:${siteConfig.phoneE164}`}
                class="rail-cta__phone"
                aria-label={`Call ${siteConfig.phoneFormatted}`}
              >
                <svg class="rail-cta__phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <span>{siteConfig.phoneFormatted}</span>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- FAQ now rendered inside .pa-main via <ArticleFAQ> — schema.org/FAQPage microdata, data-speakable="answer", gold open-state border. -->

  <!-- ============================================
       RELATED RESOURCES (placeholder)
       ============================================ -->
  <!-- TODO: Related resources component (practice area cross-links, blog posts) -->

</BaseLayout>

<style>
  /* ============================================
     HERO — Editorial warm cream header
     ============================================ */
  .pa-hero {
    background: var(--color-bg, #FAF5ED);
    position: relative;
    overflow: hidden;
  }

  .pa-hero__accent {
    height: 4px;
    background: linear-gradient(90deg, #C23B22 0%, #D4943A 100%);
  }

  .pa-hero__content {
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
  }

  .pa-hero__text {
    max-width: 780px;
  }

  .pa-hero__title {
    color: var(--color-black, #1A1A1A);
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-3);
  }

  /* Editorial byline under H1 — ProPublica / Marshall Project pattern */
  .pa-byline {
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.5;
    margin: 0 0 var(--space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5ch;
  }

  .pa-byline__author {
    color: var(--color-black, #1A1A1A);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--color-gold-text, #8B4513);
    transition: color 0.15s ease;
  }

  .pa-byline__author:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .pa-byline__sep {
    color: var(--neutral-400, #B0A696);
  }

  .pa-byline__role {
    color: var(--color-slate, #4A5859);
    font-style: italic;
  }

  .pa-byline__updated {
    color: var(--color-slate, #4A5859);
  }

  .pa-byline__updated time {
    color: var(--color-black, #1A1A1A);
    font-weight: 500;
  }

  .pa-hero__subtitle {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-lg);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    max-width: 580px;
  }

  /* ============================================
     FEATURED IMAGE (16:9, matches ArticleLayout)
     ============================================ */
  .pa-featured-image {
    padding: var(--space-6) 0 0;
    background: var(--color-bg);
  }

  .pa-featured-image__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  /* ============================================
     TWO-COLUMN BODY GRID (main + sticky right rail)
     Mirrors ArticleLayout .article-grid so resource + practice-area
     pages share a single reading experience.
     ============================================ */
  .container-article {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .pa-body {
    background: var(--color-bg);
  }

  .pa-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 1024px) {
    .pa-grid {
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: var(--space-12);
      /* Default grid stretch keeps the rail aside tall enough for
         position: sticky on the inner rail to engage. */
    }
  }

  .pa-main {
    min-width: 0;
    max-width: 720px;
  }

  @media (min-width: 1024px) {
    .pa-main {
      max-width: none;
    }
  }

  /* ============================================
     KEY TAKEAWAY CALLOUT
     ============================================ */
  .pa-takeaway {
    background: #F5EDE0;
    border-left: 4px solid var(--color-gold, #D4943A);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-5) var(--space-6);
    margin: 0 0 var(--space-8);
  }

  .pa-takeaway__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-2);
  }

  .pa-takeaway__text {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #1A1A1A;
    margin: 0;
    font-weight: 500;
  }

  /* ============================================
     RIGHT RAIL (sticky on lg+)
     ============================================ */
  .pa-rail {
    min-width: 0;
  }

  .pa-rail__sticky {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .pa-rail__sticky {
      position: sticky;
      top: var(--space-6);
    }
  }

  /* Compact intake CTA in the rail — voice-safe, matches article rail */
  .rail-cta {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-top: 3px solid var(--color-gold, #D4943A);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-5) var(--space-4);
    box-shadow: 0 1px 3px rgba(26, 26, 26, 0.04);
  }

  .rail-cta__eyebrow {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: var(--space-2);
    line-height: 1.2;
  }

  .rail-cta__copy {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #4A5859;
    margin: 0 0 var(--space-4);
  }

  .rail-cta__button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    background: var(--color-gold, #D4943A);
    color: #1A1A1A;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    min-height: 44px;
    transition: background var(--transition-base);
  }

  .rail-cta__button:hover,
  .rail-cta__button:focus-visible {
    background: var(--color-gold-hover, #B87A28);
    color: #FFFFFF;
  }

  .rail-cta__button:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: 2px;
  }

  .rail-cta__phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    padding: 0.5rem;
    min-height: 44px;
    color: #1A1A1A;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-base);
  }

  .rail-cta__phone:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .rail-cta__phone:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: 2px;
  }

  .rail-cta__phone-icon {
    width: 16px;
    height: 16px;
    color: var(--color-gold-text, #8B4513);
    flex-shrink: 0;
  }

  /* ============================================
     LEGACY SOURCES — only renders if dataSources is empty
     ============================================ */
  .pa-sources-legacy {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--neutral-200, #E8DFD0);
  }

  .pa-sources-legacy__heading {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-black, #1A1A1A);
    margin: 0 0 var(--space-4);
    letter-spacing: -0.01em;
  }

  .pa-sources-legacy__list {
    list-style: decimal;
    padding-left: var(--space-5);
    margin: 0;
  }

  .pa-sources-legacy__item {
    font-size: var(--text-sm);
    color: var(--color-slate, #4A5859);
    line-height: 1.55;
    margin-bottom: var(--space-3);
  }

  .pa-sources-legacy__link {
    color: var(--color-gold-text, #8B4513);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--color-gold-text, #8B4513);
  }

  .pa-sources-legacy__link:hover {
    color: var(--color-crimson, #C23B22);
    border-bottom-color: var(--color-crimson, #C23B22);
  }

  .pa-sources-legacy__publisher {
    color: var(--color-slate, #4A5859);
  }

  /* Breadcrumbs — editorial warm */
  .pa-breadcrumbs {
    margin-bottom: var(--space-6);
  }

  .pa-breadcrumbs ol {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--text-sm);
  }

  .pa-breadcrumbs li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--neutral-300, #D4CFC6);
  }

  .pa-breadcrumbs a {
    color: var(--color-slate, #4A5859);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pa-breadcrumbs a:hover { color: var(--color-gold-text, #8B4513); }

  .pa-breadcrumbs span[aria-current] {
    color: var(--color-gold-text, #8B4513);
    font-weight: 600;
  }

  /* Hero CTA */
  .pa-hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .pa-hero__phone-link {
    color: var(--color-slate, #4A5859);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pa-hero__phone-link:hover { color: var(--color-gold-text, #8B4513); }

  /* ============================================
     CONTENT AREA — Article-style prose
     ============================================ */
  .pa-content :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    font-weight: 700;
    color: #1A1A1A;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .pa-content :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #1A1A1A;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .pa-content :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: #4A5859;
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  .pa-content :global(strong) {
    color: #1A1A1A;
    font-weight: 700;
  }

  .pa-content :global(a) {
    color: var(--color-gold-text, #8B4513);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .pa-content :global(a:hover) {
    color: var(--color-gold-hover);
    text-decoration: underline;
  }

  .pa-content :global(ul),
  .pa-content :global(ol) {
    color: #4A5859;
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .pa-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.7;
  }

  .pa-content :global(blockquote) {
    border-left: 4px solid var(--color-gold);
    background: var(--neutral-100);
    padding: var(--space-6);
    margin: var(--space-8) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: #4A5859;
  }

  /* ============================================
     MID-CONTENT CTA
     ============================================ */
  .pa-mid-cta {
    padding: var(--space-12) 0;
    background: var(--color-bg);
  }

  .pa-mid-cta__box {
    background: var(--color-white);
    border-left: 4px solid var(--color-gold);
    padding: var(--space-8) var(--space-8);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    box-shadow: var(--shadow-md);
  }

  .pa-mid-cta__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--space-2);
  }

  .pa-mid-cta__text {
    color: var(--color-slate);
    font-size: var(--text-base);
    margin-bottom: var(--space-6);
    max-width: 480px;
    line-height: 1.6;
  }

  .pa-mid-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .pa-hero__cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .pa-mid-cta__box {
      padding: var(--space-6) var(--space-5);
    }

    /* WCAG 2.5.5 touch target — phone link needs 44px hit area */
    .pa-hero__phone-link {
      display: inline-block;
      padding: 0.625rem 0;
      min-height: 44px;
      line-height: 1.4;
    }

    /* Breadcrumb nav links need 44px hit area on touch */
    .pa-breadcrumbs a,
    .pa-breadcrumbs span[aria-current] {
      display: inline-flex;
