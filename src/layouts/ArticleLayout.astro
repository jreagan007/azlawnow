---
/**
 * Article Layout — AZ Law Now
 * Sunset Editorial LIGHT theme
 * For Brendan's investigations, Brandon's legal guides, Stephanie's client guides
 *
 * Phase 1 (2026-04): two-column template with sticky right rail.
 *   - Reading column stays ~720px for comfortable body measure
 *   - Right rail (lg+) carries the compact intake CTA + slots for
 *     "On this page" ToC, related content triad, locations — wired
 *     incrementally in later phases
 *   - Key Takeaway callout above the article body (TL;DR pattern)
 *   - Reviewed-by line under byline for E-E-A-T signal
 *   - Below 1024px the rail collapses inline below the body
 *
 * See docs/internal/editorial-templates.md for the full spec.
 */

import BaseLayout from './BaseLayout.astro';
import AutoLinker from '../components/AutoLinker.astro';
import ArticleFAQ from '../components/ArticleFAQ.astro';
import ArticleSources from '../components/ArticleSources.astro';
import ArticleToC from '../components/ArticleToC.astro';
import { siteConfig } from '../data/site-config';
import { authors, type Author } from '../data/authors';
import {
  getArticleSchema,
  generateBreadcrumbSchema,
  generateFAQSchema,
} from '../utils/schema';

interface FAQ {
  question: string;
  answer: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  author: string;
  reviewedBy?: string;
  category: string;
  tags?: string[];
  publishedAt: string;
  updatedAt?: string;
  image?: string;
  ogImage?: string;
  readingTime?: string;
  schemaType?: 'Article' | 'NewsArticle';
  keyTakeaway?: string;
  faqs?: FAQ[];
  dataSources?: string[];
  headings?: Heading[];
}

const {
  title,
  description,
  author: authorId,
  reviewedBy: reviewerId,
  category,
  tags = [],
  publishedAt,
  updatedAt,
  image,
  ogImage,
  readingTime,
  schemaType,
  keyTakeaway,
  faqs = [],
  dataSources = [],
  headings = [],
} = Astro.props;

// Resolve author
const authorData: Author = authors[authorId] || authors['brendan-franks'];

// Resolve reviewer. If not explicitly set, default to Brandon (legal editor)
// on legal-guide and client-guide content. No default reviewer on insights.
const resolvedReviewerId =
  reviewerId ??
  (category === 'legal-guide' || category === 'client-guide'
    ? 'brandon-millam'
    : undefined);
const reviewerData: Author | undefined = resolvedReviewerId
  ? authors[resolvedReviewerId]
  : undefined;

// Determine schema type from category if not explicitly set
const resolvedSchemaType = schemaType
  || (category === 'investigation' ? 'NewsArticle' : 'Article');

// Map category to section info
const categoryMeta: Record<string, { label: string; basePath: string; sectionName: string }> = {
  'investigation': { label: 'Investigation', basePath: '/investigations/', sectionName: 'Investigations' },
  'legal-guide': { label: 'Legal Guide', basePath: '/legal-guides/', sectionName: 'Legal Guides' },
  'client-guide': { label: 'Client Guide', basePath: '/client-guides/', sectionName: 'Client Guides' },
};

const meta = categoryMeta[category] || categoryMeta['investigation'];

// Build slug from URL
const slug = Astro.url.pathname.replace(meta.basePath, '').replace(/\/$/, '');

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: meta.sectionName, url: meta.basePath },
  { name: title, url: Astro.url.pathname },
];

// Format dates
function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Generate schemas
const articleSchema = getArticleSchema({
  title,
  slug,
  description,
  image: ogImage || image,
  authorName: authorData.name,
  authorSlug: authorData.id,
  authorTitle: authorData.title,
  authorImage: authorData.photo,
  publishedAt,
  updatedAt,
  basePath: meta.basePath,
  schemaType: resolvedSchemaType,
});

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbs);

const schemas: Array<Record<string, unknown>> = [articleSchema, breadcrumbSchema];

// Emit FAQPage JSON-LD only when the article actually has FAQs.
// The ArticleFAQ component also embeds matching schema.org microdata
// on the rendered accordion for redundant signal.
if (faqs.length > 0) {
  schemas.push(generateFAQSchema(faqs));
}

// Disclaimer text by category
const disclaimers: Record<string, string> = {
  'investigation': 'This article is for informational purposes only and doesn\'t constitute legal advice. If you\'ve been injured, contact a qualified attorney to discuss your specific situation.',
  'legal-guide': 'This guide provides general legal information about Arizona law. It isn\'t a substitute for legal advice from a licensed attorney. Laws change, and every case is different. Contact AZ Law Now for a confidential intake about your situation.',
  'client-guide': 'This guide is designed to help you understand the process after an injury. It doesn\'t replace the advice of your attorney. If you have questions about your case, reach out to our team directly.',
};

const disclaimer = disclaimers[category] || disclaimers['investigation'];
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage || image}
  schema={schemas}
>
  <article class="article-layout">
    <!-- ============================================
         ARTICLE HEADER
         ============================================ -->
    <header class="article-header section-sm">
      <div class="container container-narrow">
        <!-- Breadcrumbs -->
        <nav class="article-breadcrumbs" aria-label="Breadcrumb">
          <ol>
            {breadcrumbs.map((crumb, i) => (
              <li>
                {i < breadcrumbs.length - 1 ? (
                  <a href={crumb.url}>{crumb.name}</a>
                ) : (
                  <span aria-current="page">{crumb.name}</span>
                )}
              </li>
            ))}
          </ol>
        </nav>

        <!-- Category Badge -->
        <span class="article-badge">{meta.label}</span>

        <!-- Title -->
        <h1 class="article-title" data-speakable="headline">{title}</h1>

        <!-- Author Byline -->
        <div class="article-byline">
          <img
            src={authorData.photo}
            alt={authorData.name}
            class="article-byline__photo"
            width="48"
            height="48"
            loading="eager"
          />
          <div class="article-byline__info">
            <div class="article-byline__top">
              <span>By <a href={authorData.url} class="article-byline__name">{authorData.name}</a></span>
              <span class="article-byline__role">{authorData.title}</span>
            </div>
            <div class="article-byline__meta">
              <time datetime={publishedAt}>{formatDate(publishedAt)}</time>
              {updatedAt && (
                <span class="article-byline__updated">
                  Updated <time datetime={updatedAt}>{formatDate(updatedAt)}</time>
                </span>
              )}
              {readingTime && (
                <span class="article-byline__reading">{readingTime}</span>
              )}
            </div>
            {reviewerData && (
              <div class="article-byline__reviewed">
                Reviewed by
                {' '}
                <a href={reviewerData.url} class="article-byline__reviewer">{reviewerData.name}</a>
                <span class="article-byline__reviewer-title">, {reviewerData.title}</span>
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- ============================================
         FEATURED IMAGE
         ============================================ -->
    {image && (
      <div class="article-featured-image">
        <div class="container container-article">
          <img
            src={image}
            alt={title}
            class="article-featured-image__img"
            width="1200"
            height="675"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    )}

    <!-- ============================================
         ARTICLE BODY + SIDEBAR  (two-column on lg+)
         ============================================ -->
    <div class="article-body section">
      <div class="container container-article">
        <div class="article-grid">
          <!-- ── MAIN COLUMN ── -->
          <div class="article-main">
            {keyTakeaway && (
              <aside class="article-takeaway" aria-label="Key takeaway" data-speakable="takeaway">
                <span class="article-takeaway__label">Key takeaway</span>
                <p class="article-takeaway__text">{keyTakeaway}</p>
              </aside>
            )}

            <div class="article-content" data-speakable="summary">
              <AutoLinker currentPath={Astro.url.pathname} maxLinks={15}>
                <slot />
              </AutoLinker>
            </div>

            <ArticleFAQ faqs={faqs} />

            {tags.length > 0 && (
              <div class="article-tags">
                <div class="article-tags__list">
                  {tags.map((tag) => (
                    <span class="article-tags__tag">{tag}</span>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- ── RIGHT RAIL (sticky on lg+) ── -->
          <aside class="article-rail" aria-label="Article tools and related content">
            <div class="article-rail__sticky">
              <!-- On this page (ToC with scroll-spy) -->
              <ArticleToC headings={headings} />

              <!-- Compact intake CTA (voice-safe, matches footer bar) -->
              <div class="rail-cta">
                <span class="rail-cta__eyebrow">Answers start here.</span>
                <p class="rail-cta__copy">Tell us what happened. Our team will tell you what's next.</p>
                <a href="/free-case-review/" class="rail-cta__button">
                  Get answers on your case
                  <span aria-hidden="true">→</span>
                </a>
                <a
                  href={`tel:${siteConfig.phone.replace(/[^0-9+]/g, '')}`}
                  class="rail-cta__phone"
                  aria-label={`Call ${siteConfig.phone}`}
                >
                  <svg class="rail-cta__phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <span>{siteConfig.phone}</span>
                </a>
              </div>

              <!-- Phase 3 slot: The other voices (cross-voice triad) -->
              <!-- Phase 3 slot: Locations covered -->
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- ============================================
         AUTHOR BOX
         ============================================ -->
    <aside class="article-author-box section-sm" aria-label="About the author">
      <div class="container container-narrow">
        <div class="article-author-box__card">
          <img
            src={authorData.photo}
            alt={authorData.name}
            class="article-author-box__photo"
            width="80"
            height="80"
            loading="lazy"
          />
          <div class="article-author-box__info">
            <h3 class="article-author-box__name">{authorData.name}</h3>
            <p class="article-author-box__title">{authorData.title}</p>
            <p class="article-author-box__bio">{authorData.bio}</p>
            <a href={authorData.url} class="article-author-box__link">
              View Full Profile →
            </a>
          </div>
        </div>
      </div>
    </aside>

    <!-- ============================================
         DISCLAIMER
         ============================================ -->
    <div class="article-disclaimer">
      <div class="container container-narrow">
        <p class="article-disclaimer__text">{disclaimer}</p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* ============================================
     ARTICLE HEADER
     ============================================ */
  .article-header {
    background: var(--color-bg);
    padding-top: var(--space-10);
  }

  /* Breadcrumbs */
  .article-breadcrumbs {
    margin-bottom: var(--space-6);
  }

  .article-breadcrumbs ol {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }

  .article-breadcrumbs li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-2);
    color: var(--neutral-400);
  }

  .article-breadcrumbs a {
    color: var(--neutral-500);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .article-breadcrumbs a:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .article-breadcrumbs span[aria-current] {
    color: var(--neutral-700);
    font-weight: 500;
  }

  /* Category Badge */
  .article-badge {
    display: inline-block;
    background: rgba(212, 148, 58, 0.15);
    color: var(--color-gold-hover);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
  }

  /* Title */
  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.15;
    margin-bottom: var(--space-6);
  }

  /* Byline */
  .article-byline {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .article-byline__photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neutral-200);
    flex-shrink: 0;
  }

  .article-byline__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .article-byline__top {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--neutral-600);
  }

  .article-byline__name {
    font-weight: 600;
    color: #1A1A1A;
    text-decoration: none;
  }

  .article-byline__name:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .article-byline__role {
    font-size: var(--text-xs);
    color: var(--neutral-500);
  }

  .article-byline__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--neutral-500);
    flex-wrap: wrap;
  }

  .article-byline__meta time {
    color: var(--neutral-500);
  }

  .article-byline__updated::before,
  .article-byline__reading::before {
    content: '·';
    margin-right: var(--space-1);
  }

  .article-byline__reviewed {
    margin-top: var(--space-1);
    font-size: var(--text-xs);
    color: var(--neutral-600);
  }

  .article-byline__reviewer {
    color: #1A1A1A;
    font-weight: 600;
    text-decoration: none;
  }

  .article-byline__reviewer:hover {
    color: var(--color-gold-text, #8B4513);
  }

  .article-byline__reviewer-title {
    color: var(--neutral-500);
  }

  /* ============================================
     FEATURED IMAGE
     ============================================ */
  .article-featured-image {
    padding: var(--space-6) 0 0;
    background: var(--color-bg);
  }

  .article-featured-image__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  /* ============================================
     TWO-COLUMN GRID  (main + sticky right rail)
     ============================================ */
  .container-article {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: var(--space-12);
      /* Do NOT use align-items: start — the rail aside must stretch to
         the main column's height so position: sticky has room to engage.
         Stretching is the default grid behavior. */
    }
  }

  .article-main {
    min-width: 0;
    max-width: 720px;
  }

  @media (min-width: 1024px) {
    .article-main {
      max-width: none;
    }
  }

  /* ============================================
     KEY TAKEAWAY CALLOUT
     ============================================ */
  .article-takeaway {
    background: #F5EDE0;
    border-left: 4px solid var(--color-gold, #D4943A);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-5) var(--space-6);
    margin: 0 0 var(--space-8);
  }

  .article-takeaway__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-2);
  }

  .article-takeaway__text {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #1A1A1A;
    margin: 0;
    font-weight: 500;
  }

  /* ============================================
     ARTICLE BODY — MDX Content Styles
     ============================================ */
  .article-body {
    background: var(--color-bg);
  }

  .article-content :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .article-content :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.25;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .article-content :global(h4) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #1A1A1A;
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .article-content :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: #4A5859;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .article-content :global(a) {
    color: var(--color-gold-text, #8B4513);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .article-content :global(a:hover) {
    color: var(--color-gold-hover);
    text-decoration: underline;
  }

  .article-content :global(strong) {
    color: #1A1A1A;
    font-weight: 700;
  }

  .article-content :global(em) {
    font-style: italic;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid #D4943A;
    background: #F5EDE0;
    padding: var(--space-6);
    margin: var(--space-8) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
  }

  .article-content :global(blockquote p) {
    color: #4A5859;
    margin-bottom: 0;
  }

  .article-content :global(blockquote p + p) {
    margin-top: var(--space-3);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    color: #4A5859;
    padding-left: var(--space-6);
    margin-bottom: 1.25rem;
  }

  .article-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.7;
  }

  .article-content :global(li::marker) {
    color: var(--neutral-400);
  }

  .article-content :global(ol li::marker) {
    color: var(--color-gold-text, #8B4513);
    font-weight: 600;
  }

  /* Tables */
  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-8) 0;
    font-size: var(--text-sm);
  }

  .article-content :global(thead) {
    background: #F5EDE0;
  }

  .article-content :global(th) {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-weight: 700;
    color: #1A1A1A;
    border-bottom: 2px solid var(--neutral-300);
    font-size: var(--text-sm);
  }

  .article-content :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--neutral-200);
    color: #4A5859;
  }

  .article-content :global(tr:hover td) {
    background: rgba(212, 148, 58, 0.04);
  }

  /* Code */
  .article-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #F5EDE0;
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    color: #1A1A1A;
  }

  .article-content :global(pre) {
    background: #1A1A1A;
    color: var(--neutral-300);
    padding: var(--space-6);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: var(--space-8) 0;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .article-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Images in content */
  .article-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-8) 0;
  }

  /* Horizontal rules */
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--neutral-200);
    margin: var(--space-10) 0;
  }

  /* First child cleanup */
  .article-content :global(> *:first-child) {
    margin-top: 0;
  }

  .article-content :global(> h2:first-child) {
    margin-top: 0;
  }

  /* ============================================
     REFERENCES BLOCK — AEE editorial pattern
     Flat URLs visible, numbered, source on top
     ============================================ */
  .article-content :global(.references) {
    margin-top: var(--space-12);
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-left: 3px solid var(--color-gold, #D4943A);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-8);
  }

  .article-content :global(.references-label) {
    display: block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin-bottom: var(--space-4);
  }

  .article-content :global(.references ol) {
    counter-reset: ref-counter;
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .article-content :global(.references ol li) {
    counter-increment: ref-counter;
    position: relative;
    padding-left: 1.75rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: #2E2E2E;
    margin-bottom: var(--space-4);
  }

  .article-content :global(.references ol li::before) {
    content: counter(ref-counter) ".";
    position: absolute;
    left: 0;
    top: 0;
