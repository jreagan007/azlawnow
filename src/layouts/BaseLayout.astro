---
/**
 * Base Layout for AZ Law Now
 * Sunset Editorial theme — LIGHT warm cream background
 * Global layout with SEO meta tags, schema.org JSON-LD, and global styles
 */

import { SEO } from 'astro-seo';
import { Schema } from 'astro-seo-schema';
import { siteConfig } from '../data/site-config';
import { getSiteWideSchemas } from '../utils/schema';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConversionModal from '../components/ConversionModal.astro';
import StickyCTA from '../components/StickyCTA.astro';

// Self-hosted fonts via fontsource (includes WOFF2 files)
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  image?: string;
  schema?: object | object[];
  /** Hide the global header (for special landing pages) */
  hideHeader?: boolean;
  /** Hide the global footer (for special landing pages) */
  hideFooter?: boolean;
}

const {
  title,
  description = siteConfig.defaultDescription,
  canonical,
  noindex = false,
  image,
  schema,
  hideHeader = false,
  hideFooter = false,
} = Astro.props;

/**
 * Generate page title with site name appended
 */
function generateTitle(pageTitle?: string): string {
  if (!pageTitle) return siteConfig.defaultTitle;
  if (pageTitle.includes('AZ Law Now')) return pageTitle;
  return `${pageTitle} | AZ Law Now`;
}

/**
 * Generate canonical URL from pathname
 */
function generateCanonical(path: string): string {
  const siteUrl = (import.meta.env.SITE || siteConfig.siteUrl).replace(/\/$/, '');
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `${siteUrl}${cleanPath}`;
}

/**
 * Generate OG image URL from pathname
 */
function generateOGImageUrl(path: string): string {
  const siteUrl = (import.meta.env.SITE || siteConfig.siteUrl).replace(/\/$/, '');
  const cleanPath = path.replace(/^\/+|\/+$/g, '');
  const slug = cleanPath ? cleanPath.replace(/\//g, '-') : 'index';
  return `${siteUrl}/og/${slug}.webp`;
}

const pageTitle = generateTitle(title);
const canonicalUrl = canonical || generateCanonical(Astro.url.pathname);

const ogImage = image
  ? (image.startsWith('http') ? image : `${siteConfig.siteUrl}${image}`)
  : generateOGImageUrl(Astro.url.pathname);

// Site-wide schemas (WebSite, Organization, SiteNavigationElement)
const siteSchemas = getSiteWideSchemas();

// Page-specific schemas
const pageSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];

// Combine all schemas
const allSchemas = [...siteSchemas, ...pageSchemas];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- GA4 (Google Analytics 4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LB238M4SV2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LB238M4SV2');
    </script>

    <!-- TODO: Meta (Facebook) Pixel -->
    <!-- TODO: CallRail tracking -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1A1A1A" />
    <meta name="msapplication-TileColor" content="#1A1A1A" />

    <!-- Self-hosted Fonts via fontsource -->

    <!-- SEO Meta Tags -->
    <SEO
      title={pageTitle}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      openGraph={{
        basic: {
          title: pageTitle,
          type: 'website',
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          description: description,
          locale: 'en_US',
          siteName: siteConfig.siteName,
        },
        image: {
          width: 1200,
          height: 630,
          type: 'image/webp',
          alt: pageTitle,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: pageTitle,
        description: description,
        image: ogImage,
      }}
      extend={{
        meta: [
          { name: 'author', content: siteConfig.siteName },
          { name: 'robots', content: noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' },
          { name: 'format-detection', content: 'telephone=yes' },
          { property: 'og:phone_number', content: siteConfig.phone },
        ],
        link: [
          { rel: 'canonical', href: canonicalUrl },
        ],
      }}
    />

    <!-- JSON-LD Schema (via astro-seo-schema) -->
    {allSchemas.map((schemaItem) => (
      <Schema item={schemaItem} />
    ))}

    <!-- Global Design System -->
    <style is:global>
      /* ========================================
         DESIGN TOKENS — Sunset Editorial (LIGHT)
         ======================================== */
      :root {
        /* Brand Colors */
        --color-black: #1A1A1A;
        --color-gold: #D4943A;            /* masthead / decorative / dark-bg only — NOT for text on light bg */
        --color-gold-hover: #C2842E;
        --color-gold-text: #8B4513;       /* readable "gold" for text on cream/white (~8.8:1 on cream) */
        --color-bg: #FAF5ED;
        --color-sienna: #8B4513;
        --color-red: #C23B22;
        --color-red-hover: #A83220;
        --color-slate: #4A5859;
        --color-white: #FFFFFF;

        /* Neutral Scale */
        --neutral-50: #FAF5ED;
        --neutral-100: #F5EDE0;
        --neutral-200: #E8DDD0;
        --neutral-300: #D4C9BB;
        --neutral-400: #B0A698;
        --neutral-500: #8C8276;
        --neutral-600: #6B6259;
        --neutral-700: #4A5859;
        --neutral-800: #2E2E2E;
        --neutral-900: #1A1A1A;

        /* Typography */
        --font-heading: 'Cormorant Garamond', Georgia, serif;
        --font-body: 'DM Sans', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;

        /* Font Sizes */
        --text-xs: 0.75rem;
        --text-sm: 0.875rem;
        --text-base: 1rem;
        --text-lg: 1.125rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 2rem;
        --text-4xl: 2.5rem;
        --text-5xl: 3rem;
        --text-6xl: 3.5rem;

        /* Spacing — 4px base */
        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.25rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-10: 2.5rem;
        --space-12: 3rem;
        --space-16: 4rem;
        --space-20: 5rem;
        --space-24: 6rem;

        /* Border Radius */
        --radius-sm: 4px;
        --radius-md: 6px;
        --radius-lg: 8px;
        --radius-xl: 12px;

        /* Shadows — light theme: softer, warm-tinted */
        --shadow-sm: 0 2px 4px rgba(26, 26, 26, 0.06);
        --shadow-md: 0 4px 12px rgba(26, 26, 26, 0.08);
        --shadow-lg: 0 8px 24px rgba(26, 26, 26, 0.12);
        --shadow-gold: 0 4px 20px rgba(212, 148, 58, 0.2);

        /* Transitions */
        --transition-fast: 0.15s ease;
        --transition-base: 0.2s ease;
        --transition-slow: 0.3s ease;

        /* Container */
        --container-max: 1200px;
        --container-padding: 1.5rem;

        /* Z-Index Scale */
        --z-dropdown: 100;
        --z-sticky: 200;
        --z-fixed: 300;
        --z-modal: 400;
        --z-tooltip: 500;
      }

      /* ========================================
         BASE RESET & TYPOGRAPHY
         ======================================== */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: var(--font-body);
        background-color: var(--color-bg);
        color: var(--color-slate);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Headings */
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 700;
        line-height: 1.2;
        color: var(--color-black);
      }

      h1 { font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl)); }
      h2 { font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl)); }
      h3 { font-size: var(--text-2xl); }
      h4 { font-size: var(--text-xl); }

      p {
        color: var(--color-slate);
        line-height: 1.7;
      }

      a {
        color: var(--color-gold-text);
        text-decoration: none;
        transition: color var(--transition-base);
      }

      a:hover {
        color: var(--color-gold);
      }

      ::selection {
        background-color: var(--color-gold);
        color: var(--color-white);
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      /* ========================================
         LAYOUT UTILITIES
         ======================================== */
      .container {
        width: 100%;
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--container-padding);
      }

      .container-narrow {
        max-width: 800px;
      }

      .container-wide {
        max-width: 1400px;
      }

      /* Section Spacing */
      .section {
        padding: var(--space-20) 0;
      }

      .section-sm {
        padding: var(--space-12) 0;
      }

      .section-lg {
        padding: var(--space-24) 0;
      }

      /* ========================================
         DARK SECTIONS (inverted on light bg)
         ======================================== */
      .section-dark {
        background-color: var(--color-black);
        color: var(--neutral-50);
      }

      .section-dark h1,
      .section-dark h2,
      .section-dark h3,
      .section-dark h4,
      .section-dark h5,
      .section-dark h6 {
        color: var(--neutral-50);
      }

      .section-dark p {
        color: var(--neutral-400);
      }

      .section-dark a {
        color: var(--color-gold);
      }

      .section-dark a:hover {
        color: var(--color-gold-hover);
      }

      /* ========================================
         BUTTON SYSTEM
         ======================================== */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        padding: var(--space-4) var(--space-8);
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        transition: all var(--transition-base);
        text-decoration: none;
        white-space: nowrap;
      }

      .btn:focus-visible {
        outline: 2px solid var(--color-gold);
        outline-offset: 2px;
      }

      /* Primary CTA — Golden Hour gold bg, charcoal text (WCAG AA/AAA at ~8.52:1) */
      .btn-primary {
        background: var(--color-gold);
        color: var(--color-black);
        box-shadow: var(--shadow-gold);
      }

      .btn-primary:hover,
      .btn-primary:focus-visible {
        background: var(--color-sienna);
        color: var(--color-white);
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(139, 69, 19, 0.3);
      }

      .btn-primary:active {
        transform: translateY(0);
        background: var(--color-sienna);
        color: var(--color-white);
      }

      .btn-primary svg,
      .btn-primary svg path {
        stroke: currentColor;
      }

      .btn-primary svg {
        transition: transform 0.2s ease;
      }

      .btn-primary:hover svg {
        transform: translateX(3px);
      }

      /* Secondary CTA — outlined */
      .btn-secondary {
        background: transparent;
        color: var(--color-black);
        border: 1px solid var(--neutral-300);
      }

      .btn-secondary:hover,
      .btn-secondary:focus-visible {
        border-color: var(--color-gold);
        color: var(--color-gold-text);
        background: rgba(212, 148, 58, 0.06);
      }

      /* Ghost Button */
      .btn-ghost {
        background: transparent;
        color: var(--color-gold-text);
        padding: var(--space-3) var(--space-6);
      }

      .btn-ghost:hover,
      .btn-ghost:focus-visible {
        background: rgba(212, 148, 58, 0.08);
        color: var(--color-sienna);
      }

      /* Red/Urgent CTA */
      .btn-urgent {
        background: var(--color-red);
        color: var(--color-white);
      }

      .btn-urgent:hover,
      .btn-urgent:focus-visible {
        background: var(--color-red-hover);
        color: var(--color-white);
        transform: translateY(-2px);
      }

      .btn-urgent:active {
        transform: translateY(0);
      }

      /* Dark section button overrides — ensure contrast */
      .section-dark .btn-primary {
        box-shadow: 0 4px 20px rgba(212, 148, 58, 0.3);
      }

      .section-dark .btn-primary:hover,
      .section-dark .btn-primary:focus-visible {
        background: var(--color-white);
        color: var(--color-black);
        box-shadow: 0 6px 24px rgba(255, 255, 255, 0.2);
      }

      .section-dark .btn-secondary {
        color: var(--neutral-300);
        border-color: var(--neutral-600);
      }

      .section-dark .btn-secondary:hover,
      .section-dark .btn-secondary:focus-visible {
        border-color: var(--color-gold);
        color: var(--color-gold);
        background: rgba(212, 148, 58, 0.1);
      }

      /* Button Sizes */
      .btn-sm {
        padding: var(--space-3) var(--space-5);
        font-size: var(--text-xs);
      }

      .btn-lg {
        padding: var(--space-5) var(--space-10);
        font-size: var(--text-base);
      }

      /* ========================================
         CARD SYSTEM — white on cream
         ======================================== */
      .card {
        background: var(--color-white);
        border: 1px solid var(--neutral-200);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        transition: all var(--transition-base);
      }

      .card:hover {
        border-color: var(--color-gold);
      }

      .card-elevated {
        box-shadow: var(--shadow-md);
      }

      .card-elevated:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
      }

      /* Stat Card */
      .stat-card {
        background: var(--color-white);
        border: 1px solid var(--neutral-200);
        border-radius: var(--radius-lg);
        padding: var(--space-6);
        text-align: center;
        box-shadow: var(--shadow-sm);
      }

      .stat-number {
        display: block;
        font-family: var(--font-heading);
        font-size: var(--text-3xl);
        font-weight: 700;
        color: var(--color-gold-text);
        line-height: 1;
        margin-bottom: var(--space-2);
      }

      .stat-label {
        font-size: var(--text-sm);
        color: var(--color-slate);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      /* ========================================
         FORM ELEMENTS
         ======================================== */
      .form-field {
        margin-bottom: var(--space-4);
      }

      .form-label {
        display: block;
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--color-slate);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: var(--space-2);
      }

      .form-input,
      .form-select,
      .form-textarea {
        width: 100%;
        padding: var(--space-4);
        background: var(--color-white);
        border: 1px solid var(--neutral-300);
        border-radius: var(--radius-md);
        color: var(--color-black);
        font-family: var(--font-body);
        font-size: var(--text-base);
        transition: border-color var(--transition-base), box-shadow var(--transition-base);
      }

      .form-input:focus,
      .form-select:focus,
      .form-textarea:focus {
        outline: none;
        border-color: var(--color-gold);
        box-shadow: 0 0 0 3px rgba(212, 148, 58, 0.15);
      }

      .form-input::placeholder,
      .form-textarea::placeholder {
        color: var(--neutral-400);
      }

      .form-textarea {
        resize: vertical;
        min-height: 120px;
      }

      /* ========================================
         TABLE STYLES
         ======================================== */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--text-sm);
      }

      .data-table th {
        background: rgba(212, 148, 58, 0.1);
        color: var(--color-black);
        font-weight: 600;
        text-align: left;
        padding: var(--space-4);
        border-bottom: 2px solid var(--neutral-200);
      }

      .data-table td {
        padding: var(--space-4);
        border-bottom: 1px solid var(--neutral-200);
        color: var(--color-slate);
      }

      .data-table tr:hover td {
        background: rgba(212, 148, 58, 0.04);
      }

      /* ========================================
         TRUST & CRO ELEMENTS
         ======================================== */
      /* Trust Bar — dark strip with gold accents */
      .trust-bar {
        background: var(--color-black);
        border-top: 1px solid var(--neutral-800);
        border-bottom: 1px solid var(--neutral-800);
        padding: var(--space-8) 0;
      }

      .trust-bar .stat-number {
        color: var(--color-gold);
      }

      .trust-bar .stat-label {
        color: var(--neutral-400);
      }

      .trust-grid {
        display: flex;
        justify-content: center;
        gap: var(--space-12);
        flex-wrap: wrap;
      }

      /* Callout Box — cream bg with gold left border */
      .callout {
        background: var(--neutral-100);
        border-left: 4px solid var(--color-gold);
        padding: var(--space-6);
        margin: var(--space-8) 0;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
      }

      .callout-warning {
        border-left-color: #EAB308;
        background: rgba(234, 179, 8, 0.06);
      }

      .callout-urgent {
        border-left-color: var(--color-red);
        background: rgba(194, 59, 34, 0.04);
      }

      .callout-title {
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: 700;
        color: var(--color-black);
        margin-bottom: var(--space-2);
      }

      .callout-text {
        font-size: var(--text-sm);
        color: var(--color-slate);
      }

      /* Phone CTA (used on light backgrounds) */
      .phone-cta {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--color-gold-text);
      }

      .phone-cta:hover,
      .phone-cta:focus-visible {
        color: var(--color-sienna);
      }

      .phone-cta:focus-visible {
        outline: 2px solid var(--color-gold);
        outline-offset: 4px;
        border-radius: 2px;
      }

      /* ========================================
         HERO PATTERNS — light theme
         ======================================== */
      .hero {
        padding: var(--space-20) 0 var(--space-16);
        background: linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 100%);
      }

      .hero-dark {
        background: linear-gradient(180deg, var(--color-black) 0%, var(--neutral-800) 100%);
      }

      .hero-dark h1,
      .hero-dark h2,
      .hero-dark h3 {
        color: var(--neutral-50);
      }

      .hero-dark p,
      .hero-dark .hero-subtitle {
        color: var(--neutral-400);
      }

      .hero-centered {
        text-align: center;
      }

      .hero h1 {
        margin-bottom: var(--space-6);
      }

      .hero-subtitle {
        font-size: var(--text-xl);
        color: var(--color-slate);
        max-width: 700px;
        margin-bottom: var(--space-8);
      }

      .hero-centered .hero-subtitle {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-cta {
        display: flex;
        gap: var(--space-4);
        flex-wrap: wrap;
      }

      .hero-centered .hero-cta {
        justify-content: center;
      }

      /* ========================================
         CTA SECTION
         ======================================== */
      .cta-section {
        background: linear-gradient(135deg, var(--color-black) 0%, rgba(212, 148, 58, 0.15) 100%);
        padding: var(--space-20) 0;
        text-align: center;
      }

      .cta-section h2 {
        color: var(--neutral-50);
        margin-bottom: var(--space-4);
      }

      .cta-section p {
        color: var(--neutral-400);
        max-width: 600px;
        margin: 0 auto var(--space-8);
      }

      .cta-buttons {
        display: flex;
        justify-content: center;
        gap: var(--space-4);
        flex-wrap: wrap;
      }

      /* ========================================
         GRID LAYOUTS
         ======================================== */
      .grid {
        display: grid;
        gap: var(--space-6);
      }

      .grid-2 {
        grid-template-columns: repeat(2, 1fr);
      }

      .grid-3 {
        grid-template-columns: repeat(3, 1fr);
      }

      .grid-4 {
        grid-template-columns: repeat(4, 1fr);
      }

      .grid-auto {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      /* ========================================
         ACCESSIBILITY
         ======================================== */
      .skip-link {
        position: absolute;
        top: -100px;
        left: var(--space-4);
        background: var(--color-black);
        color: var(--color-white);
        padding: var(--space-3) var(--space-6);
        border-radius: var(--radius-md);
        z-index: var(--z-tooltip);
        font-weight: 600;
        text-decoration: none;
        transition: top 0.2s;
      }

      .skip-link:focus,
      .skip-link:focus-visible {
        top: var(--space-4);
        outline: 3px solid var(--color-gold);
        outline-offset: 2px;
      }

      :focus-visible {
        outline: 2px solid var(--color-gold);
        outline-offset: 2px;
      }

      /* Screen reader only */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* ========================================
         MOBILE-FIRST RESPONSIVE
         ======================================== */
      @media (max-width: 1024px) {
        .grid-4 {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 768px) {
        :root {
          --container-padding: 1rem;
        }

        .section {
          padding: var(--space-16) 0;
        }

        .hero {
          padding: var(--space-16) 0 var(--space-12);
        }

        .grid-2,
        .grid-3,
        .grid-4 {
          grid-template-columns: 1fr;
        }

        .trust-grid {
          gap: var(--space-8);
        }

        .hero-cta,
        .cta-buttons {
          flex-direction: column;
          align-items: center;
        }

        .btn {
          width: 100%;
          max-width: 320px;
        }
      }

      @media (max-width: 480px) {
        .stat-number {
          font-size: var(--text-2xl);
        }
      }

      /* ========================================
         UTILITY CLASSES
         ======================================== */
      .text-center { text-align: center; }
      .text-left { text-align: left; }
      .text-right { text-align: right; }
      .text-gold { color: var(--color-gold); }
      .text-slate { color: var(--color-slate); }
      .text-black { color: var(--color-black); }
      .text-sienna { color: var(--color-sienna); }
      .text-red { color: var(--color-red); }
      .font-heading { font-family: var(--font-heading); }
      .font-mono { font-family: var(--font-mono); }
      .uppercase { text-transform: uppercase; letter-spacing: 0.05em; }
      .mb-2 { margin-bottom: var(--space-2); }
      .mb-4 { margin-bottom: var(--space-4); }
      .mb-6 { margin-bottom: var(--space-6); }
      .mb-8 { margin-bottom: var(--space-8); }
      .mt-4 { margin-top: var(--space-4); }
      .mt-8 { margin-top: var(--space-8); }

      /* Outline small button (light bg) */
      .btn-outline-sm {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 1rem;
        min-height: 40px;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-gold-text);
        border: 1px solid var(--color-gold);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      /* Mobile touch-target pass — WCAG 2.5.5 minimum 44x44 */
      @media (max-width: 768px) {
        .btn-outline-sm {
          min-height: 44px;
          padding: 0.75rem 1rem;
        }
        .form-label {
          font-size: 0.875rem; /* 14px, up from 12px */
        }
      }

      .btn-outline-sm:hover,
      .btn-outline-sm:focus-visible {
        background: rgba(212, 148, 58, 0.08);
        color: var(--color-sienna);
        border-color: var(--color-sienna);
      }

      /* Phone link styling */
      a[href^="tel:"] {
        white-space: nowrap;
      }

      /* Sticky Mobile CTA styles are in StickyCTA.astro component */
    </style>
  </head>
  <body>
    <!-- TODO: Analytics noscript fallbacks -->

    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    {!hideHeader && <Header currentPath={Astro.url.pathname} />}

    <!-- Page Content -->
    <main id="main-content">
      <slot />
    </main>

    {!hideFooter && <Footer />}

    {!hideHeader && <ConversionModal />}
    {!hideHeader && <StickyCTA />}

    <!-- GA4 Event Tracking -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Phone call clicks
        document.querySelectorAll('a[href^="tel:"]').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'phone_call_click', {
              event_category: 'engagement',
              event_label: el.textContent.trim(),
              page_path: window.location.pathname
            });
          });
        });

        // CTA button clicks (primary buttons linking to /free-case-review/)
        document.querySelectorAll('a[href*="free-case-review"]').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'cta_click', {
              event_category: 'conversion',
              event_label: el.textContent.trim(),
              page_path: window.location.pathname
            });
          });
        });

        // Case review form submission
        var caseForm = document.querySelector('form[name="case-review"]');
        if (caseForm) {
          caseForm.addEventListener('submit', function() {
            gtag('event', 'form_submit', {
              event_category: 'conversion',
              event_label: 'case_review_form',
              page_path: window.location.pathname
            });
          });
        }

        // Lead capture modal form submission
        var modalForm = document.getElementById('modal-form');
        if (modalForm) {
          modalForm.addEventListener('submit', function() {
            gtag('event', 'form_submit', {
              event_category: 'conversion',
              event_label: 'lead_capture_modal',
              page_path: window.location.pathname
            });
          });
        }

        // Modal open event
        var modal = document.getElementById('conversion-modal');
        if (modal) {
          var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(m) {
              if (m.attributeName === 'hidden' && !modal.hidden) {
                gtag('event', 'modal_open', {
                  event_category: 'engagement',
                  event_label: 'conversion_modal',
                  page_path: window.location.pathname
                });
              }
            });
          });
          observer.observe(modal, { attributes: true });
        }

        // Scroll depth tracking (25%, 50%, 75%, 100%)
        var scrollMarks = { 25: false, 50: false, 75: false, 100: false };
        window.addEventListener('scroll', function() {
          var scrollPercent = Math.round(
            (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100
          );
          [25, 50, 75, 100].forEach(function(mark) {
            if (scrollPercent >= mark && !scrollMarks[mark]) {
              scrollMarks[mark] = true;
              gtag('event', 'scroll_depth', {
                event_category: 'engagement',
                event_label: mark + '%',
                page_path: window.location.pathname,
                value: mark
              });
            }
          });
        }, { passive: true });

        // External link clicks
        document.querySelectorAll('a[target="_blank"], a[rel*="noopener"]').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'outbound_click', {
              event_category: 'engagement',
              event_label: el.href,
              page_path: window.location.pathname
            });
          });
        });

        // Internal link clicks (AutoLinker links)
        document.querySelectorAll('.internal-link').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'internal_link_click', {
              event_category: 'engagement',
              event_label: el.href,
              link_text: el.textContent.trim(),
              page_path: window.location.pathname
            });
          });
        });
      });
    </script>
  </body>
</html>
