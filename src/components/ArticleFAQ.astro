---
/**
 * ArticleFAQ — inline FAQ accordion for editorial articles
 * Phase 2 (2026-04): renders faqs[] from frontmatter as <details> accordions
 * with schema.org Question/Answer microdata. The layout emits the FAQPage
 * JSON-LD separately so the microdata + JSON-LD agree.
 *
 * Renders nothing when faqs is empty so it's safe to always mount.
 */

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
if (!faqs || faqs.length === 0) return;
---

<section
  class="article-faqs"
  aria-labelledby="article-faqs-heading"
  itemscope
  itemtype="https://schema.org/FAQPage"
>
  <h2 id="article-faqs-heading" class="article-faqs__heading">
    Frequently asked questions
  </h2>

  <div class="article-faqs__list">
    {faqs.map((faq, i) => (
      <details
        class="article-faqs__item"
        itemprop="mainEntity"
        itemscope
        itemtype="https://schema.org/Question"
        open={i === 0}
      >
        <summary class="article-faqs__question" itemprop="name">
          <span>{faq.question}</span>
          <svg
            class="article-faqs__chevron"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <div
          class="article-faqs__answer"
          itemprop="acceptedAnswer"
          itemscope
          itemtype="https://schema.org/Answer"
        >
          <div
            class="article-faqs__answer-text"
            itemprop="text"
            data-speakable="answer"
            set:html={faq.answer}
          />
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  .article-faqs {
    margin-top: var(--space-12);
    padding-top: var(--space-10);
    border-top: 1px solid var(--neutral-200);
  }

  .article-faqs__heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0 0 var(--space-6);
  }

  .article-faqs__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .article-faqs__item {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DFD0);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }

  .article-faqs__item[open] {
    border-color: var(--color-gold, #D4943A);
  }

  .article-faqs__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    cursor: pointer;
    list-style: none;
    min-height: 44px;
    line-height: 1.35;
  }

  /* Hide default marker in webkit + firefox */
  .article-faqs__question::-webkit-details-marker {
    display: none;
  }

  .article-faqs__question::marker {
    content: '';
  }

  .article-faqs__question:hover {
    background: rgba(212, 148, 58, 0.04);
  }

  .article-faqs__question:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: -2px;
  }

  .article-faqs__chevron {
    width: 20px;
    height: 20px;
    color: var(--color-gold-text, #8B4513);
    flex-shrink: 0;
    margin-top: 2px;
    transition: transform var(--transition-base);
  }

  .article-faqs__item[open] .article-faqs__chevron {
    transform: rotate(180deg);
  }

  .article-faqs__answer {
    padding: 0 var(--space-5) var(--space-5);
    border-top: 1px solid var(--neutral-100);
  }

  .article-faqs__answer-text {
    padding-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.65;
    color: #4A5859;
  }

  .article-faqs__answer-text :global(p) {
    margin: 0 0 var(--space-3);
  }

  .article-faqs__answer-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .article-faqs__answer-text :global(a) {
    color: var(--color-gold-text, #8B4513);
    text-decoration: none;
  }

  .article-faqs__answer-text :global(a:hover) {
    text-decoration: underline;
  }

  .article-faqs__answer-text :global(ul),
  .article-faqs__answer-text :global(ol) {
    margin: 0 0 var(--space-3);
    padding-left: var(--space-5);
  }

  @media (max-width: 768px) {
    .article-faqs__heading {
      font-size: 1.5rem;
    }

    .article-faqs__question {
      font-size: 1rem;
      padding: var(--space-4);
    }

    .article-faqs__answer {
      padding: 0 var(--space-4) var(--space-4);
    }
  }
</style>
