---
/**
 * AZ Law Now Footer Component
 * LIGHT cream footer — Southwestern editorial warmth
 * Dark CTA bar at top, then warm cream body
 * NOT a dark authority footer like AEE Law
 */

import { siteConfig } from '../data/site-config';

const currentYear = new Date().getFullYear();
const social = siteConfig.social ?? {};

const practiceAreas = {
  vehicleCrashes: [
    { label: 'Car Accidents', href: '/car-accidents/' },
    { label: 'Truck Accidents', href: '/truck-accidents/' },
    { label: 'Motorcycle Accidents', href: '/motorcycle-accidents/' },
    { label: 'Pedestrian Accidents', href: '/pedestrian-accidents/' },
    { label: 'Bus Accidents', href: '/bus-accidents/' },
    { label: 'Bicycle Accidents', href: '/bicycle-accidents/' },
    { label: 'Rideshare Accidents', href: '/rideshare-accidents/' },
  ],
  abuseNegligence: [
    { label: 'Elder Abuse', href: '/elder-abuse/' },
    { label: 'Nursing Home Abuse', href: '/nursing-home-abuse/' },
    { label: 'Child Abuse', href: '/child-abuse/' },
    { label: 'Daycare Negligence', href: '/daycare-negligence/' },
    { label: 'School Abuse', href: '/school-abuse/' },
    { label: 'Medical Negligence', href: '/medical-negligence/' },
  ],
  otherClaims: [
    { label: 'Slip and Fall', href: '/slip-and-fall/' },
    { label: 'Dog Bite', href: '/dog-bite/' },
    { label: 'Wrongful Death', href: '/wrongful-death/' },
    { label: 'Premises Liability', href: '/premises-liability/' },
  ],
};

const locations = {
  primary: [
    { label: 'Buckeye', href: '/buckeye/' },
    { label: 'Maricopa', href: '/maricopa/' },
  ],
  westValley: [
    { label: 'Goodyear', href: '/goodyear/' },
    { label: 'Avondale', href: '/avondale/' },
    { label: 'Phoenix', href: '/phoenix/' },
  ],
  metro: [
    { label: 'Mesa', href: '/mesa/' },
    { label: 'Chandler', href: '/chandler/' },
    { label: 'Tempe', href: '/tempe/' },
    { label: 'Scottsdale', href: '/scottsdale/' },
  ],
};

const companyLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Our Team', href: '/about/#the-editors' },
  { label: 'Case Results', href: '/case-results/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'FAQ', href: '/faq/' },
];

const resourceLinks = [
  { label: 'Insights', href: '/investigations/' },
  { label: 'Legal Guides', href: '/legal-guides/' },
  { label: 'Client Guides', href: '/client-guides/' },
  { label: 'Glossary', href: '/glossary/' },
  { label: 'Tip Line', href: '/tips/' },
];
---

<footer class="footer">
  <!-- Site-wide CTA bar -->
  <div class="footer-cta-bar">
    <div class="footer-cta-inner container">
      <div class="footer-cta-left">
        <span class="footer-cta-headline">Answers start here.</span>
        <a
          href="tel:+16026540202"
          class="footer-cta-phone"
          aria-label="Call AZ Law Now at (602) 654-0202"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          (602) 654-0202
        </a>
      </div>
      <a href="/free-case-review/" class="btn btn-primary footer-cta-btn">
        Get answers on your case
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Main Footer — light cream -->
  <div class="footer-body">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand Column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="AZ Law Now Home">
            <img
              src="/logos/logo-dark-hz.png"
              alt="AZ Law Now"
              width="200"
              height="48"
              loading="lazy"
            />
          </a>
          <div class="footer-offices">
            <address class="footer-address">
              <span class="footer-office-name">Buckeye HQ</span>
              715 E. Monroe Avenue<br />
              Buckeye, AZ 85326
            </address>
            <address class="footer-address">
              <span class="footer-office-name">Maricopa</span>
              21300 N. John Wayne Pkwy, Suite 109-B<br />
              Maricopa, AZ 85139
            </address>
          </div>
          <a href="mailto:info@azlawnow.com" class="footer-contact">info@azlawnow.com</a>
          <a href="tel:+16026540202" class="footer-contact">(602) 654-0202</a>
          <div class="footer-social">
            {social.facebook && (
              <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="AZ Law Now on Facebook" class="footer-social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
            {social.instagram && (
              <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="AZ Law Now on Instagram" class="footer-social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            )}
            {social.twitter && (
              <a href={social.twitter} target="_blank" rel="noopener noreferrer" aria-label="AZ Law Now on X" class="footer-social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
            {social.linkedin && (
              <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="AZ Law Now on LinkedIn" class="footer-social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Practice Areas -->
        <div class="footer-column">
          <h4 class="footer-col-heading">Types of Incidents</h4>
          <ul class="footer-list-2col">
            {practiceAreas.vehicleCrashes.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
            {practiceAreas.abuseNegligence.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
            {practiceAreas.otherClaims.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Locations -->
        <div class="footer-column">
          <h4 class="footer-col-heading">Locations</h4>
          <ul class="footer-list-2col">
            {locations.primary.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
            {locations.westValley.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
            {locations.metro.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Company + Resources -->
        <div class="footer-column">
          <h4 class="footer-col-heading">Company</h4>
          <ul class="footer-list">
            {companyLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
          <h4 class="footer-col-heading footer-col-subhead">Resources</h4>
          <ul class="footer-list">
            {resourceLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="footer-disclaimer">
        <p>
          The information on this website is for general information purposes only. Nothing on this site should be taken as legal advice for any individual case or situation. This information is not intended to create, and receipt or viewing does not constitute, an attorney-client relationship.
        </p>
      </div>

      <!-- Bottom Bar -->
      <div class="footer-bottom">
        <p class="footer-copyright">
          &copy; {currentYear} AZ Law Now Injury Attorneys. All rights reserved.
        </p>
        <nav class="footer-legal" aria-label="Legal">
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms-of-service/">Terms</a>
          <a href="/disclaimer/">Disclaimer</a>
          <a href="/editorial-policy/">Editorial Policy</a>
          <span class="taqtics-credit">Design by <a href="https://taqtics.com" target="_blank" rel="noopener noreferrer">taqtics.com</a></span>
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ========================================
     FOOTER — Light cream body
     ======================================== */
  .footer {
    margin-top: 0;
  }

  /* ========================================
     CTA BAR — dark band at top of footer
     ======================================== */
  .footer-cta-bar {
    background: #1A1A1A;
    padding: 1.25rem 0;
  }

  .footer-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-cta-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-cta-headline {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #FAF5ED;
    line-height: 1.1;
    margin: 0;
  }

  .footer-cta-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: 1.375rem;
    font-weight: 700;
    color: #D4943A;
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    min-height: 44px;
    border-radius: 4px;
    transition: color 0.2s ease;
  }

  .footer-cta-phone:hover,
  .footer-cta-phone:focus-visible {
    color: #FAF5ED;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  .footer-cta-phone:focus-visible {
    outline: 2px solid #D4943A;
    outline-offset: 3px;
  }

  /* Layout override — global .btn .btn-primary handles colors/font/transitions */
  .footer-cta-btn {
    flex-shrink: 0;
    font-size: 0.8125rem;
    padding: 0.75rem 1.5rem;
  }

  @media (max-width: 768px) {
    .footer-cta-bar {
      padding: 1.5rem 0;
    }
    .footer-cta-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
    .footer-cta-left {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .footer-cta-btn {
      width: 100%;
      max-width: 320px;
      justify-content: center;
    }
  }

  /* ========================================
     FOOTER BODY — warm cream
     ======================================== */
  .footer-body {
    background: #FAF5ED;
    padding: 2.5rem 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 240px 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #E8DFD0;
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo img {
    height: 42px;
    width: auto;
  }

  .footer-offices {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .footer-address {
    font-style: normal;
    font-size: 0.8125rem;
    color: #4A5859;
    line-height: 1.6;
  }

  .footer-office-name {
    display: block;
    font-weight: 700;
    color: #1A1A1A;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.6875rem;
    margin-bottom: 0.125rem;
  }

  .footer-contact {
    font-size: 0.8125rem;
    color: #4A5859;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact:hover { color: var(--color-gold-text, #8B4513); }

  /* Social */
  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(139, 69, 19, 0.08);
    color: #4A5859;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .footer-social-link:hover {
    background: var(--color-gold-text, #8B4513);
    color: #FFF;
    transform: translateY(-1px);
  }

  .footer-social-link:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: 2px;
  }

  /* Columns */
  .footer-col-heading {
    color: #1A1A1A;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #E8DFD0;
  }

  .footer-col-subhead { margin-top: 1.25rem; }

  .footer-list-2col {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    column-gap: 1rem;
  }

  .footer-list-2col li {
    margin-bottom: 0.3rem;
    break-inside: avoid;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-list li { margin-bottom: 0.3rem; }

  .footer-list-2col a,
  .footer-list a {
    color: #4A5859;
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-list-2col a:hover,
  .footer-list a:hover { color: var(--color-gold-text, #8B4513); }

  /* Disclaimer */
  .footer-disclaimer {
    padding: 1.25rem 0;
    border-bottom: 1px solid #E8DFD0;
  }

  .footer-disclaimer p {
    font-size: 0.6875rem;
    color: #4A5859;
    line-height: 1.6;
    max-width: 800px;
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
    gap: 1rem;
  }

  .footer-copyright {
    font-size: 0.6875rem;
    color: #4A5859;
    line-height: 1.4;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .footer-legal a {
    color: #4A5859;
    font-size: 0.6875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal a:hover { color: var(--color-gold-text, #8B4513); }

  .taqtics-credit {
    color: #4A5859;
    font-size: 0.6875rem;
  }

  .taqtics-credit a {
    color: #4A5859;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .taqtics-credit a:hover { color: var(--color-gold-text, #8B4513); }

  /* Focus */
  .footer-cta-phone:focus-visible,
  .footer-cta-btn:focus-visible,
  .footer-list-2col a:focus-visible,
  .footer-list a:focus-visible,
  .footer-legal a:focus-visible,
  .footer-contact:focus-visible {
    outline: 2px solid #D4943A;
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 768px) {
    .footer-cta-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .footer-cta-left {
      flex-direction: column;
      gap: 0.5rem;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .footer-brand { text-align: center; align-items: center; }
    .footer-column { text-align: center; }
    .footer-list-2col { columns: 2; text-align: left; }
    .footer-disclaimer { text-align: center; }
    .footer-disclaimer p { max-width: none; }
    .footer-bottom { flex-direction: column; text-align: center; }
    .footer-legal { flex-wrap: wrap; justify-content: center; }
  }

  @media (max-width: 480px) {
    .footer-list-2col { columns: 1; text-align: center; }
    .footer-list { text-align: center; }
  }

  /* Mobile touch-target + readability pass (WCAG 2.5.5 + 1.4.4) */
  @media (max-width: 768px) {
    /* Footer practice-area + city links need a 44px hit area on touch.
       Short-text entries (Mesa, FAQ, Tempe) need wider horizontal padding. */
    .footer-list-2col a,
    .footer-list a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
      padding: 0.8125rem 0.625rem;
      line-height: 1.4;
    }
    .footer-list-2col li,
    .footer-list li { margin-bottom: 0; }

    /* Email + phone contact links need a larger tap target */
    .footer-contact {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 0.8125rem 0.25rem;
      line-height: 1.4;
    }

    /* Logo is an image-only link — give it a 44px floor */
    .footer-logo {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }

    /* Legal links — bump from 11px to 12px and add hit area */
    .footer-legal a,
    .footer-copyright,
    .taqtics-credit,
    .footer-disclaimer p {
      font-size: 0.75rem; /* 12px */
    }
    .footer-legal a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      min-width: 44px;
      padding: 0.75rem 0.625rem;
      line-height: 1.4;
    }
  }
</style>
