---
/**
 * AZ Law Now Footer Component
 * Modeled on AEE Law footer: brand column + 4-col links sub-grid.
 * Mobile: collapsible accordion sections with chevrons.
 * Light cream body, dark CTA bar.
 */

import { siteConfig } from '../data/site-config';

const currentYear = new Date().getFullYear();
const social = siteConfig.social ?? {};

const practiceAreaLinks = [
  { label: 'Car Accidents', href: '/car-accidents/' },
  { label: 'Truck Accidents', href: '/truck-accidents/' },
  { label: 'Motorcycle Accidents', href: '/motorcycle-accidents/' },
  { label: 'Pedestrian Accidents', href: '/pedestrian-accidents/' },
  { label: 'Bus Accidents', href: '/bus-accidents/' },
  { label: 'Bicycle Accidents', href: '/bicycle-accidents/' },
  { label: 'Rideshare Accidents', href: '/rideshare-accidents/' },
  { label: 'Elder Abuse', href: '/elder-abuse/' },
  { label: 'Nursing Home Abuse', href: '/nursing-home-abuse/' },
  { label: 'Child Abuse', href: '/child-abuse/' },
  { label: 'Daycare Negligence', href: '/daycare-negligence/' },
  { label: 'School Abuse', href: '/school-abuse/' },
  { label: 'Medical Negligence', href: '/medical-negligence/' },
  { label: 'Slip and Fall', href: '/slip-and-fall/' },
  { label: 'Dog Bite', href: '/dog-bite/' },
  { label: 'Wrongful Death', href: '/wrongful-death/' },
  { label: 'Premises Liability', href: '/premises-liability/' },
];

const locationLinks = [
  { label: 'Buckeye', href: '/buckeye/' },
  { label: 'Maricopa', href: '/maricopa/' },
  { label: 'Goodyear', href: '/goodyear/' },
  { label: 'Avondale', href: '/avondale/' },
  { label: 'Phoenix', href: '/phoenix/' },
  { label: 'Mesa', href: '/mesa/' },
  { label: 'Chandler', href: '/chandler/' },
  { label: 'Tempe', href: '/tempe/' },
  { label: 'Scottsdale', href: '/scottsdale/' },
];

const resourceLinks = [
  { label: 'All Investigations', href: '/investigations/' },
  { label: 'Legal Guides', href: '/legal-guides/' },
  { label: 'Client Guides', href: '/client-guides/' },
  { label: 'Glossary', href: '/glossary/' },
  { label: 'Tip Line', href: '/tips/' },
];

const companyLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Our Team', href: '/about/#the-editors' },
  { label: 'Case Results', href: '/case-results/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Free Case Review', href: '/free-case-review/' },
  { label: 'Editorial Policy', href: '/editorial-policy/' },
];
---

<footer class="footer">
  <!-- CTA Bar -->
  <div class="footer-cta-bar">
    <div class="container footer-cta-inner">
      <div class="footer-cta-text">
        <span class="footer-cta-label">Free Case Review</span>
        <a href="tel:+16026540202" class="footer-phone" aria-label="Call AZ Law Now at (602) 654-0202">(602) 654-0202</a>
      </div>
      <a href="/free-case-review/" class="footer-cta">Get Answers on Your Case</a>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="footer-body">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="AZ Law Now Home">
            <img
              src="/logos/logo-dark-hz.png"
              alt="AZ Law Now"
              width="180"
              height="45"
              loading="lazy"
            />
          </a>
          <address class="footer-address">
            <strong>Buckeye HQ</strong><br />
            715 E. Monroe Avenue<br />
            Buckeye, AZ 85326
          </address>
          <address class="footer-address">
            <strong>Maricopa</strong><br />
            21300 N. John Wayne Pkwy, Suite 109-B<br />
            Maricopa, AZ 85139
          </address>
          <div class="footer-social">
            {social.facebook && (
              <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
            {social.instagram && (
              <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            )}
            {social.twitter && (
              <a href={social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
            {social.linkedin && (
              <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
          </div>
        </div>

        <div class="footer-links">
          <details class="footer-column footer-column--wide" open>
            <summary><h3>Types of Cases</h3><span class="chevron" aria-hidden="true"></span></summary>
            <ul class="footer-list-compact">
              {practiceAreaLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </details>

          <details class="footer-column" open>
            <summary><h3>Locations</h3><span class="chevron" aria-hidden="true"></span></summary>
            <ul class="footer-list">
              {locationLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </details>

          <details class="footer-column" open>
            <summary><h3>Resources</h3><span class="chevron" aria-hidden="true"></span></summary>
            <ul class="footer-list">
              {resourceLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </details>

          <details class="footer-column" open>
            <summary><h3>Firm</h3><span class="chevron" aria-hidden="true"></span></summary>
            <ul class="footer-list">
              {companyLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </details>
        </div>
      </div>

      <!-- Disclaimer -->
      <p class="footer-disclaimer">
        The information on this website is for general information purposes only. Nothing on this site should be taken as legal advice for any individual case or situation. This information is not intended to create, and receipt or viewing does not constitute, an attorney-client relationship.
      </p>

      <!-- Bottom Bar -->
      <div class="footer-bottom">
        <p class="footer-copyright">
          &copy; {currentYear} AZ Law Now Injury Attorneys. All rights reserved.
        </p>
        <nav class="footer-legal" aria-label="Legal">
          <a href="/privacy-policy/">Privacy</a>
          <a href="/terms-of-service/">Terms</a>
          <a href="/disclaimer/">Disclaimer</a>
          <a href="/editorial-policy/">Editorial Policy</a>
          <span class="taqtics-credit">Design by <a href="https://taqtics.com" target="_blank" rel="noopener noreferrer">taqtics.com</a></span>
        </nav>
      </div>
    </div>
  </div>
</footer>

<!-- Mobile accordion toggle -->
<script is:inline>
  (function () {
    var mq = window.matchMedia('(max-width: 767px)');
    var sections = document.querySelectorAll('.footer-column');
    function sync(e) {
      sections.forEach(function (s) {
        if (e.matches) {
          s.removeAttribute('open');
        } else {
          s.setAttribute('open', '');
        }
      });
    }
    sync(mq);
    if (mq.addEventListener) {
      mq.addEventListener('change', sync);
    } else if (mq.addListener) {
      mq.addListener(sync);
    }
  })();
</script>

<style>
  .footer { margin-top: 0; }

  /* ========================================
     CTA BAR — dark band
     ======================================== */
  .footer-cta-bar {
    background: #1A1A1A;
    padding: 1.25rem 0;
  }

  .footer-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-cta-text {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-cta-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(250, 245, 237, 0.6);
  }

  .footer-phone {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #D4943A;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .footer-phone:hover { color: #FAF5ED; }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    background: #D4943A;
    color: #FAF5ED;
    font-weight: 600;
    font-size: 0.8rem;
    padding: 0.75rem 1.25rem;
    border-radius: 2px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    min-height: 44px;
    transition: background 0.2s;
  }

  .footer-cta:hover { background: #c08432; }

  /* ========================================
     FOOTER BODY — warm cream
     ======================================== */
  .footer-body {
    background: #FAF5ED;
    padding: 0 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid #E8DFD0;
    align-items: start;
  }

  /* Brand column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-logo img {
    height: 36px;
    width: auto;
  }

  .footer-address {
    font-style: normal;
    font-size: 0.8rem;
    color: #4A5859;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .footer-address strong {
    color: #1A1A1A;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-social {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(139, 69, 19, 0.06);
    border: 1px solid #E8DFD0;
    border-radius: 2px;
    color: #4A5859;
    transition: all 0.2s ease;
  }

  .footer-social a:hover {
    background: var(--color-gold-text, #8B4513);
    border-color: var(--color-gold-text, #8B4513);
    color: #FAF5ED;
  }

  /* Links sub-grid */
  .footer-links {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2rem;
  }

  /* Details/summary accordion */
  .footer-column { margin: 0; }

  .footer-column > summary {
    list-style: none;
    cursor: default;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0;
  }

  .footer-column > summary::-webkit-details-marker { display: none; }

  .footer-column h3 {
    color: #1A1A1A;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
  }

  .chevron { display: none; }

  .footer-list-compact,
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column--wide .footer-list-compact {
    columns: 2;
    column-gap: 1rem;
  }

  .footer-list-compact li,
  .footer-list li {
    margin-bottom: 0.35rem;
    break-inside: avoid;
  }

  .footer-list-compact a,
  .footer-list a {
    color: #4A5859;
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
    line-height: 1.4;
    display: inline-block;
  }

  .footer-list-compact a:hover,
  .footer-list a:hover {
    color: var(--color-gold-text, #8B4513);
  }

  /* Disclaimer */
  .footer-disclaimer {
    font-size: 0.6875rem;
    color: #4A5859;
    line-height: 1.6;
    max-width: 800px;
    padding: 1.25rem 0;
    border-bottom: 1px solid #E8DFD0;
    margin: 0;
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: 0.6875rem;
    color: #4A5859;
    line-height: 1.4;
    margin: 0;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: #4A5859;
    font-size: 0.6875rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-legal a:hover { color: var(--color-gold-text, #8B4513); }

  .taqtics-credit {
    color: #4A5859;
    font-size: 0.6875rem;
  }

  .taqtics-credit a {
    color: #4A5859;
    text-decoration: none;
    transition: color 0.2s;
  }

  .taqtics-credit a:hover { color: var(--color-gold-text, #8B4513); }

  /* Focus */
  .footer-phone:focus-visible,
  .footer-cta:focus-visible,
  .footer-list-compact a:focus-visible,
  .footer-list a:focus-visible,
  .footer-legal a:focus-visible,
  .footer-column > summary:focus-visible {
    outline: 2px solid #D4943A;
    outline-offset: 2px;
  }

  /* ========================================
     MOBILE — collapsible accordion
     ======================================== */
  @media (max-width: 767px) {
    .footer-cta-inner {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }

    .footer-cta-text {
      flex-direction: column;
      gap: 0.25rem;
    }

    .footer-cta {
      width: 100%;
      max-width: 320px;
      justify-content: center;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.5rem 0;
    }

    .footer-brand { text-align: center; align-items: center; }

    .footer-social { justify-content: center; }

    .footer-links {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .footer-column--wide .footer-list-compact { columns: 2; }

    .footer-column {
      border-top: 1px solid #E8DFD0;
    }

    .footer-column:last-child {
      border-bottom: 1px solid #E8DFD0;
    }

    .footer-column > summary {
      cursor: pointer;
      padding: 0.875rem 0;
      min-height: 44px;
    }

    .footer-column h3 { margin: 0; }

    .chevron {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-right: 2px solid #4A5859;
      border-bottom: 2px solid #4A5859;
      transform: rotate(45deg);
      transition: transform 0.2s ease;
      margin-right: 4px;
    }

    .footer-column[open] .chevron {
      transform: rotate(-135deg);
      margin-top: 4px;
    }

    .footer-list-compact,
    .footer-list {
      padding: 0 0 0.875rem;
    }

    .footer-list-compact a,
    .footer-list a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 0.5rem 0;
    }

    .footer-list-compact li,
    .footer-list li { margin-bottom: 0; }

    .footer-disclaimer { text-align: center; max-width: none; }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }

    .footer-legal { justify-content: center; }

    .footer-legal a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 0.5rem;
    }
  }

  @media (max-width: 419px) {
    .footer-column--wide .footer-list-compact { columns: 1; }
  }

  @media (min-width: 768px) {
    .footer-column > summary {
      pointer-events: none;
      cursor: default;
    }
  }
</style>
