---
/**
 * StickyCTA
 * Mobile-only sticky bottom bar with dual CTA: case intake + phone
 * Appears as soon as the hero CTA scrolls past (~120px threshold)
 * Hidden on desktop (768px+)
 *
 * Hidden on /contact/, /thank-you/, /free-case-review/ to avoid duplicate CTA.
 */

import { siteConfig } from '../data/site-config';
---

<div class="sticky-cta" id="sticky-cta" aria-hidden="true">
  <div class="sticky-cta-inner">
    <a
      href="/free-case-review/"
      class="sticky-cta-form"
      data-event="sticky-form-cta"
      aria-label="Review my case"
    >
      Review My Case
    </a>
    <a
      href={`tel:${siteConfig.phoneE164}`}
      class="sticky-cta-phone"
      data-event="sticky-call-cta"
      aria-label={`Call ${siteConfig.phoneFormatted}`}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>Call</span>
    </a>
  </div>
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  if (stickyCta) {
    const el = stickyCta;
    // Hide on conversion pages where it would duplicate the primary CTA
    const hiddenPaths = ['/free-case-review/', '/contact/', '/thank-you/'];
    const path = window.location.pathname;
    if (hiddenPaths.some((p) => path.startsWith(p))) {
      el.remove();
    } else {
      let visible = false;
      const threshold = 120;

      function toggle() {
        const shouldShow = window.scrollY > threshold;
        if (shouldShow !== visible) {
          visible = shouldShow;
          el.classList.toggle('sticky-cta--visible', visible);
          el.setAttribute('aria-hidden', String(!visible));
        }
      }

      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
    }
  }
</script>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: var(--color-black);
    transform: translateY(100%);
    transition: transform var(--transition-slow);
    display: none;
  }

  .sticky-cta--visible {
    transform: translateY(0);
  }

  .sticky-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    align-items: stretch;
    height: 60px;
    padding: 8px var(--container-padding);
  }

  .sticky-cta-form {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-gold, #D4943A);
    color: #1A1A1A;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-base, 1rem);
    text-decoration: none;
    border-radius: 2px;
    min-height: 44px;
    letter-spacing: 0.02em;
    padding: 0 var(--space-4, 1rem);
    transition: background var(--transition-base, 0.15s ease);
  }
  .sticky-cta-form:hover,
  .sticky-cta-form:focus-visible {
    background: var(--color-gold-hover, #C0822E);
    color: #1A1A1A;
  }

  .sticky-cta-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.45);
    color: #FFFFFF;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-base, 1rem);
    text-decoration: none;
    border-radius: 2px;
    min-height: 44px;
    padding: 0 var(--space-4, 1rem);
    transition: border-color var(--transition-base, 0.15s ease), background var(--transition-base, 0.15s ease);
  }

  .sticky-cta-phone:hover,
  .sticky-cta-phone:focus-visible {
    border-color: #FFFFFF;
    background: rgba(255, 255, 255, 0.08);
    color: #FFFFFF;
  }

  @media (max-width: 768px) {
    .sticky-cta {
      display: block;
    }
  }
</style>
