---
/**
 * StatBlock, inline data callout.
 *
 * Ported from mesowatchorg, retuned to the AZ Law Now Sunset Editorial
 * palette (Newsprint card, Golden Hour stat, Burnt Sienna left-rail accent,
 * Cormorant Garamond heading, DM Sans body). Renders as a full-width,
 * left-aligned inline callout that flows with the article body and uses
 * shared CSS vars from BaseLayout.
 *
 * Coexists with StatBlock.tsx (the centered TSX variant). The .astro version
 * is the horizontal stat-on-left, label-on-right layout for inline use.
 */

interface Props {
  stat: string;
  label: string;
  source?: string;
  sourceUrl?: string;
}

const { stat, label, source, sourceUrl } = Astro.props;
---

<aside class="stat-block-callout" role="figure">
  <div class="stat-block-stat">{stat}</div>
  <div class="stat-block-body">
    <p class="stat-block-label">{label}</p>
    {source && (
      <p class="stat-block-source">
        {sourceUrl ? (
          <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
            Source: {source} &rarr;
          </a>
        ) : (
          <span>Source: {source}</span>
        )}
      </p>
    )}
  </div>
</aside>

<style>
  .stat-block-callout {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    margin: 2rem 0;
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DDD0);
    border-left: 4px solid var(--color-sienna, #8B4513);
    border-radius: var(--radius-lg, 8px);
  }

  .stat-block-stat {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--color-gold-text, #8B4513);
    line-height: 1;
    letter-spacing: -0.01em;
    flex-shrink: 0;
    align-self: center;
    min-width: 100px;
  }

  .stat-block-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.25rem;
  }

  .stat-block-label {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: var(--text-base, 1rem);
    color: var(--color-slate, #4A5859);
    line-height: 1.55;
    margin: 0;
  }

  .stat-block-source {
    margin: 0;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: var(--text-xs, 0.75rem);
    color: var(--neutral-500, #8C8276);
  }

  .stat-block-source a {
    color: var(--color-gold, #D4943A);
    text-decoration: none;
    font-weight: 500;
  }

  .stat-block-source a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .stat-block-callout {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1rem 1.5rem;
    }
    .stat-block-stat {
      font-size: 2.25rem;
      min-width: auto;
    }
  }
</style>
