---
/**
 * RelatedResources
 * Shows 3 related resource cards based on practice area
 * Placeholder structure — will be populated from content collections later
 */

interface Props {
  practiceArea: string;
  title?: string;
}

const { practiceArea, title = 'Helpful Resources' } = Astro.props;
---

<section class="related-resources section">
  <div class="container">
    <h2 class="related-resources-heading">{title}</h2>

    <!-- TODO: Populate from content collections filtered by practiceArea -->
    <!-- Use getCollection('resources') or getCollection('blog') filtered by category/tags -->
    <div class="related-resources-grid">
      {[1, 2, 3].map(() => (
        <article class="resource-card card card-elevated">
          <span class="resource-tag">Guide</span>
          <h3 class="resource-headline">Resource Title</h3>
          <p class="resource-excerpt">
            A brief description of this resource and how it helps people understand their legal options.
          </p>
          <a href="#" class="resource-link">
            Read <span aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .related-resources {
    background: var(--neutral-100);
  }

  .related-resources-heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-black);
    margin-bottom: var(--space-10);
    text-align: center;
  }

  .related-resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
  }

  .resource-tag {
    display: inline-block;
    align-self: flex-start;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-white);
    background: var(--color-gold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
  }

  .resource-headline {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-black);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .resource-excerpt {
    font-size: var(--text-sm);
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .resource-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .resource-link:hover {
    color: var(--color-gold-hover);
  }

  @media (max-width: 1024px) {
    .related-resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .related-resources-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
