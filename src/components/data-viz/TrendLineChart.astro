---
/**
 * TrendLineChart, SVG year-over-year line chart for editorial pages.
 *
 * Ported from mesowatchorg, retuned to the AZ Law Now Sunset Editorial
 * palette (Golden Hour line on Newsprint background, Alert Vermillion
 * peak/latest callouts, Cormorant Garamond headings, DM Sans body copy).
 * Self-contained Astro single-file component with scoped styles only.
 *
 * Source line bottom-left, AZ Law Now attribution bottom-right, separate
 * zones to avoid overlap. Embed button copies an iframe snippet to clipboard
 * so journalists can drop the chart into their own story.
 */

interface DataPoint {
  year: number;
  value: number;
  label?: string;
}

interface Props {
  data: DataPoint[];
  title: string;
  subtitle?: string;
  source?: string;
  sourceUrl?: string;
  valueLabel?: string;
  showArea?: boolean;
  highlightPeak?: boolean;
  highlightLatest?: boolean;
  theme?: 'light' | 'dark';
  width?: number;
  height?: number;
  embedSlug?: string;
  embedChartId?: string;
}

const {
  data,
  title,
  subtitle,
  source,
  sourceUrl,
  valueLabel = 'cases',
  showArea = true,
  highlightPeak = true,
  highlightLatest = true,
  theme = 'light',
  width = 900,
  height = 540,
  embedSlug,
  embedChartId,
} = Astro.props;

const themes = {
  light: {
    bg: '#FAF5ED',
    title: '#1A1A1A',
    subtitle: '#6B6259',
    label: '#4A5859',
    line: '#D4943A',
    area: 'rgba(212, 148, 58, 0.10)',
    gridLine: '#E8DDD0',
    axis: '#8C8276',
    source: '#8C8276',
    highlight: '#C23B22',
    highlightLabel: '#1A1A1A',
    brand: '#8B4513',
  },
  dark: {
    bg: '#1A1A1A',
    title: '#FAF5ED',
    subtitle: '#B0A698',
    label: '#FAF5ED',
    line: '#D4943A',
    area: 'rgba(212, 148, 58, 0.12)',
    gridLine: '#4A5859',
    axis: '#B0A698',
    source: '#B0A698',
    highlight: '#C23B22',
    highlightLabel: '#FAF5ED',
    brand: '#D4943A',
  },
};

const colors = themes[theme];

const margin = { top: 80, right: 40, bottom: 110, left: 70 };
const chartWidth = width - margin.left - margin.right;
const chartHeight = height - margin.top - margin.bottom;

const minYear = Math.min(...data.map(d => d.year));
const maxYear = Math.max(...data.map(d => d.year));
const minValue = 0;
const maxValue = Math.max(...data.map(d => d.value)) * 1.18;

const peakPoint = data.reduce((max, d) => d.value > max.value ? d : max, data[0]);
const latestPoint = data[data.length - 1];

function xScale(year: number): number {
  return margin.left + ((year - minYear) / (maxYear - minYear || 1)) * chartWidth;
}

function yScale(value: number): number {
  return margin.top + chartHeight - ((value - minValue) / (maxValue - minValue || 1)) * chartHeight;
}

const linePath = data.map((d, i) => {
  const x = xScale(d.year);
  const y = yScale(d.value);
  return i === 0 ? `M ${x} ${y}` : `L ${x} ${y}`;
}).join(' ');

const areaPath = linePath +
  ` L ${xScale(maxYear)} ${margin.top + chartHeight}` +
  ` L ${xScale(minYear)} ${margin.top + chartHeight}` +
  ` Z`;

const yTickCount = 5;
const yTicks = Array.from({ length: yTickCount }, (_, i) => {
  const value = minValue + (maxValue - minValue) * (i / (yTickCount - 1));
  return Math.round(value);
});

const xTickStep = Math.max(1, Math.ceil((maxYear - minYear) / 6));
const xTicks = data.filter((d, i) =>
  i === 0 || i === data.length - 1 || (d.year - minYear) % xTickStep === 0
);

function formatNumber(num: number): string {
  if (num >= 1000) {
    const k = num / 1000;
    return k % 1 === 0 ? k.toFixed(0) + 'k' : k.toFixed(1) + 'k';
  }
  return num.toString();
}

const peakAboveOk = yScale(peakPoint.value) > margin.top + 35;
const peakLabelY = peakAboveOk
  ? yScale(peakPoint.value) - 22
  : yScale(peakPoint.value) + 28;
const peakYearY = peakAboveOk
  ? yScale(peakPoint.value) - 38
  : yScale(peakPoint.value) + 44;

const latestBelowOk = yScale(latestPoint.value) < margin.top + chartHeight - 28;
const latestLabelY = latestBelowOk
  ? yScale(latestPoint.value) + 24
  : yScale(latestPoint.value) - 18;

const safeTitle = title.replace(/"/g, '&quot;');
const embedSrc = (embedSlug && embedChartId)
  ? `https://azlawnow.com/embed/${embedSlug}/${embedChartId}/`
  : (sourceUrl || 'https://azlawnow.com');
const embedCode = `<iframe src="${embedSrc}" width="100%" height="540" frameborder="0" title="${safeTitle}"></iframe>`;

const chartId = `tlc-${Math.random().toString(36).substring(2, 9)}`;
---

<figure class="azln-chart-fig" data-chart-id={chartId}>
  <svg
    viewBox={`0 0 ${width} ${height}`}
    preserveAspectRatio="xMidYMid meet"
    class="azln-chart-svg"
    role="img"
    aria-label={`${title} chart, AZ Law Now, azlawnow.com`}
  >
    <rect width={width} height={height} fill={colors.bg} rx="12"/>

    <text
      x={margin.left}
      y="36"
      fill={colors.title}
      font-family="'Cormorant Garamond', Georgia, serif"
      font-size="22"
      font-weight="600"
    >
      {title}
    </text>

    {subtitle && (
      <text
        x={margin.left}
        y="60"
        fill={colors.subtitle}
        font-family="'DM Sans', system-ui, sans-serif"
        font-size="14"
      >
        {subtitle}
      </text>
    )}

    {yTicks.map((tick) => (
      <line
        x1={margin.left}
        y1={yScale(tick)}
        x2={margin.left + chartWidth}
        y2={yScale(tick)}
        stroke={colors.gridLine}
        stroke-width="1"
        stroke-dasharray={tick === 0 ? "0" : "3,4"}
      />
    ))}

    {yTicks.map((tick) => (
      <text
        x={margin.left - 12}
        y={yScale(tick) + 4}
        text-anchor="end"
        fill={colors.axis}
        font-family="'DM Sans', system-ui, sans-serif"
        font-size="12"
      >
        {formatNumber(tick)}
      </text>
    ))}

    {xTicks.map((d) => (
      <text
        x={xScale(d.year)}
        y={margin.top + chartHeight + 22}
        text-anchor="middle"
        fill={colors.axis}
        font-family="'DM Sans', system-ui, sans-serif"
        font-size="12"
      >
        {d.year}
      </text>
    ))}

    {showArea && (
      <path d={areaPath} fill={colors.area} />
    )}

    <path
      d={linePath}
      fill="none"
      stroke={colors.line}
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    {data.map((d) => (
      <circle
        cx={xScale(d.year)}
        cy={yScale(d.value)}
        r="4"
        fill={colors.line}
        stroke={colors.bg}
        stroke-width="2"
      >
        <title>{d.year}: {d.value.toLocaleString()} {valueLabel}</title>
      </circle>
    ))}

    {highlightPeak && peakPoint.year !== latestPoint.year && (
      <g>
        <circle
          cx={xScale(peakPoint.year)}
          cy={yScale(peakPoint.value)}
          r="7"
          fill={colors.highlight}
          stroke={colors.bg}
          stroke-width="2"
        />
        <text
          x={xScale(peakPoint.year)}
          y={peakYearY}
          text-anchor="middle"
          fill={colors.subtitle}
          font-family="'DM Sans', system-ui, sans-serif"
          font-size="10"
        >
          {peakPoint.year}
        </text>
        <text
          x={xScale(peakPoint.year)}
          y={peakLabelY}
          text-anchor="middle"
          fill={colors.highlightLabel}
          font-family="'DM Sans', system-ui, sans-serif"
          font-size="12"
          font-weight="600"
        >
          Peak {peakPoint.value.toLocaleString()}
        </text>
      </g>
    )}

    {highlightLatest && (
      <g>
        <circle
          cx={xScale(latestPoint.year)}
          cy={yScale(latestPoint.value)}
          r="7"
          fill={colors.line}
          stroke={colors.bg}
          stroke-width="2"
        />
        <text
          x={xScale(latestPoint.year)}
          y={latestLabelY}
          text-anchor={latestPoint.year === maxYear ? "end" : "middle"}
          fill={colors.highlightLabel}
          font-family="'DM Sans', system-ui, sans-serif"
          font-size="12"
          font-weight="600"
        >
          {latestPoint.year}: {latestPoint.value.toLocaleString()}
        </text>
      </g>
    )}

    {source && (
      <text
        x={margin.left}
        y={height - 22}
        fill={colors.source}
        font-family="'DM Sans', system-ui, sans-serif"
        font-size="11"
      >
        Source: {source}
      </text>
    )}

    <text
      x={width - 24}
      y={height - 22}
      text-anchor="end"
      fill={colors.brand}
      font-family="'Cormorant Garamond', Georgia, serif"
      font-size="13"
      font-weight="600"
      letter-spacing="0.04em"
    >
      AZLAWNOW.COM
    </text>
  </svg>

  <div class="azln-chart-caption">
    {sourceUrl && (
      <a class="azln-chart-source-link" href={sourceUrl} target="_blank" rel="noopener noreferrer">
        View source data &rarr;
      </a>
    )}
    {(
      <button
        class="azln-chart-embed-btn"
        type="button"
        data-embed-code={embedCode}
        aria-label="Copy embed code for this chart"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="16 18 22 12 16 6"/>
          <polyline points="8 6 2 12 8 18"/>
        </svg>
        <span>Copy embed code</span>
      </button>
    )}
  </div>
</figure>

<script>
  document.querySelectorAll<HTMLButtonElement>('.azln-chart-embed-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.embedCode || '';
      const label = btn.querySelector('span');
      const original = label?.textContent || 'Copy embed code';
      try {
        await navigator.clipboard.writeText(code);
        if (label) label.textContent = 'Copied';
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); if (label) label.textContent = 'Copied'; } catch {}
        document.body.removeChild(ta);
      }
      setTimeout(() => { if (label) label.textContent = original; }, 2000);
    });
  });
</script>

<style>
  .azln-chart-fig {
    margin: 2rem 0;
    padding: 0;
  }

  .azln-chart-svg {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg, 8px);
    border: 1px solid var(--neutral-200, #E8DDD0);
    box-shadow: var(--shadow-sm, 0 2px 4px rgba(26, 26, 26, 0.06));
  }

  .azln-chart-caption {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .azln-chart-source-link {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    color: var(--color-gold, #D4943A);
    text-decoration: none;
  }

  .azln-chart-source-link:hover { text-decoration: underline; }

  .azln-chart-embed-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-white, #FFFFFF);
    color: var(--color-gold-text, #8B4513);
    border: 1px solid var(--color-gold, #D4943A);
    border-radius: var(--radius-md, 6px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .azln-chart-embed-btn:hover {
    background: var(--color-gold, #D4943A);
    color: var(--color-black, #1A1A1A);
  }

  @media (max-width: 600px) {
    .azln-chart-caption { justify-content: flex-start; }
  }
</style>
