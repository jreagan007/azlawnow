---
/**
 * StatCard, shareable single-stat SVG card with AZ Law Now branding.
 *
 * Ported from mesowatchorg, retuned to the Sunset Editorial palette.
 * Three themes: light (Newsprint ground, Golden Hour stat), dark (Headline
 * Black ground, Golden Hour stat), gold (Golden Hour ground, Headline Black
 * stat). Embed as SVG, export to PNG, share with attribution.
 *
 * Self-contained Astro single-file component with scoped styles.
 */

interface Props {
  stat: string;
  label: string;
  sublabel?: string;
  source?: string;
  sourceUrl?: string;
  theme?: 'light' | 'dark' | 'gold';
  width?: number;
  height?: number;
}

const {
  stat,
  label,
  sublabel,
  source,
  sourceUrl = 'https://azlawnow.com',
  theme = 'light',
  width = 600,
  height = 400,
} = Astro.props;

const themes = {
  light: {
    bgGradient: 'url(#grad-light)',
    statColor: '#8B4513',
    labelColor: '#1A1A1A',
    sublabelColor: '#4A5859',
    sourceColor: '#8C8276',
    accentColor: '#D4943A',
    brandColor: '#1A1A1A',
  },
  dark: {
    bgGradient: 'url(#grad-dark)',
    statColor: '#D4943A',
    labelColor: '#FAF5ED',
    sublabelColor: '#B0A698',
    sourceColor: '#8C8276',
    accentColor: '#D4943A',
    brandColor: '#FAF5ED',
  },
  gold: {
    bgGradient: 'url(#grad-gold)',
    statColor: '#1A1A1A',
    labelColor: '#1A1A1A',
    sublabelColor: '#1A1A1A',
    sourceColor: '#4A5859',
    accentColor: '#1A1A1A',
    brandColor: '#1A1A1A',
  },
};

const colors = themes[theme];
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  width={width}
  height={height}
  xmlns="http://www.w3.org/2000/svg"
  class="stat-card"
  role="img"
  aria-label={`${stat} ${label} | AZ Law Now`}
>
  <defs>
    <linearGradient id="grad-light" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FAF5ED;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#F5EDE0;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad-dark" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2E2E2E;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1A1A1A;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad-gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E0A24A;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#C2842E;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="4" stdDeviation="8" flood-opacity="0.25"/>
    </filter>
  </defs>

  <rect width={width} height={height} fill={colors.bgGradient} rx="16"/>

  <rect x="0" y="0" width="6" height={height} fill={colors.accentColor} rx="3"/>

  <text
    x={width / 2}
    y={height * 0.4}
    text-anchor="middle"
    dominant-baseline="middle"
    fill={colors.statColor}
    font-family="'Cormorant Garamond', Georgia, serif"
    font-size="96"
    font-weight="600"
  >
    {stat}
  </text>

  <text
    x={width / 2}
    y={height * 0.58}
    text-anchor="middle"
    fill={colors.labelColor}
    font-family="'DM Sans', system-ui, sans-serif"
    font-size="24"
    font-weight="500"
  >
    {label}
  </text>

  {sublabel && (
    <text
      x={width / 2}
      y={height * 0.68}
      text-anchor="middle"
      fill={colors.sublabelColor}
      font-family="'DM Sans', system-ui, sans-serif"
      font-size="16"
    >
      {sublabel}
    </text>
  )}

  {source && (
    <text
      x={width / 2}
      y={height * 0.85}
      text-anchor="middle"
      fill={colors.sourceColor}
      font-family="'DM Sans', system-ui, sans-serif"
      font-size="12"
    >
      Source: {source}
    </text>
  )}

  <text
    x={width - 24}
    y={height - 24}
    text-anchor="end"
    fill={colors.brandColor}
    font-family="'Cormorant Garamond', Georgia, serif"
    font-size="16"
    font-weight="700"
    letter-spacing="0.06em"
  >
    AZ LAW NOW
  </text>
</svg>

<style>
  .stat-card {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(26, 26, 26, 0.18);
  }
</style>
