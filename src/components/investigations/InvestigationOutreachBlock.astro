---
/**
 * InvestigationOutreachBlock
 *
 * In-page outreach block for /investigations/* detail pages. Press-first CTAs
 * for journalists, researchers, and re-publishers: cite this investigation,
 * request the dataset, embed a chart, methodology snapshot, contact the desk,
 * subscribe to the AZ Law Now data drop. Tertiary client-intake link sits at
 * the bottom for Arizonans who actually need a lawyer.
 *
 * Style: Sunset Editorial LIGHT theme using BaseLayout CSS custom properties
 * (--color-bg cream cards on --color-white, --neutral-700 body text,
 * --color-gold accents, --neutral-200 borders). Cormorant Garamond headings,
 * DM Sans body, JetBrains Mono for citation/embed code blocks. Netlify Forms
 * for submission.
 */

interface Methodology {
  dataSources?: string[];
  processing?: string;
  limitations?: string[];
  peerReview?: string;
  lastUpdated?: string;
}

interface EmbeddableChart {
  id: string;
  title: string;
  imageUrl?: string;
  width?: number;
  height?: number;
}

export interface Props {
  slug: string;
  title: string;
  publishedAt: string;
  authorName: string;
  datasetUrl?: string;
  hasDataset?: boolean;
  methodology?: Methodology;
  embeddableCharts?: EmbeddableChart[];
}

const {
  slug,
  title,
  publishedAt,
  authorName,
  datasetUrl,
  hasDataset = false,
  methodology,
  embeddableCharts = [],
} = Astro.props;

const url = `https://azlawnow.com/investigations/${slug}/`;
const year = new Date(publishedAt).getFullYear();
const monthName = new Date(publishedAt).toLocaleDateString('en-US', { month: 'long' });
const day = new Date(publishedAt).getDate();

const lastFirst = (() => {
  const parts = authorName.split(' ');
  if (parts.length < 2) return authorName;
  const last = parts[parts.length - 1];
  const initials = parts.slice(0, -1).map(p => p[0] + '.').join(' ');
  return `${last}, ${initials}`;
})();

const apaCitation = `${lastFirst} (${year}, ${monthName} ${day}). ${title}. AZ Law Now. ${url}`;
const apCitation = `According to AZ Law Now reporting published ${monthName} ${day}, ${year}, [your claim]. The full investigation is available at azlawnow.com/investigations/${slug}.`;
const bibtexKey = `azlawnow_${slug.replace(/-/g, '_')}_${year}`;
const bibtexCitation = `@misc{${bibtexKey},\n  author = {${authorName}},\n  title = {${title}},\n  publisher = {AZ Law Now},\n  year = {${year}},\n  month = {${monthName}},\n  url = {${url}}\n}`;

const hasMethodology = !!methodology && (
  (methodology.dataSources && methodology.dataSources.length > 0) ||
  !!methodology.processing ||
  (methodology.limitations && methodology.limitations.length > 0) ||
  !!methodology.peerReview ||
  !!methodology.lastUpdated
);

const hasEmbeds = embeddableCharts.length > 0;
---

<aside class="outreach-block" aria-labelledby="outreach-heading">
  <div class="outreach-container">

    <header class="outreach-header">
      <p class="outreach-eyebrow">For journalists, researchers, and re-publishers</p>
      <h2 id="outreach-heading">Use this investigation</h2>
    </header>

    <div class="outreach-grid">

      <!-- 1. CITE THIS -->
      <section class="outreach-card">
        <h3>Cite this investigation</h3>
        <p class="outreach-card-body">Three formats. Click to copy. Use whichever your style guide accepts.</p>

        <div class={`outreach-tabs outreach-tabs-${slug}`} role="tablist" aria-label="Citation formats">
          <button role="tab" aria-selected="true" data-tab="apa" class="outreach-tab outreach-tab-active">APA</button>
          <button role="tab" aria-selected="false" data-tab="ap" class="outreach-tab">AP style</button>
          <button role="tab" aria-selected="false" data-tab="bibtex" class="outreach-tab">BibTeX</button>
        </div>

        <div class="outreach-citation outreach-citation-active" data-panel="apa">
          <pre>{apaCitation}</pre>
          <button class="outreach-copy" type="button" data-copy={apaCitation}>Copy citation</button>
        </div>
        <div class="outreach-citation" data-panel="ap" hidden>
          <pre>{apCitation}</pre>
          <button class="outreach-copy" type="button" data-copy={apCitation}>Copy citation</button>
        </div>
        <div class="outreach-citation" data-panel="bibtex" hidden>
          <pre>{bibtexCitation}</pre>
          <button class="outreach-copy" type="button" data-copy={bibtexCitation}>Copy citation</button>
        </div>
        <div class="outreach-aria-live" aria-live="polite"></div>
      </section>

      <!-- 2. REQUEST DATASET (only when hasDataset === true) -->
      {hasDataset && (
        <section class="outreach-card">
          <h3>Request the dataset</h3>
          {datasetUrl ? (
            <>
              <p class="outreach-card-body">
                We share investigation datasets with journalists, attorneys, and researchers under a press-use license.
              </p>
              <p class="outreach-direct">
                <a href={datasetUrl} download>Download the CSV</a>
              </p>
              <p class="outreach-secondary-line">Or request the cleaned working copy below.</p>
            </>
          ) : (
            <p class="outreach-card-body">
              We share investigation datasets with journalists, attorneys, and researchers under a press-use license. Tell us what you're working on and we'll send the file.
            </p>
          )}
          <form
            name="az-dataset-request"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you/"
          >
            <input type="hidden" name="form-name" value="az-dataset-request" />
            <input type="hidden" name="investigation" value={slug} />
            <p class="hidden"><label>Don't fill: <input name="bot-field" /></label></p>

            <div class="outreach-form-group">
              <label for={`data-name-${slug}`}>Your name</label>
              <input id={`data-name-${slug}`} type="text" name="name" required autocomplete="name" />
            </div>

            <div class="outreach-form-group">
              <label for={`data-outlet-${slug}`}>Outlet</label>
              <input id={`data-outlet-${slug}`} type="text" name="outlet" required autocomplete="organization" />
            </div>

            <div class="outreach-form-group">
              <label for={`data-email-${slug}`}>Email</label>
              <input id={`data-email-${slug}`} type="email" name="email" required autocomplete="email" />
            </div>

            <div class="outreach-form-group">
              <label for={`data-use-${slug}`}>Intended use</label>
              <textarea
                id={`data-use-${slug}`}
                name="use"
                rows="2"
                required
                placeholder="Story angle, research project, or how you plan to use the data"
              ></textarea>
            </div>

            <button type="submit">Send the file</button>
          </form>
        </section>
      )}

      <!-- 3. EMBED CHART -->
      {hasEmbeds && (
        <section class="outreach-card">
          <h3>Embed a chart</h3>
          <p class="outreach-card-body">
            Drop any of these charts into your story. The image links back to the source page so credit travels with the visual.
          </p>
          <p class="outreach-attribution-note">Free to use with attribution. Link back to azlawnow.com.</p>
          <ul class="outreach-embed-list">
            {embeddableCharts.map(chart => {
              const imgSrc = chart.imageUrl || `/embeds/${chart.id}/master.png`;
              const w = chart.width || 1200;
              const h = chart.height || 675;
              const embedSnippet = `<a href="${url}"><img src="https://azlawnow.com${imgSrc}" alt="${chart.title}" width="${w}" height="${h}" /></a>`;
              return (
                <li class="outreach-embed-item">
                  <div class="outreach-embed-title">{chart.title}</div>
                  <div class="outreach-embed-row">
                    <input class="outreach-embed-code" type="text" readonly value={embedSnippet} aria-label={`Embed code for ${chart.title}`} />
                    <button class="outreach-copy" type="button" data-copy={embedSnippet}>Copy</button>
                  </div>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      <!-- 4. METHODOLOGY -->
      {hasMethodology && (
        <section class="outreach-card">
          <h3>Methodology snapshot</h3>
          <dl class="outreach-method-dl">
            {methodology?.dataSources && methodology.dataSources.length > 0 && (
              <div class="outreach-method-row">
                <dt>Data sources</dt>
                <dd>
                  <ul>
                    {methodology.dataSources.map(s => <li>{s}</li>)}
                  </ul>
                </dd>
              </div>
            )}
            {methodology?.processing && (
              <div class="outreach-method-row">
                <dt>Processing notes</dt>
                <dd><p>{methodology.processing}</p></dd>
              </div>
            )}
            {methodology?.limitations && methodology.limitations.length > 0 && (
              <div class="outreach-method-row">
                <dt>Limitations</dt>
                <dd>
                  <ul>
                    {methodology.limitations.map(l => <li>{l}</li>)}
                  </ul>
                </dd>
              </div>
            )}
            {methodology?.peerReview && (
              <div class="outreach-method-row">
                <dt>Peer review</dt>
                <dd><p>{methodology.peerReview}</p></dd>
              </div>
            )}
            {methodology?.lastUpdated && (
              <div class="outreach-method-row">
                <dt>Last updated</dt>
                <dd><p><time datetime={methodology.lastUpdated}>{methodology.lastUpdated}</time></p></dd>
              </div>
            )}
          </dl>
        </section>
      )}

      <!-- 5. CONTACT THE DESK -->
      <section class="outreach-card">
        <h3>Contact the desk</h3>
        <p class="outreach-card-body">
          Brendan Franks, On Record. Press inquiries answered within one business day.
        </p>
        <p class="outreach-direct">
          <a href="mailto:editor@azlawnow.com">editor@azlawnow.com</a>
        </p>
      </section>

      <!-- 6. SUBSCRIBE TO DATA DROPS -->
      <section class="outreach-card outreach-subscribe">
        <h3>Subscribe to the AZ Law Now data drop</h3>
        <p class="outreach-card-body">
          Quarterly Arizona data dispatch. No marketing.
        </p>
        <form
          name="az-data-drops"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/thank-you/"
          class="outreach-subscribe-form"
        >
          <input type="hidden" name="form-name" value="az-data-drops" />
          <p class="hidden"><label>Don't fill: <input name="bot-field" /></label></p>
          <div class="outreach-subscribe-row">
            <label class="outreach-visually-hidden" for={`subscribe-email-${slug}`}>Email address</label>
            <input
              id={`subscribe-email-${slug}`}
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@outlet.com"
            />
            <button type="submit">Subscribe</button>
          </div>
        </form>
      </section>

    </div>

    <p class="outreach-secondary">
      If you were injured in Arizona and need a lawyer, get a <a href="/free-case-review/">free consultation</a>.
    </p>

  </div>
</aside>

<script>
  // Tab + copy handlers, scoped per page
  document.querySelectorAll<HTMLElement>('.outreach-block').forEach(block => {
    const tabs = block.querySelectorAll<HTMLButtonElement>('.outreach-tab');
    const panels = block.querySelectorAll<HTMLElement>('[data-panel]');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => {
          t.classList.remove('outreach-tab-active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('outreach-tab-active');
        tab.setAttribute('aria-selected', 'true');
        panels.forEach(p => {
          if (p.dataset.panel === target) {
            p.classList.add('outreach-citation-active');
            p.removeAttribute('hidden');
          } else {
            p.classList.remove('outreach-citation-active');
            p.setAttribute('hidden', '');
          }
        });
      });
    });

    block.querySelectorAll<HTMLButtonElement>('.outreach-copy').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy || '';
        const original = btn.textContent;
        const live = btn.closest('section')?.querySelector('.outreach-aria-live');
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch {}
          document.body.removeChild(ta);
        }
        btn.textContent = 'Copied';
        if (live) live.textContent = 'Copied to clipboard.';
        setTimeout(() => { btn.textContent = original; if (live) live.textContent = ''; }, 2000);
      });
    });
  });
</script>

<style>
  .outreach-block {
    background: var(--color-bg, #FAF5ED);
    border-top: 1px solid var(--neutral-200, #E8DDD0);
    padding: var(--space-16, 4rem) 0;
    margin-top: var(--space-16, 4rem);
  }

  .outreach-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 var(--container-padding, 1.5rem);
  }

  .outreach-header {
    text-align: center;
    margin-bottom: var(--space-10, 2.5rem);
  }

  .outreach-eyebrow {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-text, #8B4513);
    margin: 0 0 var(--space-2, 0.5rem);
  }

  .outreach-header h2 {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.005em;
  }

  .outreach-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6, 1.5rem);
  }

  @media (min-width: 900px) {
    .outreach-grid {
      grid-template-columns: 1fr 1fr;
    }
    .outreach-subscribe {
      grid-column: 1 / -1;
    }
  }

  .outreach-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--neutral-200, #E8DDD0);
    border-radius: var(--radius-lg, 8px);
    padding: var(--space-8, 2rem);
    box-shadow: var(--shadow-sm, 0 2px 4px rgba(26, 26, 26, 0.06));
  }

  .outreach-card h3 {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 var(--space-3, 0.75rem);
    line-height: 1.2;
    letter-spacing: -0.005em;
  }

  .outreach-card-body {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.9375rem;
    color: var(--neutral-700, #4A5859);
    line-height: 1.65;
    margin: 0 0 var(--space-4, 1rem);
  }

  .outreach-direct {
    margin: var(--space-4, 1rem) 0;
  }

  .outreach-direct a {
    color: var(--color-gold-text, #8B4513);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(139, 69, 19, 0.35);
    transition: color var(--transition-base, 0.2s ease), border-color var(--transition-base, 0.2s ease);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
  }

  .outreach-direct a:hover {
    color: var(--color-red, #C23B22);
    border-bottom-color: var(--color-red, #C23B22);
  }

  .outreach-secondary-line {
    font-size: 0.8125rem;
    color: var(--neutral-600, #6B6259);
    margin: var(--space-2, 0.5rem) 0 var(--space-4, 1rem);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
  }

  .outreach-attribution-note {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.75rem;
    color: var(--color-gold-text, #8B4513);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin: 0 0 var(--space-4, 1rem);
  }

  /* Forms */
  .outreach-card form {
    margin: var(--space-4, 1rem) 0 0;
  }

  .outreach-form-group {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space-4, 1rem);
  }

  .outreach-form-group label {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 0.375rem;
  }

  .outreach-form-group input,
  .outreach-form-group textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--neutral-300, #D4C9BB);
    border-radius: var(--radius-md, 6px);
    font-size: 0.9375rem;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    background: var(--color-bg, #FAF5ED);
    color: #1A1A1A;
    transition: border-color var(--transition-fast, 0.15s ease), box-shadow var(--transition-fast, 0.15s ease);
  }

  .outreach-form-group input::placeholder,
  .outreach-form-group textarea::placeholder {
    color: var(--neutral-500, #8C8276);
  }

  .outreach-form-group input:focus,
  .outreach-form-group textarea:focus {
    outline: none;
    border-color: var(--color-gold, #D4943A);
    box-shadow: 0 0 0 3px rgba(212, 148, 58, 0.18);
  }

  .outreach-form-group textarea {
    resize: vertical;
    min-height: 60px;
  }

  .outreach-card form button[type="submit"] {
    padding: 0.875rem 2rem;
    background: var(--color-gold, #D4943A);
    color: #1A1A1A;
    border: none;
    border-radius: var(--radius-md, 6px);
    font-size: 0.9375rem;
    font-weight: 700;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    cursor: pointer;
    transition: background var(--transition-base, 0.2s ease), color var(--transition-base, 0.2s ease);
    letter-spacing: 0.01em;
    min-height: 44px;
  }

  .outreach-card form button[type="submit"]:hover {
    background: var(--color-gold-hover, #C2842E);
    color: var(--color-white, #FFFFFF);
  }

  .outreach-card form button[type="submit"]:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: 2px;
  }

  /* Cite tabs */
  .outreach-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--neutral-200, #E8DDD0);
    margin-bottom: var(--space-4, 1rem);
  }

  .outreach-tab {
    padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--neutral-600, #6B6259);
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s ease);
    margin-bottom: -1px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
  }

  .outreach-tab:hover {
    color: #1A1A1A;
  }

  .outreach-tab-active {
    color: var(--color-gold-text, #8B4513);
    border-bottom-color: var(--color-gold, #D4943A);
  }

  .outreach-citation {
    display: none;
  }

  .outreach-citation-active {
    display: block;
  }

  .outreach-citation pre {
    background: var(--neutral-100, #F5EDE0);
    color: #1A1A1A;
    border: 1px solid var(--neutral-200, #E8DDD0);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    line-height: 1.6;
    padding: var(--space-4, 1rem);
    border-radius: var(--radius-md, 6px);
    margin: 0 0 var(--space-3, 0.75rem);
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 220px;
    overflow-y: auto;
  }

  .outreach-copy {
    padding: 0.5rem 1rem;
    background: var(--color-white, #FFFFFF);
    color: var(--color-gold-text, #8B4513);
    border: 1px solid var(--color-gold, #D4943A);
    border-radius: var(--radius-md, 6px);
    font-size: 0.8125rem;
    font-weight: 700;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    cursor: pointer;
    transition: background var(--transition-fast, 0.15s ease), color var(--transition-fast, 0.15s ease);
    white-space: nowrap;
    min-height: 36px;
  }

  .outreach-copy:hover {
    background: var(--color-gold, #D4943A);
    color: #1A1A1A;
  }

  .outreach-copy:focus-visible {
    outline: 2px solid var(--color-gold-text, #8B4513);
    outline-offset: 2px;
  }

  /* Methodology dl */
  .outreach-method-dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 1rem);
  }

  .outreach-method-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1, 0.25rem);
    padding-bottom: var(--space-4, 1rem);
    border-bottom: 1px solid var(--neutral-200, #E8DDD0);
  }

  .outreach-method-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (min-width: 600px) {
    .outreach-method-row {
      grid-template-columns: 140px 1fr;
      gap: var(--space-4, 1rem);
    }
  }

  .outreach-method-row dt {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold-text, #8B4513);
    margin: 0;
  }

  .outreach-method-row dd {
    margin: 0;
    font-size: 0.875rem;
    color: var(--neutral-700, #4A5859);
    line-height: 1.6;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
  }

  .outreach-method-row dd p {
    margin: 0;
  }

  .outreach-method-row dd ul {
    margin: 0;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .outreach-method-row dd li {
    margin-bottom: 0.25rem;
  }

  .outreach-method-row dd li::marker {
    color: var(--color-gold, #D4943A);
  }

  /* Embed list */
  .outreach-embed-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .outreach-embed-item {
    background: var(--neutral-100, #F5EDE0);
    border: 1px solid var(--neutral-200, #E8DDD0);
    border-radius: var(--radius-md, 6px);
    padding: 0.875rem;
  }

  .outreach-embed-title {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .outreach-embed-row {
