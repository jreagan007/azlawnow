---
/**
 * AZ Law Now Header Component
 * DARK sticky header — Southwestern editorial identity
 * NOT a clone of AEE Law's NYC authority vibe
 * Warm dark (#1A1A1A), vermillion accent strip, larger wordmark,
 * simpler nav rhythm, golden CTA warmth
 */

interface DropdownItem {
  label: string;
  href: string;
  description?: string;
}

interface DropdownGroup {
  heading: string;
  items: DropdownItem[];
}

interface NavItem {
  label: string;
  href: string;
  dropdown?: DropdownItem[];
  groupedDropdown?: DropdownGroup[];
  featured?: {
    label: string;
    href: string;
    description: string;
  };
}

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navItems: NavItem[] = [
  {
    label: 'Practice Areas',
    href: '/vehicle-crashes/car-accidents/',
    groupedDropdown: [
      {
        heading: 'Vehicle Crashes',
        items: [
          { label: 'Car Accidents', href: '/vehicle-crashes/car-accidents/' },
          { label: 'Truck Accidents', href: '/vehicle-crashes/truck-accidents/' },
          { label: 'Motorcycle Accidents', href: '/vehicle-crashes/motorcycle-accidents/' },
          { label: 'Pedestrian Accidents', href: '/vehicle-crashes/pedestrian-accidents/' },
          { label: 'Bus Accidents', href: '/vehicle-crashes/bus-accidents/' },
          { label: 'Bicycle Accidents', href: '/vehicle-crashes/bicycle-accidents/' },
          { label: 'Rideshare Accidents', href: '/vehicle-crashes/rideshare-accidents/' },
        ],
      },
      {
        heading: 'Abuse & Negligence',
        items: [
          { label: 'Elder Abuse', href: '/abuse-negligence/elder-abuse/' },
          { label: 'Nursing Home Abuse', href: '/abuse-negligence/nursing-home-abuse/' },
          { label: 'Child Abuse', href: '/abuse-negligence/child-abuse/' },
          { label: 'Daycare Negligence', href: '/abuse-negligence/daycare-negligence/' },
          { label: 'School Abuse', href: '/abuse-negligence/school-abuse/' },
          { label: 'Medical Negligence', href: '/abuse-negligence/medical-negligence/' },
        ],
      },
      {
        heading: 'Other Claims',
        items: [
          { label: 'Slip and Fall', href: '/other-claims/slip-and-fall/' },
          { label: 'Dog Bite', href: '/other-claims/dog-bite/' },
          { label: 'Wrongful Death', href: '/other-claims/wrongful-death/' },
          { label: 'Premises Liability', href: '/other-claims/premises-liability/' },
        ],
      },
    ],
    featured: {
      label: 'Hurt in Arizona?',
      href: '/free-case-review/',
      description: 'Get a free case review from our West Valley team.',
    },
  },
  { label: 'Investigations', href: '/investigations/' },
  {
    label: 'Locations',
    href: '/buckeye/',
    groupedDropdown: [
      {
        heading: 'Primary',
        items: [
          { label: 'Buckeye', href: '/buckeye/' },
          { label: 'Maricopa', href: '/maricopa/' },
        ],
      },
      {
        heading: 'West Valley',
        items: [
          { label: 'Goodyear', href: '/goodyear/' },
          { label: 'Avondale', href: '/avondale/' },
          { label: 'Phoenix', href: '/phoenix/' },
        ],
      },
      {
        heading: 'Metro',
        items: [
          { label: 'Mesa', href: '/mesa/' },
          { label: 'Chandler', href: '/chandler/' },
          { label: 'Tempe', href: '/tempe/' },
          { label: 'Scottsdale', href: '/scottsdale/' },
        ],
      },
    ],
    featured: {
      label: 'Serving the West Valley',
      href: '/contact/',
      description: 'Two offices. Buckeye HQ and Maricopa.',
    },
  },
  { label: 'Results', href: '/case-results/' },
  { label: 'Team', href: '/about/team/' },
  {
    label: 'Resources',
    href: '/resources/',
    dropdown: [
      { label: 'Resources', href: '/resources/' },
      { label: 'Legal Guides', href: '/legal-guides/' },
      { label: 'Client Guides', href: '/client-guides/' },
      { label: 'Blog', href: '/blog/' },
    ],
  },
  { label: 'About', href: '/about/' },
];
---

<!-- Vermillion accent strip — brand signature (mirrors wordmark underline bar) -->
<div class="header-accent-strip" aria-hidden="true"></div>

<header class="header" id="site-header">
  <div class="header-container">
    <nav class="nav" aria-label="Main navigation">
      <!-- Wordmark — larger, light on dark -->
      <a href="/" class="logo" aria-label="AZ Law Now Home">
        <img
          src="/logos/logo-light-hz.png"
          alt="AZ Law Now — Answers Start Here"
          width="240"
          height="56"
          loading="eager"
          class="logo-img"
        />
      </a>

      <!-- Hamburger (mobile) -->
      <button
        class="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        onclick="toggleMobileMenu()"
        type="button"
      >
        <span class="hamburger-box">
          <span class="hamburger-inner"></span>
        </span>
      </button>

      <!-- Desktop nav -->
      <div class="nav-wrapper">
        <ul class="nav-links" role="menubar">
          {navItems.map((item, index) => (
            <li class={(item.dropdown || item.groupedDropdown) ? 'has-dropdown' : ''} role="none">
              {(item.dropdown || item.groupedDropdown) ? (
                <>
                  <button
                    class="nav-link dropdown-trigger"
                    aria-expanded="false"
                    aria-haspopup="true"
                    data-dropdown={index}
                  >
                    {item.label}
                    <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <div class={`dropdown-menu ${item.groupedDropdown ? 'dropdown-menu-grouped' : ''}`} data-dropdown-menu={index}>
                    <div class="dropdown-content">
                      {item.groupedDropdown ? (
                        <div class="dropdown-groups">
                          {item.groupedDropdown.map((group) => (
                            <div class="dropdown-group">
                              <span class="dropdown-group-heading">{group.heading}</span>
                              {group.items.map((subItem) => (
                                <a href={subItem.href} class="dropdown-item dropdown-item-compact">
                                  <span class="dropdown-item-label">{subItem.label}</span>
                                </a>
                              ))}
                            </div>
                          ))}
                        </div>
                      ) : (
                        <div class="dropdown-links">
                          {item.dropdown!.map((subItem) => (
                            <a href={subItem.href} class="dropdown-item">
                              <span class="dropdown-item-label">{subItem.label}</span>
                            </a>
                          ))}
                        </div>
                      )}
                      {item.featured && (
                        <div class="dropdown-featured">
                          <a href={item.featured.href} class="dd-featured-card">
                            <span class="dd-featured-label">{item.featured.label}</span>
                            <span class="dd-featured-desc">{item.featured.description}</span>
                            <span class="dd-featured-cta">Learn more &rarr;</span>
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                </>
              ) : (
                <a href={item.href} class:list={['nav-link', { active: currentPath === item.href }]} role="menuitem">
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ul>

        <!-- Phone CTA -->
        <div class="nav-phone-block">
          <span class="phone-tagline">Your Answers. One Call Away.</span>
          <a href="tel:+16026540202" class="phone-main">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="phone-number">(602) 654-0202</span>
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-inner">
    {navItems.map((item, index) => (
      <div class="mobile-nav-item">
        {(item.dropdown || item.groupedDropdown) ? (
          <>
            <button
              class="mobile-nav-link mobile-dropdown-trigger"
              aria-expanded="false"
              data-mobile-dropdown={index}
              onclick={`toggleMobileDropdown(${index})`}
              type="button"
            >
              {item.label}
              <svg class="mobile-dropdown-arrow" width="12" height="8" viewBox="0 0 10 6" fill="none">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="mobile-dropdown" data-mobile-dropdown-menu={index}>
              {item.groupedDropdown ? (
                item.groupedDropdown.map((group) => (
                  <>
                    <span class="mobile-group-heading">{group.heading}</span>
                    {group.items.map((subItem) => (
                      <a href={subItem.href} class="mobile-dropdown-link">{subItem.label}</a>
                    ))}
                  </>
                ))
              ) : (
                item.dropdown!.map((subItem) => (
                  <a href={subItem.href} class="mobile-dropdown-link">{subItem.label}</a>
                ))
              )}
            </div>
          </>
        ) : (
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        )}
      </div>
    ))}
    <div class="mobile-cta-wrapper">
      <a href="/free-case-review/" class="btn btn-primary mobile-cta">
        Get My Free Consultation
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="tel:+16026540202" class="btn btn-secondary mobile-phone">Call (602) 654-0202</a>
    </div>
  </div>
</div>

<style>
  /* ========================================
     ACCENT STRIP — 3px vermillion bar
     Mirrors the wordmark underline. Brand signature.
     ======================================== */
  .header-accent-strip {
    height: 3px;
    background: linear-gradient(90deg, #C23B22 0%, #C23B22 60%, #D4943A 100%);
    position: sticky;
    top: 0;
    z-index: calc(var(--z-sticky, 200) + 1);
  }

  /* ========================================
     HEADER — DARK theme
     ======================================== */
  .header {
    background: rgba(26, 26, 26, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(250, 245, 237, 0.06);
    position: sticky;
    top: 3px;
    z-index: var(--z-sticky, 200);
  }

  .header-container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 1.5rem);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo-img {
    height: 52px;
    width: auto;
  }

  .nav-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2rem;
  }

  .nav-wrapper .nav-links {
    flex: 1;
    justify-content: center;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links > li {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--neutral-300, #D4CFC6);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md, 6px);
    transition: all 0.15s ease;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-gold, #D4943A);
    background: rgba(212, 148, 58, 0.08);
  }

  .dropdown-trigger[aria-expanded="true"] {
    color: var(--color-gold, #D4943A);
    background: rgba(212, 148, 58, 0.1);
  }

  .dropdown-arrow { transition: transform 0.2s ease; }
  .dropdown-trigger[aria-expanded="true"] .dropdown-arrow { transform: rotate(180deg); }

  /* Phone CTA */
  .nav-phone-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    flex-shrink: 0;
  }

  .phone-tagline {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--neutral-500, #8C8276);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .phone-main {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .phone-main svg { color: var(--color-gold, #D4943A); }

  .phone-number {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--neutral-50, #FAF5ED);
  }

  .phone-main:hover .phone-number { color: var(--color-gold, #D4943A); }

  /* Dropdown Menus — dark */
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #222;
    border: 1px solid rgba(250, 245, 237, 0.08);
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    min-width: 680px;
    padding: 1.25rem;
    z-index: 100;
  }

  .has-dropdown:hover .dropdown-menu,
  .dropdown-trigger[aria-expanded="true"] + .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-content {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 1.5rem;
  }

  .dropdown-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.25rem;
  }

  .dropdown-item {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .dropdown-item:hover { background: rgba(212, 148, 58, 0.08); }

  .dropdown-item-label {
    font-weight: 500;
    color: var(--neutral-200, #E8DFD0);
    font-size: 0.875rem;
  }

  .dropdown-item:hover .dropdown-item-label { color: var(--color-gold, #D4943A); }

  .dropdown-menu-grouped { min-width: 720px; }

  .dropdown-groups { display: flex; gap: 1.5rem; }

  .dropdown-group { flex: 1; min-width: 0; }

  .dropdown-group-heading {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold, #D4943A);
    padding: 0 0.75rem 0.5rem;
    margin-bottom: 0.25rem;
    border-bottom: 1px solid rgba(250, 245, 237, 0.08);
  }

  .dropdown-item-compact { padding: 0.4375rem 0.75rem; }
  .dropdown-item-compact .dropdown-item-label { font-size: 0.875rem; }

  .dropdown-featured {
    border-left: 1px solid rgba(250, 245, 237, 0.08);
    padding-left: 1.25rem;
  }

  .dd-featured-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, #D4943A 0%, #C2842E 100%);
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    height: 100%;
    transition: transform 0.2s ease;
  }

  .dd-featured-card:hover { transform: translateY(-2px); }

  .dd-featured-label {
    font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
    font-weight: 700;
    color: #fff;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .dd-featured-desc {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
    flex: 1;
  }

  .dd-featured-cta {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    margin-top: 0.75rem;
  }

  /* Hamburger */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 310;
    -webkit-tap-highlight-color: rgba(212, 148, 58, 0.3);
  }

  .hamburger-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    position: relative;
  }

  .hamburger-inner {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--neutral-200, #E8DFD0);
    border-radius: 2px;
    position: relative;
    transition: background 0.15s ease;
  }

  .hamburger-inner::before,
  .hamburger-inner::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 2px;
    background: var(--neutral-200, #E8DFD0);
    border-radius: 2px;
    left: 0;
    transition: all 0.2s ease;
  }

  .hamburger-inner::before { top: -7px; }
  .hamburger-inner::after { top: 7px; }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-inner { background: transparent; }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-inner::before { top: 0; transform: rotate(45deg); background: #D4943A; }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-inner::after { top: 0; transform: rotate(-45deg); background: #D4943A; }

  @media (max-width: 1024px) {
    .nav-wrapper { display: none; }
    .mobile-menu-btn { display: flex; }
  }

  .nav-link:focus-visible,
  .phone-main:focus-visible,
  .dropdown-item:focus-visible,
  .mobile-menu-btn:focus-visible {
    outline: 2px solid #D4943A;
    outline-offset: 2px;
  }
</style>

<style is:global>
  /* Mobile Menu — dark */
  .mobile-menu {
    position: fixed;
    top: 83px;
    left: 0;
    right: 0;
    bottom: 0;
    background: #1A1A1A;
    z-index: 300;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    visibility: hidden;
  }

  .mobile-menu.active { transform: translateX(0); visibility: visible; }

  .mobile-menu-inner { padding: 1rem 1.5rem 2rem; }

  .mobile-nav-item { border-bottom: 1px solid rgba(250, 245, 237, 0.06); }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #E8DFD0;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    text-align: left;
  }

  .mobile-dropdown-arrow { color: #8C8276; transition: transform 0.2s ease; }
  .mobile-dropdown-trigger[aria-expanded="true"] .mobile-dropdown-arrow { transform: rotate(180deg); }
  .mobile-dropdown-trigger[aria-expanded="true"] { color: #D4943A; }

  .mobile-dropdown { display: none; padding-bottom: 0.5rem; }
  .mobile-dropdown.active { display: block; }

  .mobile-dropdown-link {
    display: block;
    padding: 0.625rem 0 0.625rem 1rem;
    font-size: 0.9375rem;
    color: #B0A696;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .mobile-dropdown-link:hover { color: #D4943A; }

  .mobile-group-heading {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #D4943A;
    padding: 0.75rem 0 0.25rem 1rem;
  }

  .mobile-group-heading:first-child { padding-top: 0.25rem; }

  .mobile-cta-wrapper { padding-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }

  /* Layout overrides — global .btn handles colors/font/transitions */
  .mobile-cta {
    width: 100%;
    max-width: none;
    font-size: 0.9375rem;
    padding: 1rem 1.5rem;
  }

  .mobile-phone {
    width: 100%;
    max-width: none;
    font-size: 0.9375rem;
    padding: 1rem 1.5rem;
    border-color: var(--color-gold, #D4943A);
    color: var(--color-gold, #D4943A);
  }
</style>

<script is:inline>
  function toggleMobileMenu() {
    var btn = document.querySelector('.mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    var isOpen = menu.classList.contains('active');
    if (isOpen) {
      menu.classList.remove('active');
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    } else {
      menu.classList.add('active');
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  }

  function toggleMobileDropdown(index) {
    var trigger = document.querySelector('[data-mobile-dropdown="' + index + '"]');
    var dropdown = document.querySelector('[data-mobile-dropdown-menu="' + index + '"]');
    if (!trigger || !dropdown) return;
    var isOpen = dropdown.classList.contains('active');
    trigger.setAttribute('aria-expanded', !isOpen);
    dropdown.classList.toggle('active');
  }

  document.addEventListener('click', function(e) {
    if (!e.target || !e.target.closest) return;
    var link = e.target.closest('.mobile-menu a:not(.mobile-dropdown-trigger)');
    if (link) {
      var menu = document.getElementById('mobile-menu');
      var btn = document.querySelector('.mobile-menu-btn');
      if (menu) { menu.classList.remove('active'); menu.setAttribute('aria-hidden', 'true'); }
      if (btn) { btn.setAttribute('aria-expanded', 'false'); }
      document.body.style.overflow = '';
    }
    var dropdownTrigger = e.target.closest('.dropdown-trigger');
    if (dropdownTrigger) {
      e.preventDefault();
      var expanded = dropdownTrigger.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.dropdown-trigger').forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
      dropdownTrigger.setAttribute('aria-expanded', !expanded);
    }
    if (!e.target.closest('.has-dropdown')) {
      document.querySelectorAll('.dropdown-trigger').forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
    }
  });

  document.addEventListener('mouseenter', function(e) {
    if (!e.target || !e.target.closest) return;
    var d = e.target.closest('.has-dropdown');
    if (d) { var t = d.querySelector('.dropdown-trigger'); if (t) t.setAttribute('aria-expanded', 'true'); }
  }, true);

  document.addEventListener('mouseleave', function(e) {
    if (!e.target || !e.target.closest) return;
    var d = e.target.closest('.has-dropdown');
    if (d) { var t = d.querySelector('.dropdown-trigger'); if (t) t.setAttribute('aria-expanded', 'false'); }
  }, true);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.dropdown-trigger').forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
      var menu = document.getElementById('mobile-menu');
      var btn = document.querySelector('.mobile-menu-btn');
      if (menu && menu.classList.contains('active')) {
        menu.classList.remove('active');
        menu.setAttribute('aria-hidden', 'true');
        if (btn) btn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }
  });
</script>
